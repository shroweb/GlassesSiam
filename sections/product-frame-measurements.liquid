<section class="pfm-section">
  <div class="container">
    <h3 class="pfm-heading">{{ section.settings.heading }}</h3>
    <div class="pfm-divider"></div>

    <div class="pfm-inner">

      {%- comment -%} Side-view product image {%- endcomment -%}
      <div class="pfm-img-col">
        {%- if section.settings.measurements_image != blank -%}
        <img
          src="{{ section.settings.measurements_image | image_url: width: 500 }}"
          alt="{{ section.settings.measurements_image.alt | default: product.title | escape }}"
          class="pfm-img"
          loading="lazy"
          width="500"
          height="340">
        {%- elsif product.featured_image != blank -%}
        <img
          src="{{ product.featured_image | image_url: width: 500 }}"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          class="pfm-img"
          loading="lazy"
          width="500"
          height="340">
        {%- endif -%}
      </div>

      {%- comment -%} Measurements table {%- endcomment -%}
      <div class="pfm-table-col">
        <table class="pfm-table">
          <thead>
            <tr>
              {%- if product.metafields.custom.lens_width != blank -%}
              <th>{{ section.settings.label_lens_width }}</th>
              {%- endif -%}
              {%- if product.metafields.custom.lens_height != blank -%}
              <th>{{ section.settings.label_lens_height }}</th>
              {%- endif -%}
              {%- if product.metafields.custom.bridge_width != blank -%}
              <th>{{ section.settings.label_bridge_width }}</th>
              {%- endif -%}
              {%- if product.metafields.custom.temple_length != blank -%}
              <th>{{ section.settings.label_temple_length }}</th>
              {%- endif -%}
            </tr>
          </thead>
          <tbody>
            <tr class="pfm-icons-row">
              {%- if product.metafields.custom.lens_width != blank -%}
              <td>
                {%- comment -%} Lens width icon — horizontal arrows through lens {%- endcomment -%}
                <svg class="pfm-diagram" width="52" height="32" viewBox="0 0 52 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="12" y="4" width="28" height="24" rx="5" stroke="#4a90d9" stroke-width="2"/>
                  <line x1="0" y1="16" x2="52" y2="16" stroke="#4a90d9" stroke-width="1.5" stroke-dasharray="3 2"/>
                  <polyline points="4,12 0,16 4,20" stroke="#4a90d9" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
                  <polyline points="48,12 52,16 48,20" stroke="#4a90d9" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
                </svg>
              </td>
              {%- endif -%}
              {%- if product.metafields.custom.lens_height != blank -%}
              <td>
                {%- comment -%} Lens height icon — vertical arrows through lens {%- endcomment -%}
                <svg class="pfm-diagram" width="40" height="48" viewBox="0 0 40 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="6" y="10" width="28" height="28" rx="5" stroke="#4a90d9" stroke-width="2"/>
                  <line x1="20" y1="0" x2="20" y2="48" stroke="#4a90d9" stroke-width="1.5" stroke-dasharray="3 2"/>
                  <polyline points="16,4 20,0 24,4" stroke="#4a90d9" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
                  <polyline points="16,44 20,48 24,44" stroke="#4a90d9" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
                </svg>
              </td>
              {%- endif -%}
              {%- if product.metafields.custom.bridge_width != blank -%}
              <td>
                {%- comment -%} Bridge width icon — two circles with arrows between {%- endcomment -%}
                <svg class="pfm-diagram" width="60" height="32" viewBox="0 0 60 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="1" y="4" width="22" height="24" rx="5" stroke="#4a90d9" stroke-width="2"/>
                  <rect x="37" y="4" width="22" height="24" rx="5" stroke="#4a90d9" stroke-width="2"/>
                  <line x1="23" y1="16" x2="37" y2="16" stroke="#4a90d9" stroke-width="1.5" stroke-dasharray="3 2"/>
                  <polyline points="27,12 23,16 27,20" stroke="#4a90d9" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
                  <polyline points="33,12 37,16 33,20" stroke="#4a90d9" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
                </svg>
              </td>
              {%- endif -%}
              {%- if product.metafields.custom.temple_length != blank -%}
              <td>
                {%- comment -%} Temple length icon — angled arm with arrow {%- endcomment -%}
                <svg class="pfm-diagram" width="52" height="40" viewBox="0 0 52 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <rect x="1" y="4" width="22" height="20" rx="5" stroke="#4a90d9" stroke-width="2"/>
                  <line x1="23" y1="14" x2="51" y2="38" stroke="#4a90d9" stroke-width="2"/>
                  <polyline points="43,29 51,38 41,38" stroke="#4a90d9" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
                </svg>
              </td>
              {%- endif -%}
            </tr>
            <tr class="pfm-values-row">
              {%- if product.metafields.custom.lens_width != blank -%}
              <td>{{ product.metafields.custom.lens_width }}</td>
              {%- endif -%}
              {%- if product.metafields.custom.lens_height != blank -%}
              <td>{{ product.metafields.custom.lens_height }}</td>
              {%- endif -%}
              {%- if product.metafields.custom.bridge_width != blank -%}
              <td>{{ product.metafields.custom.bridge_width }}</td>
              {%- endif -%}
              {%- if product.metafields.custom.temple_length != blank -%}
              <td>{{ product.metafields.custom.temple_length }}</td>
              {%- endif -%}
            </tr>
          </tbody>
        </table>

        {%- if section.settings.find_my_size_url != blank -%}
        <p class="pfm-find-size">
          {{ section.settings.find_my_size_prefix }}
          <a href="{{ section.settings.find_my_size_url }}" class="pfm-find-size-link">{{ section.settings.find_my_size_label }}</a>
        </p>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Frame Measurements",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frame Measurements:"
    },
    {
      "type": "image_picker",
      "id": "measurements_image",
      "label": "Side-view image (optional — falls back to product image)"
    },
    {
      "type": "header",
      "content": "Column Labels"
    },
    {
      "type": "text",
      "id": "label_lens_width",
      "label": "Lens Width label",
      "default": "Lens Width:"
    },
    {
      "type": "text",
      "id": "label_lens_height",
      "label": "Lens Height label",
      "default": "Lens Height:"
    },
    {
      "type": "text",
      "id": "label_bridge_width",
      "label": "Bridge Width label",
      "default": "Bridge Width:"
    },
    {
      "type": "text",
      "id": "label_temple_length",
      "label": "Temple Length label",
      "default": "Temple Length:"
    },
    {
      "type": "header",
      "content": "Find My Size Link"
    },
    {
      "type": "text",
      "id": "find_my_size_prefix",
      "label": "Prefix text",
      "default": "Need help finding your size?"
    },
    {
      "type": "text",
      "id": "find_my_size_label",
      "label": "Link text",
      "default": "Find My Size"
    },
    {
      "type": "url",
      "id": "find_my_size_url",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding Top (desktop)",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding Bottom (desktop)",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_top_xs",
      "label": "Padding Top (mobile)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_bottom_xs",
      "label": "Padding Bottom (mobile)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Frame Measurements"
    }
  ]
}
{% endschema %}

<style>
.pfm-section {
  padding-top: {{ section.settings.section_padding_top }}px;
  padding-bottom: {{ section.settings.section_padding_bottom }}px;
}
@media (max-width: 767px) {
  .pfm-section {
    padding-top: {{ section.settings.section_padding_top_xs }}px;
    padding-bottom: {{ section.settings.section_padding_bottom_xs }}px;
  }
}

.pfm-heading {
  font-size: 18px;
  font-weight: 700;
  color: #111;
  margin-bottom: 14px;
}
.pfm-divider {
  border-top: 1.5px solid #e5e5e5;
  margin-bottom: 36px;
}
.pfm-inner {
  display: flex;
  align-items: center;
  gap: 48px;
}
@media (max-width: 767px) {
  .pfm-inner {
    flex-direction: column;
    gap: 24px;
    align-items: flex-start;
  }
}

/* Image */
.pfm-img-col {
  flex: 0 0 auto;
  max-width: 280px;
}
.pfm-img {
  width: 100%;
  height: auto;
  display: block;
}
@media (max-width: 767px) {
  .pfm-img-col {
    max-width: 220px;
  }
}

/* Table */
.pfm-table-col {
  flex: 1;
}
.pfm-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
}
.pfm-table thead tr {
  background: #f7f9fb;
}
.pfm-table thead th {
  padding: 14px 20px;
  text-align: center;
  font-weight: 600;
  color: #444;
  border: 1px solid #e5e5e5;
  font-size: 14px;
}
.pfm-icons-row td {
  padding: 18px 20px;
  text-align: center;
  border: 1px solid #e5e5e5;
  background: #fff;
}
.pfm-values-row td {
  padding: 14px 20px;
  text-align: center;
  font-size: 14px;
  color: #333;
  border: 1px solid #e5e5e5;
  background: #fff;
  white-space: nowrap;
}
.pfm-diagram {
  display: block;
  margin: 0 auto;
}
@media (max-width: 600px) {
  .pfm-table thead th,
  .pfm-icons-row td,
  .pfm-values-row td {
    padding: 10px 8px;
    font-size: 12px;
  }
}

/* Find my size */
.pfm-find-size {
  margin-top: 16px;
  font-size: 14px;
  color: #555;
}
.pfm-find-size-link {
  color: var(--font-color-primary, #113071);
  font-weight: 600;
  text-decoration: none;
  margin-left: 5px;
}
.pfm-find-size-link:hover {
  text-decoration: underline;
}
</style>
