{% comment %}
  Editorial Split Section
  - Two column layout
  - Text + image
  - Reusable trust icon blocks
{% endcomment %}

<section
  class="editorial-split"
  style="background-color: {{ section.settings.background_color }};"
>
  <div class="editorial-split__inner {% if section.settings.flip_layout %}is-flipped{% endif %}">

    <!-- Text Column -->
    <div class="editorial-split__content">
      {% if section.settings.heading != blank %}
        <h2>{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="editorial-split__text">
          {{ section.settings.text }}
        </div>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <ul class="editorial-split__features">
          {% for block in section.blocks %}
            <li class="feature-item">
              {% if block.settings.icon != blank %}
        <img
        src="{{ block.settings.icon | image_url: width: 40 }}"
        alt=""
        loading="lazy"
        />
                    {% endif %}
              <span>{{ block.settings.label }}</span>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>

    <!-- Image Column -->
    <div class="editorial-split__media">
      {% if section.settings.image != blank %}
        <img
          src="{{ section.settings.image | image_url: width: 1200 }}"
          alt="{{ section.settings.heading | escape }}"
          loading="lazy"
        >
      {% endif %}
    </div>

  </div>
</section>

{% style %}
.editorial-split {
  padding: 6rem 2rem;
}

.editorial-split__inner {
  max-width: 1200px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.1fr 1fr;
  gap: 4rem;
  align-items: center;
}

.editorial-split__inner.is-flipped {
  grid-template-columns: 1fr 1.1fr;
}

.editorial-split__inner.is-flipped .editorial-split__content {
  order: 2;
}

.editorial-split__inner.is-flipped .editorial-split__media {
  order: 1;
}

.editorial-split__content h2 {
  font-size: clamp(2rem, 4vw, 3rem);
  margin-bottom: 1.5rem;
}

.editorial-split__text {
  font-size: 1rem;
  line-height: 1.7;
  color: #444;
  max-width: 520px;
}

.editorial-split__features {
  margin-top: 2.5rem;
  display: flex;
  gap: 2rem;
  flex-wrap: wrap;
  list-style: none;
  padding: 0;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.95rem;
  color: #222;
}

.editorial-split__media img {
  width: 100%;
  height: auto;
  border-radius: 1.5rem;
  display: block;
}

@media (max-width: 900px) {
  .editorial-split__inner {
    grid-template-columns: 1fr;
  }

  .editorial-split__inner.is-flipped .editorial-split__content,
  .editorial-split__inner.is-flipped .editorial-split__media {
    order: unset;
  }
}
{% endstyle %}

{% schema %}
{
  "name": "Editorial split",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "State-of-the-art lenses."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>In our profession, quality is paramount...</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background colour",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "flip_layout",
      "label": "Flip image and text",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "FDA-listed"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial split",
      "blocks": [
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" }
      ]
    }
  ]
}
{% endschema %}