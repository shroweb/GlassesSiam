{%- assign current_variant = product.selected_or_first_available_variant -%}

<section class="product-about-tabs-section" id="product-about-tabs">
  <div class="container">

    {%- comment -%} Tab Navigation {%- endcomment -%}
    <div class="pat-tab-nav">
      <button class="pat-tab-btn pat-tab-btn--active" data-tab="about">
        <span class="pat-tab-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/></svg>
        </span>
        {{ section.settings.tab_about_title }}
      </button>
      <button class="pat-tab-btn" data-tab="shipping">
        <span class="pat-tab-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </span>
        {{ section.settings.tab_shipping_title }}
      </button>
    </div>
    <div class="pat-tab-divider"></div>

    {%- comment -%} About the Frame Tab {%- endcomment -%}
    <div class="pat-tab-content pat-tab-content--active" id="pat-tab-about">

      {%- comment -%} Description + Specs Grid {%- endcomment -%}
      <div class="pat-about-grid">
        <div class="pat-about-desc">
          <h3 class="pat-about-title">{{ product.title }}</h3>
          <div class="pat-about-text">{{ product.description }}</div>
        </div>
        <div class="pat-specs-table-wrap">
          <table class="pat-specs-table">
            <tbody>
              {%- assign specs = '' -%}
              {%- if product.metafields.custom.size != blank or product.metafields.custom.color != blank -%}
              <tr>
                <th>{{ section.settings.label_size }}</th>
                <td>{{ product.metafields.custom.size | default: '—' }}</td>
                <th>{{ section.settings.label_color }}</th>
                <td>{{ product.metafields.custom.color | default: '—' }}</td>
              </tr>
              {%- endif -%}
              {%- if product.metafields.custom.material != blank or product.metafields.custom.gender != blank -%}
              <tr>
                <th>{{ section.settings.label_material }}</th>
                <td>{{ product.metafields.custom.material | default: '—' }}</td>
                <th>{{ section.settings.label_gender }}</th>
                <td>{{ product.metafields.custom.gender | default: '—' }}</td>
              </tr>
              {%- endif -%}
              {%- if product.metafields.custom.shape != blank or product.metafields.custom.frame_type != blank -%}
              <tr>
                <th>{{ section.settings.label_shape }}</th>
                <td>{{ product.metafields.custom.shape | default: '—' }}</td>
                <th>{{ section.settings.label_type }}</th>
                <td>{{ product.metafields.custom.frame_type | default: '—' }}</td>
              </tr>
              {%- endif -%}
              {%- if product.metafields.custom.spring_hinges != blank or product.metafields.custom.lens_feature != blank -%}
              <tr>
                <th>{{ section.settings.label_spring_hinges }}</th>
                <td>{{ product.metafields.custom.spring_hinges | default: '—' }}</td>
                <th>{{ section.settings.label_lens_feature }}</th>
                <td>{{ product.metafields.custom.lens_feature | default: '—' }}</td>
              </tr>
              {%- endif -%}
              {%- if product.metafields.custom.progressive_bifocal != blank -%}
              <tr>
                <th>{{ section.settings.label_progressive }}</th>
                <td>{{ product.metafields.custom.progressive_bifocal | default: '—' }}</td>
                <th></th>
                <td></td>
              </tr>
              {%- endif -%}
            </tbody>
          </table>
        </div>
      </div>

      {%- comment -%} Expandable Features Section {%- endcomment -%}
      {%- assign has_features = false -%}
      {%- for i in (1..6) -%}
        {%- assign key = 'feature_' | append: i -%}
        {%- if section.settings[key] != blank -%}{%- assign has_features = true -%}{%- endif -%}
      {%- endfor -%}

      {%- if has_features or section.settings.feature_image_1 != blank or section.settings.feature_image_2 != blank or section.settings.lifestyle_image != blank -%}
      <div class="pat-features-wrap" id="pat-features-wrap">
        <div class="pat-features-inner pat-features-collapsed" id="pat-features-inner">
          <div class="pat-features-row">

            {%- comment -%} Feature checklist {%- endcomment -%}
            <div class="pat-features-list-col">
              <ul class="pat-features-list">
                {%- for i in (1..6) -%}
                  {%- assign key = 'feature_' | append: i -%}
                  {%- if section.settings[key] != blank -%}
                  <li class="pat-features-item">
                    <span class="pat-features-check">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </span>
                    <span>{{ section.settings[key] }}</span>
                  </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            </div>

            {%- comment -%} Feature images {%- endcomment -%}
            {%- if section.settings.feature_image_1 != blank -%}
            <div class="pat-features-img-col">
              <img src="{{ section.settings.feature_image_1 | image_url: width: 500 }}" alt="{{ section.settings.feature_image_1.alt | escape }}" class="pat-features-img" loading="lazy" width="500" height="400">
            </div>
            {%- endif -%}
            {%- if section.settings.feature_image_2 != blank -%}
            <div class="pat-features-img-col">
              <img src="{{ section.settings.feature_image_2 | image_url: width: 500 }}" alt="{{ section.settings.feature_image_2.alt | escape }}" class="pat-features-img" loading="lazy" width="500" height="400">
            </div>
            {%- endif -%}
          </div>

          {%- comment -%} Lifestyle / 180° image {%- endcomment -%}
          {%- if section.settings.lifestyle_image != blank -%}
          <div class="pat-lifestyle-row">
            <div class="pat-lifestyle-img-wrap">
              {%- if section.settings.show_360_badge -%}
              <span class="pat-badge-360">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                180°
              </span>
              {%- endif -%}
              <img src="{{ section.settings.lifestyle_image | image_url: width: 900 }}" alt="{{ section.settings.lifestyle_image.alt | escape }}" class="pat-lifestyle-img" loading="lazy" width="900" height="600">
            </div>
          </div>
          {%- endif -%}
        </div>

        {%- comment -%} Show More / Show Less toggle {%- endcomment -%}
        <div class="pat-toggle-wrap">
          <button class="pat-toggle-btn" id="pat-toggle-btn" aria-expanded="false">
            <span class="pat-toggle-label-more">{{ section.settings.show_more_label }}</span>
            <span class="pat-toggle-label-less" style="display:none;">{{ section.settings.show_less_label }}</span>
            <svg class="pat-toggle-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
        </div>
      </div>
      {%- endif -%}

      {%- comment -%} Including Bar {%- endcomment -%}
      {%- assign has_includes = false -%}
      {%- for i in (1..4) -%}
        {%- assign key = 'include_label_' | append: i -%}
        {%- if section.settings[key] != blank -%}{%- assign has_includes = true -%}{%- endif -%}
      {%- endfor -%}
      {%- if has_includes -%}
      <div class="pat-includes-bar">
        <span class="pat-includes-label">{{ section.settings.includes_heading }}</span>
        <div class="pat-includes-items">
          {%- for i in (1..4) -%}
            {%- assign label_key = 'include_label_' | append: i -%}
            {%- assign icon_key = 'include_icon_' | append: i -%}
            {%- if section.settings[label_key] != blank -%}
            {%- unless forloop.first -%}<span class="pat-includes-divider">|</span>{%- endunless -%}
            <span class="pat-includes-item">
              {%- if section.settings[icon_key] != blank -%}
              <img src="{{ section.settings[icon_key] | image_url: width: 28 }}" alt="" class="pat-includes-icon" width="28" height="28" loading="lazy">
              {%- else -%}
              <svg class="pat-includes-icon-svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              {%- endif -%}
              {{ section.settings[label_key] }}
            </span>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
      {%- endif -%}

    </div>{%- comment -%} /pat-tab-about {%- endcomment -%}

    {%- comment -%} Shipping & Returns Tab {%- endcomment -%}
    <div class="pat-tab-content" id="pat-tab-shipping">
      <div class="pat-shipping-content">
        {{ section.settings.shipping_content }}
      </div>
    </div>

  </div>
</section>

<script>
(function() {
  var tabBtns = document.querySelectorAll('#product-about-tabs .pat-tab-btn');
  var tabContents = {
    'about': document.getElementById('pat-tab-about'),
    'shipping': document.getElementById('pat-tab-shipping')
  };
  tabBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      tabBtns.forEach(function(b) { b.classList.remove('pat-tab-btn--active'); });
      Object.values(tabContents).forEach(function(c) { if(c) c.classList.remove('pat-tab-content--active'); });
      btn.classList.add('pat-tab-btn--active');
      var target = tabContents[btn.getAttribute('data-tab')];
      if (target) target.classList.add('pat-tab-content--active');
    });
  });

  var toggleBtn = document.getElementById('pat-toggle-btn');
  var featuresInner = document.getElementById('pat-features-inner');
  if (toggleBtn && featuresInner) {
    toggleBtn.addEventListener('click', function() {
      var expanded = toggleBtn.getAttribute('aria-expanded') === 'true';
      toggleBtn.setAttribute('aria-expanded', !expanded);
      featuresInner.classList.toggle('pat-features-collapsed', expanded);
      featuresInner.classList.toggle('pat-features-expanded', !expanded);
      toggleBtn.querySelector('.pat-toggle-label-more').style.display = expanded ? '' : 'none';
      toggleBtn.querySelector('.pat-toggle-label-less').style.display = expanded ? 'none' : '';
      toggleBtn.querySelector('.pat-toggle-icon').style.transform = expanded ? '' : 'rotate(180deg)';
    });
  }
})();
</script>

