<style>
.product-about-tabs-section {
  padding-top: {{ section.settings.section_padding_top }}px;
  padding-bottom: {{ section.settings.section_padding_bottom }}px;
}
@media (max-width: 767px) {
  .product-about-tabs-section {
    padding-top: {{ section.settings.section_padding_top_xs }}px;
    padding-bottom: {{ section.settings.section_padding_bottom_xs }}px;
  }
}

/* ── Tab Navigation ── */
.pat-tab-nav {
  display: flex;
  gap: 8px;
  margin-bottom: 0;
}
.pat-tab-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 24px;
  font-size: 15px;
  font-weight: 600;
  color: #888;
  background: none;
  border: none;
  border-bottom: 3px solid transparent;
  cursor: pointer;
  transition: color 0.2s, border-color 0.2s;
  white-space: nowrap;
}
.pat-tab-btn:hover {
  color: #333;
}
.pat-tab-btn--active {
  color: #111;
  border-bottom-color: #111;
}
.pat-tab-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: #f0f0f0;
  flex-shrink: 0;
}
.pat-tab-btn--active .pat-tab-icon {
  background: #e8ecf5;
  color: var(--font-color-primary, #113071);
}
.pat-tab-divider {
  border-top: 1.5px solid #e5e5e5;
  margin-bottom: 36px;
}

/* ── Tab Content ── */
.pat-tab-content {
  display: none;
}
.pat-tab-content--active {
  display: block;
}

/* ── About: Description + Specs ── */
.pat-about-grid {
  display: grid;
  grid-template-columns: 1fr 1.3fr;
  gap: 48px;
  align-items: start;
  margin-bottom: 40px;
}
@media (max-width: 991px) {
  .pat-about-grid {
    grid-template-columns: 1fr;
    gap: 28px;
  }
}
.pat-about-title {
  font-size: 17px;
  font-weight: 700;
  margin-bottom: 12px;
  color: #111;
}
.pat-about-text {
  font-size: 14px;
  line-height: 1.7;
  color: #444;
}

/* Specs table */
.pat-specs-table-wrap {
  border: 1px solid #e5e5e5;
  border-radius: 8px;
  overflow: hidden;
}
.pat-specs-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 14px;
}
.pat-specs-table tr {
  border-bottom: 1px solid #e5e5e5;
}
.pat-specs-table tr:last-child {
  border-bottom: none;
}
.pat-specs-table th,
.pat-specs-table td {
  padding: 13px 16px;
  text-align: left;
  line-height: 1.4;
}
.pat-specs-table th {
  background: #f7f7f7;
  font-weight: 600;
  color: #444;
  width: 26%;
  white-space: nowrap;
}
.pat-specs-table td {
  color: #111;
  background: #fff;
  width: 24%;
}
@media (max-width: 767px) {
  .pat-specs-table th,
  .pat-specs-table td {
    padding: 10px 12px;
    font-size: 13px;
  }
}

/* ── Features Section ── */
.pat-features-wrap {
  margin-bottom: 32px;
}
.pat-features-inner {
  overflow: hidden;
  transition: max-height 0.45s ease;
}
.pat-features-collapsed {
  max-height: 340px;
}
.pat-features-expanded {
  max-height: 2000px;
}
.pat-features-row {
  display: grid;
  grid-template-columns: 220px 1fr 1fr;
  gap: 24px;
  align-items: stretch;
  margin-bottom: 24px;
}
@media (max-width: 767px) {
  .pat-features-row {
    grid-template-columns: 1fr 1fr;
  }
  .pat-features-list-col {
    grid-column: 1 / -1;
  }
}
.pat-features-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.pat-features-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 14px 16px;
  background: #f0f4fb;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 500;
  color: #222;
  line-height: 1.4;
}
.pat-features-check {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: #fff;
  color: var(--font-color-primary, #113071);
  flex-shrink: 0;
  margin-top: 1px;
}
.pat-features-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 8px;
  display: block;
}
.pat-features-img-col {
  border-radius: 8px;
  overflow: hidden;
}

/* Lifestyle row */
.pat-lifestyle-row {
  width: 100%;
}
.pat-lifestyle-img-wrap {
  position: relative;
  display: inline-block;
  width: 100%;
  max-width: 540px;
}
.pat-lifestyle-img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 8px;
}
.pat-badge-360 {
  position: absolute;
  top: 14px;
  right: 14px;
  display: flex;
  align-items: center;
  gap: 5px;
  background: #fff;
  border: 1px solid #ddd;
  border-radius: 20px;
  padding: 5px 10px;
  font-size: 13px;
  font-weight: 600;
  color: #333;
  box-shadow: 0 1px 4px rgba(0,0,0,0.1);
}

/* Show More / Less */
.pat-toggle-wrap {
  display: flex;
  justify-content: center;
  margin-top: 16px;
}
.pat-toggle-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 22px;
  background: #fff;
  border: 1.5px solid #ccc;
  border-radius: 24px;
  font-size: 14px;
  font-weight: 600;
  color: #333;
  cursor: pointer;
  transition: border-color 0.2s, color 0.2s;
}
