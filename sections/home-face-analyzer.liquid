<section class="home-face-analyzer">
  <div class="container">
    <div class="home-face-analyzer__card">
      <div class="home-face-analyzer__content">
        <p class="home-face-analyzer__eyebrow">{{ section.settings.eyebrow }}</p>
        <h2 class="home-face-analyzer__title">{{ section.settings.heading }}</h2>
        <div class="home-face-analyzer__actions">
          <button type="button" class="home-face-analyzer__chip" data-fsa-open data-fsa-category="eyeglasses">
            <span class="home-face-analyzer__chip-icon" aria-hidden="true">
              <svg viewBox="0 0 64 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 11.5C3 8.46243 5.46243 6 8.5 6H21.5C24.5376 6 27 8.46243 27 11.5V14.5C27 17.5376 24.5376 20 21.5 20H8.5C5.46243 20 3 17.5376 3 14.5V11.5Z" stroke="currentColor" stroke-width="2.5"/>
                <path d="M37 11.5C37 8.46243 39.4624 6 42.5 6H55.5C58.5376 6 61 8.46243 61 11.5V14.5C61 17.5376 58.5376 20 55.5 20H42.5C39.4624 20 37 17.5376 37 14.5V11.5Z" stroke="currentColor" stroke-width="2.5"/>
                <path d="M27 12.5H37" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                <path d="M2 10L7 9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                <path d="M62 10L57 9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
              </svg>
            </span>
            {{ section.settings.eyeglasses_label }}
          </button>
          <button type="button" class="home-face-analyzer__chip" data-fsa-open data-fsa-category="sunglasses">
            <span class="home-face-analyzer__chip-icon" aria-hidden="true">
              <svg viewBox="0 0 64 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 11.5C3 8.46243 5.46243 6 8.5 6H21.5C24.5376 6 27 8.46243 27 11.5V14.5C27 17.5376 24.5376 20 21.5 20H8.5C5.46243 20 3 17.5376 3 14.5V11.5Z" fill="currentColor" fill-opacity="0.18" stroke="currentColor" stroke-width="2.5"/>
                <path d="M37 11.5C37 8.46243 39.4624 6 42.5 6H55.5C58.5376 6 61 8.46243 61 11.5V14.5C61 17.5376 58.5376 20 55.5 20H42.5C39.4624 20 37 17.5376 37 14.5V11.5Z" fill="currentColor" fill-opacity="0.18" stroke="currentColor" stroke-width="2.5"/>
                <path d="M27 12.5H37" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                <path d="M2 10L7 9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                <path d="M62 10L57 9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
              </svg>
            </span>
            {{ section.settings.sunglasses_label }}
          </button>
          <button type="button" class="home-face-analyzer__chip" data-fsa-open data-fsa-category="both">
            <span class="home-face-analyzer__chip-icon"><i class="ri-equalizer-line"></i></span>
            {{ section.settings.both_label }}
          </button>
        </div>
        <p class="home-face-analyzer__note">{{ section.settings.note }}</p>
      </div>

      <div class="home-face-analyzer__visual" aria-hidden="true">
        <div class="home-face-analyzer__shape"></div>
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 900 | image_tag:
            loading: 'lazy',
            widths: '360,540,720,900',
            class: 'home-face-analyzer__image',
            alt: section.settings.image.alt | escape }}
        {% else %}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'home-face-analyzer__placeholder' }}
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home Face Analyzer",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Let's Find Your Pairfect Match"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What type of glasses are you looking for?"
    },
    {
      "type": "text",
      "id": "eyeglasses_label",
      "label": "Eyeglasses label",
      "default": "Eyeglasses"
    },
    {
      "type": "text",
      "id": "sunglasses_label",
      "label": "Sunglasses label",
      "default": "Sunglasses"
    },
    {
      "type": "text",
      "id": "both_label",
      "label": "Both label",
      "default": "Both"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Note",
      "default": "Start with a quick style quiz, then continue with camera or skip it and shop your matches right away."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Feature image"
    }
  ],
  "presets": [
    {
      "name": "Home Face Analyzer"
    }
  ]
}
{% endschema %}

<style>
.home-face-analyzer {
  padding: 36px 0 14px;
}
.home-face-analyzer__card {
  position: relative;
  overflow: hidden;
  display: grid;
  grid-template-columns: minmax(0, 1.08fr) minmax(360px, 0.92fr);
  gap: 24px;
  align-items: center;
  padding: 34px 34px 34px 40px;
  border-radius: 28px;
  background: #ffffff;
  border: 1px solid #e6edf5;
  box-shadow: 0 20px 48px rgba(15, 23, 42, 0.06);
}
.home-face-analyzer__content {
  position: relative;
  z-index: 1;
  text-align: left;
}
.home-face-analyzer__eyebrow {
  margin: 0 0 10px;
  color: #6f99c3;
  font-size: 14px;
  font-weight: 500;
}
.home-face-analyzer__title {
  margin: 0;
  max-width: 640px;
  color: #111827;
  font-size: clamp(30px, 4.1vw, 54px);
  line-height: 1.1;
  letter-spacing: -0.04em;
}
.home-face-analyzer__actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  gap: 12px;
  margin-top: 24px;
}
.home-face-analyzer__chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 14px;
  min-height: 68px;
  min-width: 168px;
  padding: 12px 22px;
  border: 1px solid #e5edf5;
  background: #f8fafc;
  color: #111827;
  border-radius: 999px;
  font-size: 17px;
  font-weight: 700;
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
}
.home-face-analyzer__chip:hover {
  transform: translateY(-2px);
  border-color: rgba(17, 48, 113, 0.14);
  box-shadow: 0 12px 24px rgba(15, 23, 42, 0.08);
}
.home-face-analyzer__chip-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  color: #67737f;
}
.home-face-analyzer__chip-icon svg {
  display: block;
  width: 36px;
  height: 22px;
}
.home-face-analyzer__note {
  margin: 12px 0 0;
  max-width: 540px;
  color: #64748b;
  font-size: 14px;
  line-height: 1.65;
  text-align: left;
}
.home-face-analyzer__visual {
  position: relative;
  min-height: 360px;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  overflow: hidden;
}
.home-face-analyzer__shape {
  position: absolute;
  inset: 22px 0 22px 22px;
  border-radius: 999px 26px 26px 999px;
  background: linear-gradient(135deg, #4e79b1 0%, #113071 100%);
}
.home-face-analyzer__image,
.home-face-analyzer__placeholder {
  position: relative;
  z-index: 1;
  display: block;
  width: calc(100% - 42px);
  max-width: 100%;
  height: calc(100% - 44px);
  max-height: 100%;
  margin: 22px 0 22px auto;
  border-radius: 999px 24px 24px 999px;
  object-fit: cover;
  object-position: center;
  background: #f8fafc;
}
@media (max-width: 991px) {
  .home-face-analyzer__card {
    grid-template-columns: 1fr;
    padding: 28px 24px;
  }
  .home-face-analyzer__content,
  .home-face-analyzer__note {
    text-align: center;
  }
  .home-face-analyzer__title {
    margin: 0 auto;
  }
  .home-face-analyzer__actions {
    justify-content: center;
  }
  .home-face-analyzer__chip {
    min-width: 0;
    width: calc(50% - 6px);
    font-size: 16px;
  }
  .home-face-analyzer__visual {
    min-height: 260px;
  }
  .home-face-analyzer__shape {
    inset: 12px 0 0;
    border-radius: 28px;
  }
  .home-face-analyzer__image,
  .home-face-analyzer__placeholder {
    width: 100%;
    height: calc(100% - 12px);
    margin: 0;
    border-radius: 28px;
  }
}
@media (max-width: 767px) {
  .home-face-analyzer {
    padding: 20px 0 8px;
  }
  .home-face-analyzer__card {
    padding: 22px 16px;
    gap: 18px;
    border-radius: 18px;
  }
  .home-face-analyzer__title {
    font-size: clamp(24px, 8vw, 34px);
    line-height: 1.12;
  }
  .home-face-analyzer__actions {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
    margin-top: 22px;
  }
  .home-face-analyzer__chip {
    width: 100%;
    min-width: 0;
    min-height: 58px;
    justify-content: flex-start;
    padding: 12px 16px;
    font-size: 15px;
    gap: 12px;
  }
  .home-face-analyzer__chip-icon {
    width: 32px;
    height: 32px;
  }
  .home-face-analyzer__note {
    margin-top: 10px;
    font-size: 13px;
  }
  .home-face-analyzer__visual {
    min-height: 200px;
  }
  .home-face-analyzer__shape {
    inset: 0;
    border-radius: 18px;
  }
  .home-face-analyzer__image,
  .home-face-analyzer__placeholder {
    width: 100%;
    height: 100%;
    margin: 0;
    border-radius: 18px;
    object-position: center;
  }
}
</style>
