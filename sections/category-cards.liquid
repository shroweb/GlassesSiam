{% comment %}
  Category Cards — 4-column image cards for homepage
  Each card: image, title, subtitle, CTA link
{% endcomment %}

<section class="cat-cards" style="background: {{ section.settings.background_color }}; padding: {{ section.settings.padding_top }}px 2rem {{ section.settings.padding_bottom }}px;">
  <div class="cat-cards__inner">

    {% if section.settings.heading != blank %}
      <h2 class="cat-cards__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="cat-cards__subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="cat-cards__grid">
      {% for block in section.blocks %}
        {% if block.type == 'card' %}
          <a
            href="{{ block.settings.url | default: '#' }}"
            class="cat-card"
            {{ block.shopify_attributes }}
          >
            <div class="cat-card__img-wrap">
              {% if block.settings.image %}
                <img
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  alt="{{ block.settings.title | escape }}"
                  loading="lazy"
                  width="600"
                >
              {% else %}
                <div class="cat-card__placeholder">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                </div>
              {% endif %}
              {% if block.settings.badge != blank %}
                <span class="cat-card__badge">{{ block.settings.badge }}</span>
              {% endif %}
            </div>
            <div class="cat-card__body">
              {% if block.settings.title != blank %}
                <h3 class="cat-card__title">{{ block.settings.title }}</h3>
              {% endif %}
              {% if block.settings.subtitle != blank %}
                <p class="cat-card__subtitle">{{ block.settings.subtitle }}</p>
              {% endif %}
              {% if block.settings.cta != blank %}
                <span class="cat-card__cta">
                  {{ block.settings.cta }}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
              {% endif %}
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

{% style %}
.cat-cards__inner {
  max-width: 1200px;
  margin: 0 auto;
}

.cat-cards__heading {
  text-align: center;
  font-size: clamp(1.4rem, 2.5vw, 2rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: #111827;
  margin-bottom: 0.5rem;
}

.cat-cards__subheading {
  text-align: center;
  font-size: 15px;
  color: #6b7280;
  margin-bottom: 2.5rem;
}

.cat-cards__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20px;
}

/* Card */
.cat-card {
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 1.25rem;
  overflow: hidden;
  border: 1px solid #e8ecf0;
  text-decoration: none;
  color: inherit;
  transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
}

.cat-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 48px rgba(0,0,0,0.1);
  border-color: transparent;
  text-decoration: none;
  color: inherit;
}

/* Image */
.cat-card__img-wrap {
  position: relative;
  aspect-ratio: 4/3;
  overflow: hidden;
  background: #f1f5f9;
}

.cat-card__img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.4s ease;
}

.cat-card:hover .cat-card__img-wrap img {
  transform: scale(1.04);
}

.cat-card__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Badge */
.cat-card__badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: #113071;
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 4px 10px;
  border-radius: 999px;
}

/* Body */
.cat-card__body {
  padding: 1.25rem 1.4rem 1.5rem;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.cat-card__title {
  font-size: 17px;
  font-weight: 700;
  color: #111827;
  margin-bottom: 0.3rem;
  letter-spacing: -0.01em;
}

.cat-card__subtitle {
  font-size: 13.5px;
  color: #6b7280;
  line-height: 1.5;
  flex: 1;
  margin-bottom: 0.9rem;
}

.cat-card__cta {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 13px;
  font-weight: 700;
  color: #113071;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  transition: gap 0.2s ease;
}

.cat-card:hover .cat-card__cta {
  gap: 8px;
}

/* Responsive */
@media (max-width: 900px) {
  .cat-cards__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 500px) {
  .cat-cards__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .cat-card__body {
    padding: 1rem 1rem 1.2rem;
  }
  .cat-card__title {
    font-size: 15px;
  }
}
{% endstyle %}

{% schema %}
{
  "name": "Category Cards",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Sub-heading",
      "default": "Find the perfect frames for every style"
