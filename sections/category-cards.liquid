            "cta": "Shop Now",
            "badge": "Popular"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Reading Glasses",
            "subtitle": "Magnification in stylish frames",
            "cta": "Shop Now"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Kids' Frames",
            "subtitle": "Durable and fun frames for little ones",
            "cta": "Shop Now",
            "badge": "New"
          }
        }
      ]
    }
  ]
}
