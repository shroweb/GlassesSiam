{% comment %}
Lens Configurator - Complete Solution with Dynamic Pricing
{% endcomment %}

<section class="lens-configurator" 
  data-product-id="{{ product.id }}" 
  data-variant-id="{{ product.selected_or_first_available_variant.id }}"
  data-product-title="{{ product.title | escape }}">
  
  <div class="lens-button-wrapper lens-align-{{ section.settings.button_alignment }}">
    <button class="lens-start-btn" id="openLensConfigurator">
      Choose Lenses
    </button>
  </div>

  <div class="lens-modal" id="lensModal">
    <div class="lens-modal__inner">

      <!-- STEP 1: Usage -->
      <div class="lens-step is-active" data-step="1">
        <h2>What do you use your glasses for?</h2>
        <p class="lens-subtitle">Step 1 of 5</p>
        <button class="lens-option" data-value="Single Vision">
          <div class="lens-option-content">
            <div>
              <strong>Single Vision</strong>
              <span>For distance or reading</span>
            </div>
            <div class="lens-option-price" data-price-type="usage" data-price-key="Single Vision">From £0</div>
          </div>
        </button>
        <button class="lens-option" data-value="Reading">
          <div class="lens-option-content">
            <div>
              <strong>Reading</strong>
              <span>For close-up work</span>
            </div>
            <div class="lens-option-price" data-price-type="usage" data-price-key="Reading">From £25</div>
          </div>
        </button>
        <button class="lens-option" data-value="Progressive">
          <div class="lens-option-content">
            <div>
              <strong>Progressive</strong>
              <span>Multi-focal lenses</span>
            </div>
            <div class="lens-option-price" data-price-type="usage" data-price-key="Progressive">From £150</div>
          </div>
        </button>
      </div>

      <!-- STEP 2: Lens Type -->
      <div class="lens-step" data-step="2">
        <h2>Choose your lens type</h2>
        <p class="lens-subtitle">Step 2 of 5</p>
        <button class="lens-option" data-value="Clear">
          <div class="lens-option-content">
            <div>
              <strong>Clear</strong>
              <span>Standard clear lenses</span>
            </div>
            <div class="lens-option-price" data-price-type="lensType" data-price-key="Clear">+£0</div>
          </div>
        </button>
        <button class="lens-option" data-value="Blue Light">
          <div class="lens-option-content">
            <div>
              <strong>Blue Light</strong>
              <span>Filter digital screen light</span>
            </div>
            <div class="lens-option-price" data-price-type="lensType" data-price-key="Blue Light">+£50</div>
          </div>
        </button>
        <button class="lens-option" data-value="Transitions">
          <div class="lens-option-content">
            <div>
              <strong>Transitions</strong>
              <span>Adapt to light conditions</span>
            </div>
            <div class="lens-option-price" data-price-type="lensType" data-price-key="Transitions">+£100</div>
          </div>
        </button>
        <button class="lens-back-btn" id="backToStep1">← Back</button>
      </div>

      <!-- STEP 3: Upgrades -->
      <div class="lens-step" data-step="3">
        <h2>Add upgrades (optional)</h2>
        <p class="lens-subtitle">Step 3 of 5</p>
        <div class="lens-checkbox-group">
          <label class="lens-checkbox">
            <input type="checkbox" value="Anti-Reflective">
            <div class="lens-checkbox-content">
              <div>
                <strong>Anti-Reflective Coating</strong>
                <span>Reduces glare and reflections</span>
              </div>
              <div class="lens-checkbox-price" data-price-type="coating" data-price-key="Anti-Reflective">+£40</div>
            </div>
          </label>
          <label class="lens-checkbox">
            <input type="checkbox" value="Hydrophobic">
            <div class="lens-checkbox-content">
              <div>
                <strong>Hydrophobic Coating</strong>
                <span>Repels water and smudges</span>
              </div>
              <div class="lens-checkbox-price" data-price-type="coating" data-price-key="Hydrophobic">+£30</div>
            </div>
          </label>
        </div>
        <button class="lens-next-btn" id="goToPrescription">Continue →</button>
        <button class="lens-back-btn" id="backToStep2">← Back</button>
      </div>

      <!-- STEP 4: Prescription Method -->
      <div class="lens-step" data-step="4">
        <h2>How do you want to add your prescription?</h2>
        <p class="lens-subtitle">Step 4 of 6</p>
        <button class="lens-option" data-value="Fill Online" data-goto="4a">
          <div class="lens-option-content">
            <div>
              <strong>Fill it out online</strong>
              <span>Fill it manually according to your printed prescription</span>
            </div>
            <div class="lens-option-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10 9 9 9 8 9"/>
              </svg>
            </div>
          </div>
        </button>
        <button class="lens-option" data-value="Use Saved" data-goto="4c">
          <div class="lens-option-content">
            <div>
              <strong>Use saved prescription</strong>
              <span>Use a prescription that you've saved or shopped with before</span>
            </div>
            <div class="lens-option-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <path d="M12 18v-6"/>
                <path d="m9 15 3 3 3-3"/>
              </svg>
            </div>
          </div>
        </button>
        <button class="lens-option" data-value="Send Later" data-goto="5">
          <div class="lens-option-content">
            <div>
              <strong>Send later</strong>
              <span>You can easily send it after checkout (we'll remind you)</span>
            </div>
            <div class="lens-option-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
                <circle cx="17" cy="17" r="3"/>
                <polyline points="17 15 17 17 18 18"/>
              </svg>
            </div>
          </div>
        </button>
        <button class="lens-back-btn" id="backToStep3">← Back</button>
      </div>

      <!-- STEP 4A: Fill Out Online -->
      <div class="lens-step" data-step="4a">
        <h2>Fill it out online</h2>
        <p class="lens-subtitle">Step 5 of 6</p>
        
        <a href="#" class="lens-help-link" id="howToReadLink">How to read my prescription?</a>
        
        <div class="lens-prescription-table">
          <table>
            <thead>
              <tr>
                <th></th>
                <th>Sphere (SPH)</th>
                <th>Cylinder (CYL)</th>
                <th>Axis (AXI)</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Right (OD)</strong></td>
                <td>
                  <select name="od_sph" class="lens-select">
                    <option value="">None</option>
                    <option value="+0.25">+0.25</option>
                    <option value="+0.50">+0.50</option>
                    <option value="+0.75">+0.75</option>
                    <option value="+1.00">+1.00</option>
                    <option value="-0.25">-0.25</option>
                    <option value="-0.50">-0.50</option>
                    <option value="-0.75">-0.75</option>
                    <option value="-1.00">-1.00</option>
                  </select>
                </td>
                <td>
                  <select name="od_cyl" class="lens-select">
                    <option value="">None</option>
                    <option value="+0.25">+0.25</option>
                    <option value="+0.50">+0.50</option>
                    <option value="-0.25">-0.25</option>
                    <option value="-0.50">-0.50</option>
                  </select>
                </td>
                <td>
                  <select name="od_axis" class="lens-select">
                    <option value="">None</option>
                    <option value="1">1</option>
                    <option value="15">15</option>
                    <option value="30">30</option>
                    <option value="45">45</option>
                    <option value="60">60</option>
                    <option value="75">75</option>
                    <option value="90">90</option>
                  </select>
                </td>
              </tr>
              <tr>
                <td><strong>Left (OS)</strong></td>
                <td>
                  <select name="os_sph" class="lens-select">
                    <option value="">None</option>
                    <option value="+0.25">+0.25</option>
                    <option value="+0.50">+0.50</option>
                    <option value="+0.75">+0.75</option>
                    <option value="+1.00">+1.00</option>
                    <option value="-0.25">-0.25</option>
                    <option value="-0.50">-0.50</option>
                    <option value="-0.75">-0.75</option>
                    <option value="-1.00">-1.00</option>
                  </select>
                </td>
                <td>
                  <select name="os_cyl" class="lens-select">
                    <option value="">None</option>
                    <option value="+0.25">+0.25</option>
                    <option value="+0.50">+0.50</option>
                    <option value="-0.25">-0.25</option>
                    <option value="-0.50">-0.50</option>
                  </select>
                </td>
                <td>
                  <select name="os_axis" class="lens-select">
                    <option value="">None</option>
                    <option value="1">1</option>
                    <option value="15">15</option>
                    <option value="30">30</option>
                    <option value="45">45</option>
                    <option value="60">60</option>
                    <option value="75">75</option>
                    <option value="90">90</option>
                  </select>
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="lens-form-group">
          <label class="lens-label">Does your prescription have a PD value?</label>
          <select name="pd_value" class="lens-select">
            <option value="">Select an option</option>
            <option value="yes">Yes</option>
            <option value="no">No</option>
            <option value="unsure">Not sure</option>
          </select>
        </div>

        <div class="lens-form-group">
          <label class="lens-label">Additional comments...</label>
          <textarea name="comments" class="lens-textarea" rows="4" placeholder="Any special instructions or notes"></textarea>
        </div>

        <label class="lens-checkbox-inline">
          <input type="checkbox" name="includes_prism">
          <span>My prescription includes prism (+$30 +$15)</span>
        </label>

        <label class="lens-checkbox-inline">
          <input type="checkbox" name="save_prescription" checked>
          <span>Save your prescription for quick reuse (Recommended)</span>
        </label>

        <button class="lens-next-btn" id="continueFromFillOnline">Continue</button>
        <button class="lens-next-btn lens-secondary-btn" id="sendLaterFromFillOnline">Send Later</button>
        <button class="lens-back-btn" id="backToStep4FromFillOnline">← Back</button>
      </div>

      <!-- STEP 4C: Use Saved Prescription -->
      <div class="lens-step" data-step="4c">
        <h2>Use saved prescription</h2>
        <p class="lens-subtitle">Step 5 of 6</p>
        
        <div class="lens-saved-list">
          <div class="lens-info-box">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <line x1="12" y1="16" x2="12" y2="12"/>
              <line x1="12" y1="8" x2="12.01" y2="8"/>
            </svg>
            <p>No saved prescriptions found. Complete a prescription form and select "Save for quick reuse" to save it for future orders.</p>
          </div>
        </div>

        <button class="lens-next-btn" id="continueFromSaved">Continue</button>
        <button class="lens-back-btn" id="backToStep4FromSaved">← Back</button>
      </div>

      <!-- STEP 5: Review -->
      <div class="lens-step" data-step="5">
        <h2>Review your selection</h2>
        <p class="lens-subtitle">Step 6 of 6</p>
        <div class="lens-review-box">
          <div class="lens-review-item">
            <span class="lens-review-label">Frame:</span>
            <span class="lens-review-value" id="reviewProduct"></span>
          </div>
          <div class="lens-review-item">
            <span class="lens-review-label">Usage:</span>
            <span class="lens-review-value" id="reviewUsage"></span>
          </div>
          <div class="lens-review-item">
            <span class="lens-review-label">Lens Type:</span>
            <span class="lens-review-value" id="reviewLens"></span>
          </div>
          <div class="lens-review-item">
            <span class="lens-review-label">Coatings:</span>
            <span class="lens-review-value" id="reviewUpgrades"></span>
          </div>
          <div class="lens-review-item">
            <span class="lens-review-label">Prescription:</span>
            <span class="lens-review-value" id="reviewPrescription"></span>
          </div>
          <div class="lens-review-item lens-review-total">
            <span class="lens-review-label">Lens Cost:</span>
            <span class="lens-review-value" id="reviewTotal">£0</span>
          </div>
        </div>
        <button class="lens-add-cart-btn" id="addToCartFinal">
          <span id="addToCartText">Add Frame + Lenses to Cart</span>
        </button>
        <button class="lens-back-btn" id="backToStep4">← Back</button>
      </div>

      <button class="lens-close" id="closeLensModal" aria-label="Close">✕</button>

    </div>
  </div>
</section>

<style>
.lens-button-wrapper {
  display: flex;
  margin: 20px 0;
}
.lens-align-left { justify-content: flex-start; }
.lens-align-center { justify-content: center; }
.lens-align-right { justify-content: flex-end; }

.lens-start-btn {
  padding: 16px 32px;
  border-radius: 8px;
  background: #2563eb;
  color: #fff;
  border: none;
  font-weight: 600;
  font-size: 16px;
  cursor: pointer;
  max-width: 400px;
  transition: background 0.2s;
}
.lens-start-btn:hover {
  background: #1d4ed8;
}

.lens-modal {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 9999;
  align-items: center;
  justify-content: center;
  padding: 20px;
}
.lens-modal.is-open {
  display: flex;
}

.lens-modal__inner {
  background: #fff;
  max-width: 560px;
  width: 100%;
  max-height: 90vh;
  overflow-y: auto;
  padding: 32px;
  border-radius: 16px;
  position: relative;
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
}

.lens-step {
  display: none;
}
.lens-step.is-active {
  display: block;
}

.lens-step h2 {
  margin: 0 0 8px 0;
  font-size: 24px;
  font-weight: 700;
  color: #111;
}

.lens-subtitle {
  margin: 0 0 24px 0;
  color: #6b7280;
  font-size: 14px;
}

.lens-option {
  display: block;
  width: 100%;
  margin: 12px 0;
  padding: 16px 20px;
  border-radius: 12px;
  border: 2px solid #e5e7eb;
  background: #fff;
  cursor: pointer;
  text-align: left;
  transition: all 0.2s;
}
.lens-option:hover {
  border-color: #2563eb;
  background: #eff6ff;
  transform: translateY(-2px);
}

.lens-option-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.lens-option strong {
  display: block;
  font-size: 16px;
  font-weight: 600;
  color: #111;
  margin-bottom: 4px;
}

.lens-option span {
  display: block;
  font-size: 14px;
  color: #6b7280;
}

.lens-option-price {
  font-size: 18px;
  font-weight: 700;
  color: #2563eb;
  white-space: nowrap;
  margin-left: 16px;
}

.lens-option-icon {
  color: #6b7280;
  flex-shrink: 0;
  margin-left: 16px;
}

.lens-checkbox-group {
  margin: 20px 0;
}

.lens-checkbox {
  display: flex;
  align-items: flex-start;
  padding: 16px;
  border: 2px solid #e5e7eb;
  border-radius: 12px;
  margin: 12px 0;
  cursor: pointer;
  transition: all 0.2s;
}
.lens-checkbox:hover {
  border-color: #2563eb;
  background: #eff6ff;
}

.lens-checkbox input[type="checkbox"] {
  margin: 4px 12px 0 0;
  width: 18px;
  height: 18px;
  cursor: pointer;
  flex-shrink: 0;
}

.lens-checkbox-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex: 1;
}

.lens-checkbox strong {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: #111;
  margin-bottom: 4px;
}

.lens-checkbox span {
  display: block;
  font-size: 13px;
  color: #6b7280;
}

.lens-checkbox-price {
  font-size: 16px;
  font-weight: 700;
  color: #2563eb;
  white-space: nowrap;
  margin-left: 16px;
}

.lens-review-box {
  background: #f9fafb;
  border: 1px solid #e5e7eb;
  border-radius: 12px;
  padding: 20px;
  margin: 20px 0;
}

.lens-review-item {
  display: flex;
  justify-content: space-between;
  padding: 12px 0;
  border-bottom: 1px solid #e5e7eb;
}
.lens-review-item:last-child {
  border-bottom: none;
}

.lens-review-total {
  margin-top: 8px;
  padding-top: 16px;
  border-top: 2px solid #2563eb;
  font-size: 18px;
}

.lens-review-total .lens-review-label {
  font-size: 18px;
  color: #111;
}

.lens-review-total .lens-review-value {
  font-size: 24px;
  font-weight: 700;
  color: #2563eb;
}

.lens-review-label {
  font-weight: 600;
  color: #374151;
}

.lens-review-value {
  color: #111;
  text-align: right;
}

.lens-next-btn,
.lens-add-cart-btn {
  width: 100%;
  padding: 16px 24px;
  border-radius: 8px;
  background: #2563eb;
  color: #fff;
  border: none;
  font-weight: 600;
  font-size: 16px;
  cursor: pointer;
  margin-top: 12px;
  transition: background 0.2s;
}
.lens-next-btn:hover,
.lens-add-cart-btn:hover {
  background: #1d4ed8;
}
.lens-add-cart-btn:disabled {
  background: #9ca3af;
  cursor: not-allowed;
}

.lens-back-btn {
  width: 100%;
  padding: 12px 24px;
  border-radius: 8px;
  background: transparent;
  color: #6b7280;
  border: 1px solid #e5e7eb;
  font-weight: 500;
  font-size: 14px;
  cursor: pointer;
  margin-top: 8px;
  transition: all 0.2s;
}
.lens-back-btn:hover {
  background: #f9fafb;
  color: #111;
}

.lens-close {
  position: absolute;
  top: 16px;
  right: 16px;
  border: none;
  background: #f3f4f6;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  font-size: 20px;
  cursor: pointer;
  color: #6b7280;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}
.lens-close:hover {
  background: #e5e7eb;
  color: #111;
}

.lens-help-link {
  display: inline-block;
  color: #2563eb;
  text-decoration: none;
  font-size: 14px;
  margin-bottom: 16px;
}

.lens-help-link:hover {
  text-decoration: underline;
}

.lens-prescription-table {
  overflow-x: auto;
  margin: 20px 0;
}

.lens-prescription-table table {
  width: 100%;
  border-collapse: collapse;
  background: #f9fafb;
  border-radius: 8px;
  overflow: hidden;
}

.lens-prescription-table th,
.lens-prescription-table td {
  padding: 12px;
  text-align: left;
  border-bottom: 1px solid #e5e7eb;
}

.lens-prescription-table th {
  background: #f3f4f6;
  font-weight: 600;
  font-size: 13px;
  color: #6b7280;
}

.lens-prescription-table td:first-child {
  font-weight: 600;
}

.lens-select {
  width: 100%;
  padding: 8px 12px;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  background: #fff;
  font-size: 14px;
  cursor: pointer;
}

.lens-select:focus {
  outline: none;
  border-color: #2563eb;
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
}

.lens-form-group {
  margin: 20px 0;
}

.lens-label {
  display: block;
  font-weight: 600;
  font-size: 14px;
  color: #374151;
  margin-bottom: 8px;
}

.lens-textarea {
  width: 100%;
  padding: 12px;
  border: 1px solid #d1d5db;
  border-radius: 8px;
  font-size: 14px;
  font-family: inherit;
  resize: vertical;
}

.lens-textarea:focus {
  outline: none;
  border-color: #2563eb;
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
}

.lens-checkbox-inline {
  display: flex;
  align-items: center;
  margin: 12px 0;
  cursor: pointer;
}

.lens-checkbox-inline input[type="checkbox"] {
  margin-right: 8px;
  width: 18px;
  height: 18px;
  cursor: pointer;
}

.lens-checkbox-inline span {
  font-size: 14px;
  color: #374151;
}

.lens-secondary-btn {
  background: #fff;
  color: #2563eb;
  border: 2px solid #2563eb;
}

.lens-secondary-btn:hover {
  background: #eff6ff;
}

.lens-saved-list {
  margin: 20px 0;
}

.lens-info-box {
  display: flex;
  align-items: flex-start;
  padding: 16px;
  background: #eff6ff;
  border: 1px solid #bfdbfe;
  border-radius: 8px;
  gap: 12px;
}

.lens-info-box svg {
  color: #2563eb;
  flex-shrink: 0;
  margin-top: 2px;
}

.lens-info-box p {
  margin: 0;
  font-size: 14px;
  color: #1e40af;
  line-height: 1.5;
}

@media (max-width: 640px) {
  .lens-modal__inner {
    padding: 24px 20px;
  }
  .lens-step h2 {
    font-size: 20px;
  }
  .lens-option-price,
  .lens-checkbox-price {
    font-size: 16px;
  }
  .lens-option-icon {
    display: none;
  }
  .lens-prescription-table {
    font-size: 12px;
  }
  .lens-prescription-table th,
  .lens-prescription-table td {
    padding: 8px 6px;
  }
}
</style>

<script>
(() => {
  const modal = document.getElementById('lensModal');
  const openBtn = document.getElementById('openLensConfigurator');
  const closeBtn = document.getElementById('closeLensModal');
  const steps = document.querySelectorAll('.lens-step');
  const addBtn = document.getElementById('addToCartFinal');
  const configurator = document.querySelector('.lens-configurator');

  if (!modal || !openBtn) {
    console.error('Configurator elements not found');
    return;
  }

  let selections = {
    usage: '',
    lensType: '',
    coatings: [],
    prescriptionMethod: '',
    prescriptionData: null
  };

  let priceData = {
    usage: {},
    lensType: {},
    coatings: {}
  };

  // Fetch actual prices from Shopify product
  async function loadPrices() {
    try {
      const response = await fetch('/products/prescription-lens-package.js');
      if (!response.ok) throw new Error('Could not load lens product');
      
      const lensProduct = await response.json();
      
      // Map variant prices to our price structure
      lensProduct.variants.forEach(variant => {
        const usage = variant.option1;
        const lensType = variant.option2;
        const coating = variant.option3;
        
        // Store base prices (we'll calculate from the cheapest variant of each type)
        if (usage && !priceData.usage[usage]) {
          priceData.usage[usage] = variant.price / 100; // Convert cents to pounds
        }
        
        // Calculate lens type price differences
        if (lensType && usage === 'Single Vision' && coating === 'None') {
          priceData.lensType[lensType] = (variant.price / 100) - (priceData.usage['Single Vision'] || 0);
        }
        
        // Calculate coating prices (difference between with and without)
        if (coating && coating !== 'None' && coating !== 'Both Coatings') {
          const baseVariant = lensProduct.variants.find(v => 
            v.option1 === usage && v.option2 === lensType && v.option3 === 'None'
          );
          if (baseVariant) {
            priceData.coatings[coating] = (variant.price - baseVariant.price) / 100;
          }
        }
      });
      
      updatePriceDisplay();
      
    } catch (error) {
      console.error('Error loading prices:', error);
      // Fallback to hardcoded prices if fetch fails
      priceData = {
        usage: { 'Single Vision': 0, 'Reading': 25, 'Progressive': 150 },
        lensType: { 'Clear': 0, 'Blue Light': 50, 'Transitions': 100 },
        coatings: { 'Anti-Reflective': 40, 'Hydrophobic': 30 }
      };
      updatePriceDisplay();
    }
  }

  // Update all price displays
  function updatePriceDisplay() {
    document.querySelectorAll('[data-price-type]').forEach(el => {
      const type = el.dataset.priceType;
      const key = el.dataset.priceKey;
      
      if (type === 'usage' && priceData.usage[key] !== undefined) {
        el.textContent = `From £${priceData.usage[key].toFixed(0)}`;
      } else if (type === 'lensType' && priceData.lensType[key] !== undefined) {
        const price = priceData.lensType[key];
        el.textContent = price === 0 ? '+£0' : `+£${price.toFixed(0)}`;
      } else if (type === 'coating' && priceData.coatings[key] !== undefined) {
        el.textContent = `+£${priceData.coatings[key].toFixed(0)}`;
      }
    });
  }

  // Load prices on page load
  loadPrices();

  // Open modal
  openBtn.onclick = (e) => {
    e.preventDefault();
    modal.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    // Reset selections when opening
    selections = {
      usage: '',
      lensType: '',
      coatings: [],
      prescriptionMethod: '',
      prescriptionData: null
    };
    // Reset to first step
    goToStep('1');
  };

  // Close modal
  closeBtn.onclick = (e) => {
    e.preventDefault();
    modal.classList.remove('is-open');
    document.body.style.overflow = '';
  };

  modal.onclick = (e) => {
    if (e.target === modal) {
      closeBtn.click();
    }
  };

  // Navigation
  function goToStep(stepNumber) {
    steps.forEach(s => s.classList.remove('is-active'));
    const targetStep = document.querySelector(`[data-step="${stepNumber}"]`);
    if (targetStep) {
      targetStep.classList.add('is-active');
      // Update review when navigating to step 5
      if (stepNumber === '5') {
        updateReview();
      }
    }
  }

  // Step 1: Usage
  document.querySelectorAll('[data-step="1"] .lens-option').forEach(btn => {
    btn.onclick = (e) => {
      e.preventDefault();
      selections.usage = btn.dataset.value;
      console.log('Usage selected:', selections.usage); // Debug
      goToStep('2');
    };
  });

  // Step 2: Lens type
  document.querySelectorAll('[data-step="2"] .lens-option').forEach(btn => {
    btn.onclick = (e) => {
      e.preventDefault();
      selections.lensType = btn.dataset.value;
      console.log('Lens type selected:', selections.lensType); // Debug
      goToStep('3');
    };
  });

  // Step 3: Checkboxes
  document.querySelectorAll('[data-step="3"] input[type="checkbox"]').forEach(cb => {
    cb.onchange = () => {
      selections.coatings = [...document.querySelectorAll('[data-step="3"] input:checked')].map(i => i.value);
      console.log('Coatings selected:', selections.coatings); // Debug
    };
  });

  // Continue to prescription
  document.getElementById('goToPrescription').onclick = (e) => {
    e.preventDefault();
    goToStep('4');
  };

  // Step 4: Prescription method
  document.querySelectorAll('[data-step="4"] .lens-option').forEach(btn => {
    btn.onclick = (e) => {
      e.preventDefault();
      selections.prescriptionMethod = btn.dataset.value;
      const gotoStep = btn.dataset.goto;
      console.log('Prescription method selected:', selections.prescriptionMethod, 'Going to step:', gotoStep); // Debug
      goToStep(gotoStep);
    };
  });

  // Step 4A: Fill out online
  document.getElementById('continueFromFillOnline').onclick = (e) => {
    e.preventDefault();
    // Collect prescription data
    selections.prescriptionData = {
      od_sph: document.querySelector('[name="od_sph"]').value,
      od_cyl: document.querySelector('[name="od_cyl"]').value,
      od_axis: document.querySelector('[name="od_axis"]').value,
      os_sph: document.querySelector('[name="os_sph"]').value,
      os_cyl: document.querySelector('[name="os_cyl"]').value,
      os_axis: document.querySelector('[name="os_axis"]').value,
      pd_value: document.querySelector('[name="pd_value"]').value,
      comments: document.querySelector('[name="comments"]').value,
      includes_prism: document.querySelector('[name="includes_prism"]').checked,
      save_prescription: document.querySelector('[name="save_prescription"]').checked
    };
    console.log('Selections before review:', selections); // Debug
    goToStep('5');
  };

  document.getElementById('sendLaterFromFillOnline').onclick = (e) => {
    e.preventDefault();
    selections.prescriptionMethod = 'Send Later';
    selections.prescriptionData = null;
    console.log('Selections before review:', selections); // Debug
    goToStep('5');
  };

  // Step 4C: Use saved
  document.getElementById('continueFromSaved').onclick = (e) => {
    e.preventDefault();
    // In a real implementation, you'd load saved prescriptions here
    goToStep('5');
  };

  // Back buttons for new steps
  document.getElementById('backToStep4FromFillOnline').onclick = (e) => { 
    e.preventDefault(); 
    goToStep('4'); 
  };
  document.getElementById('backToStep4FromSaved').onclick = (e) => { 
    e.preventDefault(); 
    goToStep('4'); 
  };
  document.getElementById('backToStep4').onclick = (e) => { 
    e.preventDefault(); 
    goToStep('4'); 
  };

  // Get coating option
  function getCoatingOption() {
    if (selections.coatings.length === 0) return 'None';
    if (selections.coatings.length === 2) return 'Both Coatings';
    return selections.coatings[0];
  }

  // Calculate price
  function calculatePrice() {
    let total = priceData.usage[selections.usage] || 0;
    total += priceData.lensType[selections.lensType] || 0;
    
    selections.coatings.forEach(coating => {
      total += priceData.coatings[coating] || 0;
    });
    
    return total;
  }

  // Update review
  function updateReview() {
    console.log('Updating review with selections:', selections); // Debug
    
    const productTitle = configurator.dataset.productTitle;
    const usage = selections.usage || 'Not selected';
    const lensType = selections.lensType || 'Not selected';
    const coatings = getCoatingOption();
    
    document.getElementById('reviewProduct').textContent = productTitle;
    document.getElementById('reviewUsage').textContent = usage;
    document.getElementById('reviewLens').textContent = lensType;
    document.getElementById('reviewUpgrades').textContent = coatings;
    
    let prescriptionText = selections.prescriptionMethod || 'Not selected';
    if (selections.prescriptionData && selections.prescriptionData.od_sph) {
      prescriptionText = `${selections.prescriptionMethod} (Completed)`;
    }
    document.getElementById('reviewPrescription').textContent = prescriptionText;
    
    const totalPrice = calculatePrice();
    document.getElementById('reviewTotal').textContent = `£${totalPrice.toFixed(0)}`;
    
    console.log('Review updated:', {
      product: productTitle,
      usage,
      lensType,
      coatings,
      prescription: prescriptionText,
      total: totalPrice
    }); // Debug
  }

  // Back buttons
  document.getElementById('backToStep1').onclick = (e) => { e.preventDefault(); goToStep('1'); };
  document.getElementById('backToStep2').onclick = (e) => { e.preventDefault(); goToStep('2'); };
  document.getElementById('backToStep3').onclick = (e) => { e.preventDefault(); goToStep('3'); };

  // Add to cart
  addBtn.onclick = async (e) => {
    e.preventDefault();
    const addToCartText = document.getElementById('addToCartText');
    const originalText = addToCartText.textContent;
    
    addBtn.disabled = true;
    addToCartText.textContent = 'Adding...';

    try {
      // Get frame variant ID
      let frameVariantId = configurator.dataset.variantId;
      
      const variantInput = document.querySelector('input[name="id"]');
      const variantSelect = document.querySelector('select[name="id"]');
      const variantRadio = document.querySelector('input[name="id"]:checked');
      
      if (variantInput?.value) frameVariantId = variantInput.value;
      else if (variantSelect?.value) frameVariantId = variantSelect.value;
      else if (variantRadio?.value) frameVariantId = variantRadio.value;

      if (!frameVariantId) {
        throw new Error('Please select frame options first');
      }

      // Fetch lens product variants
      const lensResponse = await fetch('/products/prescription-lens-package.js');
      if (!lensResponse.ok) {
        throw new Error('Could not load lens options');
      }
      
      const lensProduct = await lensResponse.json();

      // Find matching variant
      const coatingOption = getCoatingOption();
      const matchingVariant = lensProduct.variants.find(v => 
        v.option1 === selections.usage &&
        v.option2 === selections.lensType &&
        v.option3 === coatingOption
      );

      if (!matchingVariant) {
        throw new Error('Lens combination not available. Please contact support.');
      }

      console.log('Found matching variant:', {
        id: matchingVariant.id,
        title: `${matchingVariant.option1} / ${matchingVariant.option2} / ${matchingVariant.option3}`,
        available: matchingVariant.available,
        inventory_policy: matchingVariant.inventory_policy,
        inventory_management: matchingVariant.inventory_management
      });

      // Build lens properties with all configurator data
      const lensProperties = {
        '_Paired with': configurator.dataset.productTitle,
        '_Usage': selections.usage,
        '_Lens Type': selections.lensType,
        '_Coatings': getCoatingOption()
      };

      // Add prescription method
      if (selections.prescriptionMethod) {
        lensProperties['_Prescription Method'] = selections.prescriptionMethod;
      }

      // Add prescription details if filled online
      if (selections.prescriptionData && selections.prescriptionData.od_sph) {
        lensProperties['_Right Eye SPH'] = selections.prescriptionData.od_sph || 'None';
        lensProperties['_Right Eye CYL'] = selections.prescriptionData.od_cyl || 'None';
        lensProperties['_Right Eye AXIS'] = selections.prescriptionData.od_axis || 'None';
        lensProperties['_Left Eye SPH'] = selections.prescriptionData.os_sph || 'None';
        lensProperties['_Left Eye CYL'] = selections.prescriptionData.os_cyl || 'None';
        lensProperties['_Left Eye AXIS'] = selections.prescriptionData.os_axis || 'None';
        lensProperties['_PD Value'] = selections.prescriptionData.pd_value || 'Not specified';
        
        if (selections.prescriptionData.comments) {
          lensProperties['_Comments'] = selections.prescriptionData.comments;
        }
        if (selections.prescriptionData.includes_prism) {
          lensProperties['_Includes Prism'] = 'Yes (+£30 +£15)';
        }
      }

      // Add both items to cart
      const response = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify({
          items: [
            {
              id: frameVariantId,
              quantity: 1
            },
            {
              id: matchingVariant.id,
              quantity: 1,
              properties: lensProperties
            }
          ]
        })
      });

      if (!response.ok) {
        const error = await response.json();
        const errorMessage = error.description || error.message || 'Failed to add to cart';
        
        // Check if it's an inventory issue
        if (errorMessage.includes('sold out') || errorMessage.includes('out of stock')) {
          throw new Error('This lens combination is temporarily unavailable. Please contact support or try a different option.');
        }
        
        throw new Error(errorMessage);
      }

      window.location.href = '/cart';

    } catch (error) {
      console.error('Cart error:', error);
      alert('Error: ' + error.message);
      addBtn.disabled = false;
      addToCartText.textContent = originalText;
    }
  };

})();
</script>

{% schema %}
