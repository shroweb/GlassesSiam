    {
      "type": "range",
      "id": "button_padding_v",
      "label": "Button Vertical Padding",
      "min": 8,
      "max": 30,
      "step": 2,
      "default": 14
    },
    {
      "type": "range",
      "id": "button_padding_h",
      "label": "Button Horizontal Padding",
      "min": 15,
      "max": 50,
      "step": 5,
      "default": 30
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Button Text Size",
      "min": 12,
      "max": 20,
      "step": 1,
      "default": 16
