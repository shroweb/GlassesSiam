{% comment %}
  Tabbed lens options section
  - Pill-style tabs
  - Image + content per tab
  - Fully editable
{% endcomment %}

<section class="tabbed-lens">
  <div class="tabbed-lens__inner">

    {% if section.settings.heading != blank %}
      <h2 class="tabbed-lens__heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <!-- TAB BUTTONS -->
    <div class="tabbed-lens__tabs" role="tablist">
      {% for block in section.blocks %}
        {% if block.type == 'tab' %}
          <button
            class="tabbed-lens__tab {% if forloop.first %}is-active{% endif %}"
            data-tab="{{ block.id }}"
            type="button"
          >
            {{ block.settings.tab_label }}
          </button>
        {% endif %}
      {% endfor %}
    </div>

    <!-- TAB PANELS -->
    <div class="tabbed-lens__panels">
      {% for block in section.blocks %}
        {% if block.type == 'tab' %}
          <div
            class="tabbed-lens__panel {% if forloop.first %}is-active{% endif %}"
            data-panel="{{ block.id }}"
            {{ block.shopify_attributes }}
          >
            <div class="tabbed-lens__panel-inner">

              <!-- IMAGE -->
              <div class="tabbed-lens__image">
                {% if block.settings.image %}
                  <img
                    src="{{ block.settings.image | image_url: width: 1600 }}"
                    alt="{{ block.settings.heading | escape }}"
                    loading="lazy"
                  >
                {% else %}
                  <div class="tabbed-lens__placeholder">
                    Upload image
                  </div>
                {% endif %}
              </div>

              <!-- CONTENT -->
              <div class="tabbed-lens__content">
                {% if block.settings.heading != blank %}
                  <h3>{{ block.settings.heading }}</h3>
                {% endif %}

                {% if block.settings.text != blank %}
                  <p>{{ block.settings.text }}</p>
                {% endif %}

                {% if block.settings.features != blank %}
                  <ul class="tabbed-lens__features">
                    {{ block.settings.features }}
                  </ul>
                {% endif %}

                {% if block.settings.cta_label != blank %}
                  <a
                    href="{{ block.settings.cta_url }}"
                    class="tabbed-lens__cta"
                  >
                    {{ block.settings.cta_label }} →
                  </a>
                {% endif %}
              </div>

            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

{% style %}
.tabbed-lens {
  padding: 3rem 2rem;
}

.tabbed-lens__inner {
  max-width: 1200px;
  margin: 0 auto;
}

.tabbed-lens__heading {
  text-align: center;
  margin-bottom: 2rem;
}

/* Tabs */
.tabbed-lens__tabs {
  display: flex;
  justify-content: center;
  gap: 0.75rem;
  flex-wrap: wrap;
  margin-bottom: 3rem;
}

.tabbed-lens__tab {
  border: 1px solid #3b82f6;
  background: transparent;
  color: #3b82f6;
  padding: 0.6rem 1.2rem;
  border-radius: 999px;
  cursor: pointer;
  font-weight: 500;
}

.tabbed-lens__tab.is-active {
  background: #3b82f6;
  color: #fff;
}

/* Panels */
.tabbed-lens__panel {
  display: none;
}

.tabbed-lens__panel.is-active {
  display: block;
}

.tabbed-lens__panel-inner {
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 4rem;
  align-items: center;
}

.tabbed-lens__image img {
  width: 100%;
  border-radius: 1rem;
}

.tabbed-lens__placeholder {
  height: 360px;
  background: #f3f4f6;
  border-radius: 1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
}

/* Content */
.tabbed-lens__content h3 {
  font-size: 1.8rem;
  margin-bottom: 1rem;
}

.tabbed-lens__content p {
  margin-bottom: 1.5rem;
}

.tabbed-lens__features {
  list-style: none;
  padding: 0;
  margin-bottom: 1.5rem;
}

.tabbed-lens__features li {
  margin-bottom: 0.75rem;
}

.tabbed-lens__cta {
  color: #3b82f6;
  font-weight: 600;
  text-decoration: none;
}

/* Mobile */
@media (max-width: 900px) {
  .tabbed-lens__panel-inner {
    grid-template-columns: 1fr;
  }
}
{% endstyle %}

<script>
document.addEventListener('DOMContentLoaded', () => {
  const tabs = document.querySelectorAll('.tabbed-lens__tab');
  const panels = document.querySelectorAll('.tabbed-lens__panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const id = tab.dataset.tab;

      tabs.forEach(t => t.classList.remove('is-active'));
      panels.forEach(p => p.classList.remove('is-active'));

      tab.classList.add('is-active');
      document.querySelector(`[data-panel="${id}"]`).classList.add('is-active');
    });
  });
});
</script>

{% schema %}
{
  "name": "Tabbed lens options",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Customize your perfect pair with special lenses and coatings"
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Lens option",
      "settings": [
        {
          "type": "text",
          "id": "tab_label",
          "label": "Tab label",
          "default": "Blue Light"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Panel heading"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Panel text"
        },
        {
          "type": "richtext",
          "id": "features",
          "label": "Features (use bullet list)"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "CTA link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tabbed lens options",
      "blocks": [
        { "type": "tab" },
        { "type": "tab" },
        { "type": "tab" },
        { "type": "tab" }
      ]
    }
  ]
}
{% endschema %}