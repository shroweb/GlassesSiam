{% comment %}
==============================================
SECTION 2: Image Cards with Overlay Text & Buttons
==============================================
{% endcomment %}

{% comment %} File: sections/image-card-grid.liquid {% endcomment %}
<section class="image-card-grid" style="
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  background-color: {{ section.settings.background_color }};
">
  <div class="container" style="max-width: 1400px; margin: 0 auto; padding: 0 20px;">
    <div class="grid" style="
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
    ">
      {% for block in section.blocks %}
        <div class="image-card" style="
          position: relative;
          border-radius: {{ section.settings.card_radius }}px;
          overflow: hidden;
          height: 500px;
        ">
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | img_url: '800x' }}" 
                 alt="{{ block.settings.title }}" 
                 style="width: 100%; height: 100%; object-fit: cover;">
          {% endif %}
          
          <div class="overlay" style="
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 30px;
            background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 70%, transparent 100%);
            color: white;
          ">
            {% if block.settings.title != blank %}
              <h3 style="
                font-size: {{ block.settings.title_size }}px;
                margin-bottom: 10px;
                font-weight: bold;
                color: white;
              ">
                {{ block.settings.title }}
              </h3>
            {% endif %}
            
            {% if block.settings.subtitle != blank %}
              <p style="
                font-size: 16px;
                margin-bottom: 20px;
                color: rgba(255,255,255,0.9);
              ">
                {{ block.settings.subtitle }}
              </p>
            {% endif %}
            
            <div class="button-group" style="display: flex; gap: 10px; flex-wrap: wrap;">
              {% if block.settings.button1_text != blank %}
                <a href="{{ block.settings.button1_link }}" style="
                  display: inline-block;
                  padding: 12px 28px;
                  background-color: {{ block.settings.button1_bg }};
                  color: {{ block.settings.button1_color }};
                  border: 2px solid {{ block.settings.button1_border }};
                  border-radius: 50px;
                  text-decoration: none;
                  font-size: 15px;
                  font-weight: 600;
                ">
                  {{ block.settings.button1_text }}
                </a>
              {% endif %}
              
              {% if block.settings.button2_text != blank %}
                <a href="{{ block.settings.button2_link }}" style="
                  display: inline-block;
                  padding: 12px 28px;
                  background-color: {{ block.settings.button2_bg }};
                  color: {{ block.settings.button2_color }};
                  border: 2px solid {{ block.settings.button2_border }};
                  border-radius: 50px;
                  text-decoration: none;
                  font-size: 15px;
                  font-weight: 600;
                ">
                  {{ block.settings.button2_text }}
                </a>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    .image-card-grid .grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>

{% schema %}
{
  "name": "Image Card Grid",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card Border Radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Image Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Best Sellers"
        },
        {
          "type": "range",
          "id": "title_size",
          "label": "Title Size",
          "min": 20,
          "max": 48,
          "step": 2,
          "default": 32
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Save up to 50% off."
        },
        {
          "type": "text",
          "id": "button1_text",
          "label": "Button 1 Text",
          "default": "Women"
        },
        {
          "type": "url",
          "id": "button1_link",
          "label": "Button 1 Link"
        },
        {
          "type": "color",
          "id": "button1_bg",
          "label": "Button 1 Background",
          "default": "rgba(255,255,255,0.2)"
        },
        {
          "type": "color",
          "id": "button1_color",
          "label": "Button 1 Text Color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "button1_border",
          "label": "Button 1 Border",
          "default": "#ffffff"
        },
        {
          "type": "text",
          "id": "button2_text",
          "label": "Button 2 Text",
          "default": "Men"
        },
        {
          "type": "url",
          "id": "button2_link",
          "label": "Button 2 Link"
        },
        {
          "type": "color",
          "id": "button2_bg",
          "label": "Button 2 Background",
          "default": "rgba(255,255,255,0.2)"
        },
        {
          "type": "color",
          "id": "button2_color",
          "label": "Button 2 Text Color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "button2_border",
          "label": "Button 2 Border",
          "default": "#ffffff"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image Card Grid",
      "blocks": [
        {"type": "card"},
        {"type": "card"},
        {"type": "card"},
        {"type": "card"}
      ]
    }
  ]
}
{% endschema %}

