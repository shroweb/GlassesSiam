<section class="offer-banner-area">
  <div class="container">
    <div class="row">
      <div class="col">
        <ul class="offer-banner-ul">
          {% for block in section.blocks %}
          {% case block.type %}
          {% when 'button_banner' %}
          <li class="offer-banner-li button-banner">
            <div class="banner-block">
              <a href="{{ block.settings.banner_url }}" class="banner-img">
                {%- if block.settings.banner_img -%}
                {{ block.settings.banner_img | image_url: width: 1024 | image_tag:
                  loading: 'lazy',
                  width: block.settings.banner_img.width,
                  height: block.settings.banner_img.height,
                  class: "img-fluid",
                  alt: block.settings.banner_img.alt | escape }}
                {%- else -%}
                {%- capture placeholder -%}collection-{% cycle 1, 2, 3, 4, 5, 6 %}{%- endcapture -%}
                {{ placeholder | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
                <div class="banner-content">
                  <div class="banner-text">
                    {% if block.settings.banner_subtitle != '' %}
                      <span class="subtitle" style="color: {{ block.settings.banner_subtitle_color }};">{{ block.settings.banner_subtitle }}</span>
                      {% endif %}
                      {% if block.settings.banner_title_1 != '' or block.settings.banner_title_2 != '' %}
                      <h2 class="title" style="color: {{ block.settings.banner_title_color }};">
                        {% if block.settings.banner_title_1 != '' %}
                        <span>{{ block.settings.banner_title_1 }}</span>
                        {% endif %}
                        {% if block.settings.banner_title_2 != '' %}
                        <span>{{ block.settings.banner_title_2 }}</span>
                        {% endif %}
                      </h2>
                      {% endif %}
                  </div>
                  <div class="banner-button">
                    <span class="banner-btn"><i class="feather-arrow-right"></i></span>
                  </div>
                </div>
              </a>
            </div>
          </li>
          {% when 'offer_banner' %}
            <li class="offer-banner-li offer-banner">
              <div class="banner-block">
                <a href="{{ block.settings.banner_url }}" class="banner-img">
                  {%- if block.settings.banner_img -%}
                  {{ block.settings.banner_img | image_url: width: 1024 | image_tag:
                    loading: 'lazy',
                    width: block.settings.banner_img.width,
                    height: block.settings.banner_img.height,
                    class: "img-fluid",
                    alt: block.settings.banner_img.alt | escape }}
                  {%- else -%}
                  {%- capture placeholder -%}collection-{% cycle 1, 2, 3, 4, 5, 6 %}{%- endcapture -%}
                  {{ placeholder | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                  <div class="banner-content">
                    {% if block.settings.banner_subtitle != '' %}
                    <span class="subtitle" style="color: {{ block.settings.banner_subtitle_color }};">{{ block.settings.banner_subtitle }}</span>
                    {% endif %}
                    {% if block.settings.banner_title != '' %}
                    <h2 class="title" style="color: {{ block.settings.banner_title_color }};">{{ block.settings.banner_title }}</h2>
                    {% endif %}
                  </div>
                </a>
              </div>
            </li>
          {% endcase %}
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Offer Banner",
  "settings": [
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Section Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Section Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 100
    },
    {
      "type": "paragraph",
      "content": "Ipad Pro / Ipad"
    },
    {
      "type": "range",
      "id": "section_padding_top_ip",
      "label": "Section Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 70
    },
    {
      "type": "range",
      "id": "section_padding_bottom_ip",
      "label": "Section Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 70
    },
    {
      "type": "paragraph",
      "content": "Mobile"
    },
    {
      "type": "range",
      "id": "section_padding_top_xs",
      "label": "Section Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "section_padding_bottom_xs",
      "label": "Section Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "button_banner",
      "name": "Button Banner",
      "settings": [
        {
          "type": "paragraph",
          "content": "Banner Image"
        },
        {
          "type": "image_picker",
          "id": "banner_img",
          "label": "Banner Image",
          "info": "Recommended Size: 580x580px"
        },
        {
          "type": "paragraph",
          "content": "Banner Content"
        },
        {
          "type": "text",
          "id": "banner_subtitle",
          "label": "Banner Subtitle",
          "default": "Sports offers"
        },
        {
          "type": "color",
          "id": "banner_subtitle_color",
          "label": "Banner Subtitle Color",
          "default": "#FFFFFF"
        },
        {
          "type": "text",
          "id": "banner_title_1",
          "label": "Title 1",
          "default": "Sports,"
        },
        {
          "type": "text",
          "id": "banner_title_2",
          "label": "Title 2",
          "default": "Your Way!"
        },
        {
          "type": "color",
          "id": "banner_title_color",
          "label": "Banner Title Color",
          "default": "#FFFFFF"
        },
        {
          "type": "url",
          "id": "banner_url",
          "label": "Banner url"
        }
      ]
    },
    {
      "type": "offer_banner",
      "name": "Offer banner",
      "settings": [
        {
          "type": "paragraph",
          "content": "Banner Image"
        },
        {
          "type": "image_picker",
          "id": "banner_img",
          "label": "Banner Image",
          "info": "Recommended Size: 580x580px"
        },
        {
          "type": "paragraph",
          "content": "Banner Content"
        },
        {
          "type": "text",
          "id": "banner_subtitle",
          "label": "Banner Subtitle",
          "default": "Use code: spt246"
        },
        {
          "type": "color",
          "id": "banner_subtitle_color",
          "label": "Banner Subtitle Color",
          "default": "#FFFFFF"
        },
        {
          "type": "text",
          "id": "banner_title",
          "label": "Title",
          "default": "Football accessories"
        },
        {
          "type": "color",
          "id": "banner_title_color",
          "label": "Banner Title Color",
          "default": "#FFFFFF"
        },
        {
          "type": "url",
          "id": "banner_url",
          "label": "Banner url"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Offer Banner"
    }
  ]
}
{% endschema %}
<style>
  .offer-banner-area {
    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
  }
  @media(max-width: 1199px) {
    .offer-banner-area {
      padding-top: {{ section.settings.section_padding_top_ip }}px;
      padding-bottom: {{ section.settings.section_padding_bottom_ip }}px;
    }
  }
  @media(max-width: 767px) {
    .offer-banner-area {
      padding-top: {{ section.settings.section_padding_top_xs }}px;
      padding-bottom: {{ section.settings.section_padding_bottom_xs }}px;
    }
  }

  /*=====================================
      banner css
  ======================================*/
  /* main css */
  .offer-banner-area ul.offer-banner-ul {
    position: relative;
    display: -ms-flexbox;
    display: flex;
    -ms-flex-wrap: wrap;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    {%- if settings.enable_rtl -%}
    margin: -30px -30px 0px 0px;
    {%- else -%}
    margin: -30px 0px 0px -30px;
    {%- endif -%}
  }
  .offer-banner-area ul.offer-banner-ul li.offer-banner-li {
    width: calc(33.33% - 30px);
    {%- if settings.enable_rtl -%}
    margin: 30px 30px 0px 0px;
    {%- else -%}
    margin: 30px 0px 0px 30px;
    {%- endif -%}
  }
  @media (max-width: 991px) {
    .offer-banner-area ul.offer-banner-ul {
      {%- if settings.enable_rtl -%}
      margin: -30px -30px 0px 0px;
      {%- else -%}
      margin: -30px 0px 0px -30px;
      {%- endif -%}
    }
    .offer-banner-area ul.offer-banner-ul li.offer-banner-li {
      width: calc(50% - 30px);
      {%- if settings.enable_rtl -%}
      margin: 30px 30px 0px 0px;
      {%- else -%}
      margin: 30px 0px 0px 30px;
      {%- endif -%}
    }
    .offer-banner-area ul.offer-banner-ul li.offer-banner-li.offer-banner {
      order: 1;
    }
  }
  @media (max-width: 767px) {
    .offer-banner-area ul.offer-banner-ul {
      {%- if settings.enable_rtl -%}
      margin: -30px -12px 0px 0px;
      {%- else -%}
      margin: -30px 0px 0px -12px;
      {%- endif -%}
    }
    .offer-banner-area ul.offer-banner-ul li.offer-banner-li {
      width: calc(50% - 12px);
      {%- if settings.enable_rtl -%}
      margin: 30px 12px 0px 0px;
      {%- else -%}
      margin: 30px 0px 0px 12px;
      {%- endif -%}
    }
  }
  @media (max-width: 600px) {
    .offer-banner-area ul.offer-banner-ul li.offer-banner-li {
      width: calc(100% - 12px);
    }
    .offer-banner-area ul.offer-banner-ul li.offer-banner-li.offer-banner {
      order: unset;
    }
  }

  /* button banner css */
  .offer-banner-area ul.offer-banner-ul li.offer-banner-li .banner-block a.banner-img {
    position: relative;
    overflow: hidden;
    display: block;
  }
  .offer-banner-area ul.offer-banner-ul li.offer-banner-li .banner-block a.banner-img::before {
    background-color: #000000;
    content: "";
    position: absolute;
    top: 0px;
    right: 0px;
    bottom: 0px;
    left: 0px;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    z-index: 1;
  }
  .offer-banner-area ul.offer-banner-ul li.offer-banner-li:hover .banner-block a.banner-img::before {
    opacity: 0.3;
    visibility: visible;
  }
  {%- if settings.enable_rtl -%}
  .offer-banner-area ul.offer-banner-ul li.offer-banner-li .banner-block a.banner-img img {
    transform: scaleX(-1);
  }
  {%- endif -%}
  .offer-banner-area ul.offer-banner-ul li.offer-banner-li:hover .banner-block a.banner-img svg {
    width: 100%;
  }
  .offer-banner-area ul.offer-banner-ul li.button-banner .banner-block a.banner-img .banner-content {
    bottom: 30px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }
  .offer-banner-area ul.offer-banner-ul li.offer-banner-li .banner-block a.banner-img .banner-content {
    position: absolute;
    right: 30px;
    left: 30px;
    z-index: 2;
  }
  .offer-banner-area ul.offer-banner-ul li.offer-banner-li .banner-block a.banner-img::before,
  .offer-banner-area ul.offer-banner-ul li.offer-banner-li:hover .banner-block a.banner-img::before {
    -webkit-transition: all .3s ease-in-out 0s;
    -o-transition: all .3s ease-in-out 0s;
    transition: all .3s ease-in-out 0s;
  }
  .offer-banner-area ul.offer-banner-ul li.button-banner .banner-block a.banner-img .banner-content .banner-text  {
    width: calc(100% - 80px);
  }
  .offer-banner-area ul.offer-banner-ul li.button-banner .banner-block a.banner-img .banner-content .banner-text span.subtitle {
    margin-bottom: 17px;
  }
  .offer-banner-area ul.offer-banner-ul li.button-banner .banner-block a.banner-img .banner-content .banner-text h2.title {
    font-size: 40px;
    {% if settings.other_custom_font_handle_enable %}
    font-family: '{{ settings.other_custom_font_handle }}', sans-serif;
    {% endif %}
    font-weight: var(--font-custom-weight-section-header);
    text-transform: uppercase;
    line-height: 1.1;
  }
  .offer-banner-area ul.offer-banner-ul li.button-banner .banner-block a.banner-img .banner-content .banner-button {
    {%- if settings.enable_rtl -%}
    margin-right: 30px;
    {%- else -%}
    margin-left: 30px;
    {%- endif -%}
  }
  .offer-banner-area ul.offer-banner-ul li.button-banner .banner-block a.banner-img .banner-content .banner-button span.banner-btn {
    background-color: transparent;
    color: #FFFFFF;
    font-size: 18px;
    width: 50px;
    height: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid #FFFFFF;
    -webkit-transition: background-color .3s ease-in-out, color .3s ease-in-out, border-color .3s ease-in-out;
    -o-transition: background-color .3s ease-in-out, color .3s ease-in-out, border-color .3s ease-in-out;
    transition: background-color .3s ease-in-out, color .3s ease-in-out, border-color .3s ease-in-out;
  }
  .offer-banner-area ul.offer-banner-ul li.button-banner .banner-block a.banner-img .banner-content .banner-button span.banner-btn:hover {
    background-color: var(--font-color-primary);
    color: #FFFFFF;
    border-color: var(--font-color-primary);
  }
  {%- if settings.enable_rtl -%}
  .offer-banner-area ul.offer-banner-ul li.button-banner .banner-block a.banner-img .banner-content .banner-button span.banner-btn i {
    transform: scaleX(-1);
  }
  {%- endif -%}
  @media (max-width: 1399px) {
    .offer-banner-area ul.offer-banner-ul li.button-banner .banner-block a.banner-img .banner-content .banner-text h2.title {
      font-size: 30px;
    }
  }
  @media (max-width: 1199px) {
    .offer-banner-area ul.offer-banner-ul li.button-banner .banner-block a.banner-img .banner-content .banner-text span.subtitle {
      margin-bottom: 13px;
    }
    .offer-banner-area ul.offer-banner-ul li.button-banner .banner-block a.banner-img .banner-content .banner-text h2.title {
      font-size: 24px;
    }
  }
  @media (max-width: 767px) {
    .offer-banner-area ul.offer-banner-ul li.offer-banner-li .banner-block a.banner-img .banner-content {
      right: 12px;
      left: 12px;
    }
  }

  /* offer banner css */
  .offer-banner-area ul.offer-banner-ul li.offer-banner .banner-block a.banner-img .banner-content {
    top: 30px;
    text-align: center;
  }
  .offer-banner-area ul.offer-banner-ul li.offer-banner .banner-block a.banner-img .banner-content span.subtitle {
    margin-bottom: 22px;
    font-weight: var(--font-custom-weight-header);
    text-transform: uppercase;
  }
  .offer-banner-area ul.offer-banner-ul li.offer-banner .banner-block a.banner-img .banner-content h2.title {
    font-size: 30px;
    {% if settings.other_custom_font_handle_enable %}
    font-family: '{{ settings.other_custom_font_handle }}', sans-serif;
    {% endif %}
    font-weight: var(--font-custom-weight-section-header);
    text-transform: uppercase;
    line-height: 1.1;
  }
  @media (max-width: 1399px) {
    .offer-banner-area ul.offer-banner-ul li.offer-banner .banner-block a.banner-img .banner-content h2.title {
      font-size: 24px;
    }
  }
  @media (max-width: 1199px) {
    .offer-banner-area ul.offer-banner-ul li.offer-banner .banner-block a.banner-img .banner-content span.subtitle {
      margin-bottom: 13px;
    }
    .offer-banner-area ul.offer-banner-ul li.offer-banner .banner-block a.banner-img .banner-content h2.title {
      font-size: 20px;
    }
  } 
</style>