{% liquid
  assign sort_by = collection.sort_by | default: collection.default_sort_by
  assign has_brand_filter = false
  assign has_type_filter = false
  assign vendor_values = collection.products | map: 'vendor' | uniq
  assign type_values = collection.products | map: 'type' | uniq

  for filter in collection.filters
    assign filter_label_downcase = filter.label | downcase
    if filter_label_downcase contains 'brand' or filter_label_downcase contains 'vendor'
      assign has_brand_filter = true
    endif
    if filter_label_downcase contains 'type' or filter_label_downcase contains 'category'
      assign has_type_filter = true
    endif
  endfor
%}

{% capture rail_base_query %}
  sort_by={{ sort_by | url_encode }}
  {% for active_filter in collection.filters %}
    {% if active_filter.type == 'list' %}
      {% for active_value in active_filter.active_values %}
        {% unless active_value.param_name contains 'vendor' or active_value.param_name contains 'product_type' %}
          &{{ active_value.param_name | escape }}={{ active_value.value | url_encode }}
        {% endunless %}
      {% endfor %}
    {% elsif active_filter.type == 'price_range' %}
      {% if active_filter.min_value.value %}
        &{{ active_filter.min_value.param_name | escape }}={{ active_filter.min_value.value | money_without_currency | replace: ',', '' | url_encode }}
      {% endif %}
      {% if active_filter.max_value.value %}
        &{{ active_filter.max_value.param_name | escape }}={{ active_filter.max_value.value | money_without_currency | replace: ',', '' | url_encode }}
      {% endif %}
    {% endif %}
  {% endfor %}
{% endcapture %}
{% assign rail_base_query = rail_base_query | strip | strip_newlines | replace: ' ', '' %}

{% if collection %}
  <section class="collection-filter-rail">
    <div class="container">
      <div class="collection-filter-rail__heading">
        <h1>{{ collection.title }}</h1>
        <p>{{ collection.all_products_count }} items</p>
      </div>
      <div class="collection-filter-rail__shell">
        <div class="collection-filter-rail__left">
          {% if has_brand_filter == false and vendor_values.size > 1 %}
            <details class="collection-filter-rail__item collection-filter-rail__item--client" data-filter-key="vendor">
              <summary class="collection-filter-rail__button">
                <span>Brand</span>
                <i class="feather-chevron-down"></i>
              </summary>
              <div class="collection-filter-rail__panel">
                <ul class="collection-filter-rail__options" role="list">
                  <li>
                    <button type="button" class="collection-filter-rail__option collection-filter-rail__option--button is-active">
                      <span>All</span>
                    </button>
                  </li>
                  {% for vendor in vendor_values %}
                    {% assign vendor_name = vendor | strip %}
                    {% if vendor_name != blank %}
                      <li>
                        <button type="button" class="collection-filter-rail__option collection-filter-rail__option--button">
                            <span>{{ vendor_name }}</span>
                        </button>
                      </li>
                    {% endif %}
                  {% endfor %}
                </ul>
              </div>
            </details>
          {% endif %}

          {% if has_type_filter == false and type_values.size > 1 %}
            <details class="collection-filter-rail__item collection-filter-rail__item--client" data-filter-key="category">
              <summary class="collection-filter-rail__button">
                <span>Category</span>
                <i class="feather-chevron-down"></i>
              </summary>
              <div class="collection-filter-rail__panel">
                <ul class="collection-filter-rail__options" role="list">
                  <li>
                    <button type="button" class="collection-filter-rail__option collection-filter-rail__option--button is-active">
                      <span>All</span>
                    </button>
                  </li>
                  {% for product_type in type_values %}
                    {% assign type_name = product_type | strip %}
                    {% if type_name != blank %}
                      <li>
                        <button type="button" class="collection-filter-rail__option collection-filter-rail__option--button">
                            <span>{{ type_name }}</span>
                        </button>
                      </li>
                    {% endif %}
                  {% endfor %}
                </ul>
              </div>
            </details>
          {% endif %}

          {% for filter in collection.filters %}
            {% if filter.type == 'list' and filter.values.size > 0 %}
              <details class="collection-filter-rail__item">
                <summary class="collection-filter-rail__button">
                  <span>{{ filter.label }}</span>
                  <i class="feather-chevron-down"></i>
                </summary>
                <div class="collection-filter-rail__panel">
                  <ul class="collection-filter-rail__options" role="list">
                    {% for value in filter.values %}
                      <li>
                        <a
                          class="collection-filter-rail__option{% if value.active %} is-active{% endif %}{% if value.count == 0 and value.active == false %} is-disabled{% endif %}"
                          {% if value.count == 0 and value.active == false %}
                            aria-disabled="true"
                          {% else %}
                            href="{% if value.active %}{{ value.url_to_remove }}{% else %}{{ value.url_to_add }}{% endif %}"
                          {% endif %}
                        >
                          <span>{{ value.label }}</span>
                          <small>{{ value.count }}</small>
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                </div>
              </details>
            {% elsif filter.type == 'price_range' %}
              <details class="collection-filter-rail__item">
                <summary class="collection-filter-rail__button">
                  <span>{{ filter.label }}</span>
                  <i class="feather-chevron-down"></i>
                </summary>
                <div class="collection-filter-rail__panel collection-filter-rail__panel--price">
                  <form action="{{ collection.url }}" method="get" class="collection-filter-rail__price-form">
                    {% if collection.current_vendor %}
                      <input type="hidden" name="filter.p.vendor" value="{{ collection.current_vendor | escape }}">
                    {% endif %}
                    {% if collection.current_type %}
                      <input type="hidden" name="filter.p.product_type" value="{{ collection.current_type | escape }}">
                    {% endif %}
                    {% for active_filter in collection.filters %}
                      {% if active_filter.type == 'list' %}
                        {% for active_value in active_filter.active_values %}
                          <input type="hidden" name="{{ active_value.param_name }}" value="{{ active_value.value | escape }}">
                        {% endfor %}
                      {% endif %}
                    {% endfor %}
                    <div class="collection-filter-rail__price-fields">
                      <label>
                        <span>From</span>
                        <input
                          type="number"
                          name="{{ filter.min_value.param_name }}"
                          min="0"
                          placeholder="0"
                          {% if filter.min_value.value %}
                            value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                          {% endif %}
                        >
                      </label>
                      <label>
                        <span>To</span>
                        <input
                          type="number"
                          name="{{ filter.max_value.param_name }}"
                          min="0"
                          placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                          {% if filter.max_value.value %}
                            value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                          {% endif %}
                        >
                      </label>
                    </div>
                    <button type="submit" class="collection-filter-rail__apply">Apply</button>
                  </form>
                </div>
              </details>
            {% endif %}
          {% endfor %}
        </div>

        <div class="collection-filter-rail__right">
          <div class="collection-filter-rail__sort">
            <span>Sort</span>
            <select name="sort_by" id="CollectionFilterSort">
              {% for option in collection.sort_options %}
                <option value="{{ option.value }}" {% if option.value == sort_by %}selected{% endif %}>
                  {{ option.name }}
                </option>
              {% endfor %}
            </select>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      var sortSelect = document.getElementById('CollectionFilterSort');
      if (sortSelect) {
        sortSelect.addEventListener('change', function() {
          var url = new URL(window.location.href);
          url.searchParams.set('sort_by', sortSelect.value);
          window.location.href = url.toString();
        });
      }

      var filterRail = document.querySelector('.collection-filter-rail');
      var productGrid = document.getElementById('product-grid');
      var filterLeft = document.querySelector('.collection-filter-rail__left');
      var cards = productGrid ? Array.prototype.slice.call(productGrid.querySelectorAll('.single-product-wrap')) : [];

      function normaliseValues(raw) {
        if (!raw) return [];
        return raw
          .split('|')
          .map(function(value) { return value.trim(); })
          .filter(function(value) { return value.length > 0; });
      }

      if (filterRail && filterLeft && cards.length) {
        var existingLabels = Array.prototype.slice.call(filterLeft.querySelectorAll('.collection-filter-rail__button span'))
          .map(function(node) { return node.textContent.trim().toLowerCase(); });
        var selectedValues = {};
        var dynamicConfigs = [
          { key: 'vendor', label: 'Brand' },
          { key: 'category', label: 'Category' },
          { key: 'material', label: 'Material' },
          { key: 'shape', label: 'Shape' },
          { key: 'gender', label: 'Gender' },
          { key: 'color', label: 'Color' },
          { key: 'size', label: 'Size' },
          { key: 'frame-type', label: 'Frame Type' },
          { key: 'lens-feature', label: 'Lens Feature' },
          { key: 'progressive-bifocal', label: 'Progressive Bifocal' },
          { key: 'spring-hinges', label: 'Spring Hinges' },
          { key: 'face-shape', label: 'Face Shape' },
          { key: 'temple-length', label: 'Temple Length' },
          { key: 'bridge-width', label: 'Bridge Width' },
          { key: 'lens-width', label: 'Lens Width' },
          { key: 'lens-height', label: 'Lens Height' }
        ];

        function applyClientFilters() {
          cards.forEach(function(card) {
            var shouldShow = dynamicConfigs.every(function(config) {
              var selected = selectedValues[config.key];
              if (!selected) return true;
              var cardValues = normaliseValues(card.dataset['filter' + config.key.replace(/(^|-)([a-z])/g, function(_, __, letter) { return letter.toUpperCase(); })]);
              return cardValues.indexOf(selected) !== -1;
            });
            var listItem = card.closest('li');
            if (listItem) {
              listItem.style.display = shouldShow ? '' : 'none';
            }
          });
        }

        filterLeft.querySelectorAll('.collection-filter-rail__item--client').forEach(function(details) {
          var filterKey = details.dataset.filterKey;
          var optionsList = details.querySelector('.collection-filter-rail__options');
          if (!filterKey || !optionsList) return;

          optionsList.addEventListener('click', function(event) {
            var button = event.target.closest('.collection-filter-rail__option--button');
            if (!button) return;
            event.preventDefault();
            optionsList.querySelectorAll('.collection-filter-rail__option--button').forEach(function(optionButton) {
              optionButton.classList.remove('is-active');
            });
            button.classList.add('is-active');
            var value = button.textContent.trim();
            if (value === 'All') {
              delete selectedValues[filterKey];
            } else {
              selectedValues[filterKey] = value;
            }
            applyClientFilters();
            details.open = false;
          });
        });

        dynamicConfigs.forEach(function(config) {
          if (existingLabels.indexOf(config.label.toLowerCase()) !== -1) return;

          var unique = [];
          cards.forEach(function(card) {
            var datasetKey = 'filter' + config.key.replace(/(^|-)([a-z])/g, function(_, __, letter) { return letter.toUpperCase(); });
            normaliseValues(card.dataset[datasetKey]).forEach(function(value) {
              if (unique.indexOf(value) === -1) unique.push(value);
            });
          });

          if (unique.length < 2) return;

          var details = document.createElement('details');
          details.className = 'collection-filter-rail__item collection-filter-rail__item--dynamic';
          details.innerHTML =
            '<summary class="collection-filter-rail__button"><span>' + config.label + '</span><i class="feather-chevron-down"></i></summary>' +
            '<div class="collection-filter-rail__panel"><ul class="collection-filter-rail__options" role="list"></ul></div>';

          var optionsList = details.querySelector('.collection-filter-rail__options');

          details.addEventListener('toggle', function() {
            if (!details.open) return;
            document.querySelectorAll('.collection-filter-rail details').forEach(function(other) {
              if (other !== details) other.open = false;
            });
          });

          var allItem = document.createElement('li');
          allItem.innerHTML = '<button type="button" class="collection-filter-rail__option collection-filter-rail__option--button is-active"><span>All</span></button>';
          optionsList.appendChild(allItem);

          unique.sort().forEach(function(value) {
            var item = document.createElement('li');
            item.innerHTML = '<button type="button" class="collection-filter-rail__option collection-filter-rail__option--button"><span>' + value + '</span></button>';
            optionsList.appendChild(item);
          });

          optionsList.addEventListener('click', function(event) {
            var button = event.target.closest('.collection-filter-rail__option--button');
            if (!button) return;
            event.preventDefault();
            optionsList.querySelectorAll('.collection-filter-rail__option--button').forEach(function(optionButton) {
              optionButton.classList.remove('is-active');
            });
            button.classList.add('is-active');
            var value = button.textContent.trim();
            if (value === 'All') {
              delete selectedValues[config.key];
            } else {
              selectedValues[config.key] = value;
            }
            applyClientFilters();
            details.open = false;
          });

          filterLeft.appendChild(details);
        });
      }

      document.querySelectorAll('.collection-filter-rail details').forEach(function(detail) {
        detail.addEventListener('toggle', function() {
          if (!detail.open) return;
          document.querySelectorAll('.collection-filter-rail details').forEach(function(other) {
            if (other !== detail) other.open = false;
          });
        });
      });

      document.addEventListener('click', function(event) {
        if (!event.target.closest('.collection-filter-rail__item')) {
          document.querySelectorAll('.collection-filter-rail details[open]').forEach(function(detail) {
            detail.open = false;
          });
        }
      });
    });
  </script>

  {% style %}
    .collection-filter-rail {
      margin-top: 26px;
      padding: 0 0 16px;
    }

    .collection-filter-rail__heading {
      display: flex;
      align-items: baseline;
      gap: 10px;
      margin-bottom: 16px;
    }

    .collection-filter-rail__heading h1 {
      margin: 0;
      color: #171d2f;
      font-size: clamp(26px, 2.4vw, 38px);
      font-weight: 700;
      line-height: 1.08;
    }

    .collection-filter-rail__heading p {
      margin: 0;
      color: #61708c;
      font-size: 15px;
      line-height: 1.2;
    }

    .collection-filter-rail__shell {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
      padding: 16px 18px;
      background: #f3f5f8;
      border: 1px solid rgba(28, 51, 103, 0.08);
      border-radius: 22px;
    }

    .collection-filter-rail__left {
      display: flex;
      align-items: center;
      gap: 12px;
      flex: 1 1 auto;
      min-width: 0;
      flex-wrap: wrap;
    }

    .collection-filter-rail__right {
      flex: 0 0 auto;
      display: flex;
      align-items: center;
      justify-content: flex-end;
    }

    .collection-filter-rail__item {
      position: relative;
      flex: 0 0 auto;
    }

    .collection-filter-rail__item summary {
      list-style: none;
    }

    .collection-filter-rail__item summary::-webkit-details-marker {
      display: none;
    }

    .collection-filter-rail__button,
    .collection-filter-rail__sort {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      min-height: 48px;
      padding: 0 16px;
      border-radius: 14px;
      border: 1px solid rgba(28, 51, 103, 0.10);
      background: #fff;
      color: #1b2540;
      font-size: 14px;
      font-weight: 600;
      line-height: 1;
      cursor: pointer;
      white-space: nowrap;
    }

    .collection-filter-rail__button i,
    .collection-filter-rail__sort i {
      font-size: 14px;
    }

    .collection-filter-rail__sort {
      gap: 12px;
      padding-right: 12px;
    }

    .collection-filter-rail__sort span {
      color: #61708c;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .collection-filter-rail__sort select {
      border: 0;
      background: transparent;
      color: #1b2540;
      font-size: 14px;
      font-weight: 600;
      padding-right: 20px;
      cursor: pointer;
      outline: none;
    }

    .collection-filter-rail__panel {
      position: absolute;
      top: calc(100% + 10px);
      left: 0;
      z-index: 20;
      min-width: 240px;
      padding: 14px;
      border-radius: 18px;
      border: 1px solid rgba(28, 51, 103, 0.10);
      background: #fff;
      box-shadow: 0 20px 50px rgba(15, 30, 68, 0.12);
    }

    .collection-filter-rail__options {
      margin: 0;
      padding: 0;
      list-style: none;
      display: grid;
      gap: 8px;
      max-height: 320px;
      overflow-y: auto;
    }

    .collection-filter-rail__option {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 10px 12px;
      border-radius: 12px;
      color: #1b2540;
      background: #fff;
      text-decoration: none;
      transition: background 0.2s ease, color 0.2s ease;
    }

    .collection-filter-rail__option:hover,
    .collection-filter-rail__option.is-active {
      background: #eef3fb;
      color: #17397a;
    }

    .collection-filter-rail__option.is-disabled {
      opacity: 0.45;
      pointer-events: none;
    }

    .collection-filter-rail__option small {
      color: #7f8aa3;
      font-size: 12px;
      font-weight: 600;
    }

    .collection-filter-rail__option--button {
      width: 100%;
      border: 0;
      text-align: left;
      cursor: pointer;
    }

    .collection-filter-rail__panel--price {
      min-width: 280px;
    }

    .collection-filter-rail__price-form {
      display: grid;
      gap: 12px;
    }

    .collection-filter-rail__price-fields {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .collection-filter-rail__price-fields label {
      display: grid;
      gap: 6px;
      color: #61708c;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .collection-filter-rail__price-fields input {
      width: 100%;
      min-height: 44px;
      padding: 0 12px;
      border-radius: 12px;
      border: 1px solid rgba(28, 51, 103, 0.12);
      color: #1b2540;
      background: #fff;
      font-size: 15px;
      outline: none;
    }

    .collection-filter-rail__apply {
      min-height: 46px;
      border: 0;
      border-radius: 14px;
      background: #1f3f87;
      color: #fff;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
    }

    @media (max-width: 991px) {
      .collection-filter-rail {
        margin-top: 20px;
        padding: 0 0 14px;
      }

      .collection-filter-rail__heading {
        gap: 8px;
        margin-bottom: 12px;
      }

      .collection-filter-rail__heading h1 {
        font-size: 28px;
      }

      .collection-filter-rail__shell {
        align-items: stretch;
        flex-direction: column;
        gap: 12px;
        padding: 14px;
        border-radius: 18px;
      }

      .collection-filter-rail__left,
      .collection-filter-rail__right {
        width: 100%;
      }

      .collection-filter-rail__left {
        flex-wrap: nowrap;
        overflow-x: auto;
        padding-bottom: 4px;
        gap: 10px;
      }

      .collection-filter-rail__left::-webkit-scrollbar {
        height: 0;
      }

      .collection-filter-rail__right {
        justify-content: flex-start;
      }

      .collection-filter-rail__sort {
        width: 100%;
        justify-content: space-between;
      }

      .collection-filter-rail__panel {
        left: 0;
      }
    }

    @media (max-width: 767px) {
      .collection-filter-rail {
        margin-top: 16px;
        padding: 0 0 12px;
      }

      .collection-filter-rail__heading {
        align-items: flex-start;
        flex-direction: column;
        gap: 4px;
        margin-bottom: 10px;
      }

      .collection-filter-rail__heading h1 {
        font-size: 22px;
      }

      .collection-filter-rail__heading p {
        font-size: 13px;
      }

      .collection-filter-rail__shell {
        gap: 10px;
        padding: 12px;
        border-radius: 16px;
      }

      .collection-filter-rail__button,
      .collection-filter-rail__sort {
        min-height: 42px;
        padding: 0 13px;
        font-size: 13px;
      }

      .collection-filter-rail__panel {
        min-width: 220px;
      }

      .collection-filter-rail__left {
        gap: 8px;
        margin: 0 -2px;
        padding: 0 2px 4px;
      }

      .collection-filter-rail__sort span {
        font-size: 11px;
      }

      .collection-filter-rail__sort select {
        min-width: 0;
        max-width: 62vw;
        font-size: 13px;
        text-overflow: ellipsis;
      }

      .collection-filter-rail__panel {
        min-width: min(260px, calc(100vw - 40px));
        max-width: calc(100vw - 32px);
      }

      .collection-filter-rail__price-fields {
        grid-template-columns: minmax(0, 1fr);
      }
    }
  {% endstyle %}

{% endif %}

{% schema %}
{
  "name": "Collection filter bar",
  "settings": [],
  "presets": [
    {
      "name": "Collection filter bar"
    }
  ]
}
{% endschema %}
