{% comment %}
  Brand logo pills
  - GlassesUSA-inspired brand rail/grid
  - Uploadable logos
  - Optional links
{% endcomment %}

{%- liquid
  assign heading_text = section.settings.heading | default: 'All the brands you love.'
  assign eyebrow_text = section.settings.eyebrow | default: 'Trusted brands'
  assign view_all_text = section.settings.view_all_text | default: 'All Brands'
  assign view_all_url = section.settings.view_all_url | default: routes.all_products_collection_url
-%}

<section class="brand-pills-gusa">
  <div class="brand-pills-gusa__inner">
    {% if eyebrow_text != blank %}
    <p class="brand-pills-gusa__eyebrow">{{ eyebrow_text }}</p>
    {% endif %}
    {% if heading_text != blank %}
    <h2 class="brand-pills-gusa__heading">{{ heading_text }}</h2>
    {% endif %}

    <div class="brand-pills-gusa__list">
      {% for block in section.blocks %}
        {% if block.type == 'brand' %}
          {%- liquid
            assign brand_name = block.settings.name | strip
            assign logo_path = block.settings.logo | downcase
            if brand_name == blank
              if logo_path contains 'oak'
                assign brand_name = 'Oakley'
              elsif logo_path contains 'herrera'
                assign brand_name = 'Carolina Herrera'
              elsif logo_path contains 'rayban' or logo_path contains 'ray-ban'
                assign brand_name = 'Ray-Ban'
              elsif logo_path contains 'revel'
                assign brand_name = 'Revel'
              else
                assign brand_name = 'Brand'
              endif
            endif
            assign brand_filter_name = brand_name
            assign brand_filter_name = brand_filter_name | replace: ' Eyewear', ''
            assign brand_filter_name = brand_filter_name | replace: ' eyewear', ''
            assign brand_filter_param = brand_filter_name | url_encode
            assign fallback_brand_url = '/a/search/brands?filter_brand=' | append: brand_filter_param
            assign brand_url = block.settings.url | default: fallback_brand_url
          -%}
          <a href="{{ brand_url }}" class="brand-pills-gusa__pill" {{ block.shopify_attributes }}>

          {% if block.settings.logo %}
            <img
              src="{{ block.settings.logo | image_url: width: 320 }}"
              alt="{{ brand_name | escape }}"
              loading="lazy"
            >
          {% elsif brand_name != blank %}
            <span class="brand-pills-gusa__text">{{ brand_name }}</span>
          {% else %}
            <span class="brand-pills-gusa__text">Brand</span>
          {% endif %}

          </a>
        {% endif %}
      {% endfor %}

      <a href="{{ view_all_url }}" class="brand-pills-gusa__pill brand-pills-gusa__pill--all">
        <span class="brand-pills-gusa__text">{{ view_all_text }}</span>
      </a>
    </div>
  </div>
</section>

{% style %}
.brand-pills-gusa {
  padding: 28px 20px 18px;
  background: #edf4fb;
}
.brand-pills-gusa__inner {
  max-width: 100%;
  margin: 0 auto;
  text-align: center;
}
.brand-pills-gusa__eyebrow {
  margin: 0 0 10px;
  color: #8a94a6;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}
.brand-pills-gusa__heading {
  margin: 0 0 14px;
  color: #111827;
  font-size: clamp(24px, 2.8vw, 38px);
  line-height: 1.05;
  letter-spacing: -0.045em;
}
.brand-pills-gusa__list {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14px;
  flex-wrap: nowrap;
  overflow-x: auto;
  overflow-y: hidden;
  width: 100%;
  padding: 4px 28px 6px;
  scroll-behavior: smooth;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.brand-pills-gusa__list::-webkit-scrollbar {
  display: none;
}
.brand-pills-gusa__pill {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  min-width: 186px;
  min-height: 68px;
  padding: 12px 16px;
  border-radius: 999px;
  border: 1.5px solid #d6deea;
  background: rgba(255,255,255,0.96);
  text-decoration: none;
  transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease;
}
.brand-pills-gusa__pill:hover {
  transform: translateY(-2px);
  border-color: #9db4d7;
  box-shadow: 0 14px 28px rgba(15, 23, 42, 0.08);
}
.brand-pills-gusa__pill img {
  max-width: 112px;
  max-height: 32px;
  width: auto;
  height: auto;
  object-fit: contain;
  filter: grayscale(100%);
  opacity: 0.92;
  transition: filter .2s ease, opacity .2s ease;
}
.brand-pills-gusa__pill:hover img {
  filter: grayscale(0%);
  opacity: 1;
}
.brand-pills-gusa__text {
  color: #374151;
  font-size: 15px;
  font-weight: 700;
  line-height: 1;
}
.brand-pills-gusa__pill--all .brand-pills-gusa__text {
  color: #2a80e3;
  font-size: 17px;
}
@media (max-width: 1199px) {
}
@media (max-width: 991px) {
  .brand-pills-gusa {
    padding: 18px 16px 14px;
  }
  .brand-pills-gusa__eyebrow {
    margin-bottom: 8px;
    font-size: 11px;
    letter-spacing: 0.12em;
  }
  .brand-pills-gusa__heading {
    font-size: 30px;
    margin-bottom: 12px;
  }
  .brand-pills-gusa__list {
    gap: 12px;
    padding-left: 10px;
    padding-right: 10px;
  }
  .brand-pills-gusa__pill {
    min-width: 154px;
    min-height: 58px;
    padding: 10px 14px;
  }
}
@media (max-width: 767px) {
  .brand-pills-gusa {
    padding: 14px 12px 12px;
  }
  .brand-pills-gusa__eyebrow {
    margin-bottom: 6px;
    font-size: 10px;
  }
  .brand-pills-gusa__heading {
    margin-bottom: 10px;
    font-size: 24px;
  }
  .brand-pills-gusa__list {
    gap: 10px;
    justify-content: flex-start;
    padding-left: 4px;
    padding-right: 4px;
  }
  .brand-pills-gusa__pill {
    min-width: 138px;
    min-height: 52px;
  }
  .brand-pills-gusa__pill img {
    max-width: 78px;
    max-height: 22px;
  }
  .brand-pills-gusa__text {
    font-size: 14px;
  }
  .brand-pills-gusa__pill--all .brand-pills-gusa__text {
    font-size: 15px;
  }
}
{% endstyle %}

{% schema %}
{
  "name": "Brand logo pills",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Trusted brands"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "All the brands you love."
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all text",
      "default": "All Brands"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View all link"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Brand logo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Brand name"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Brand link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand logo pills",
      "blocks": [
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" },
        { "type": "brand" }
      ]
    }
  ]
}
{% endschema %}
