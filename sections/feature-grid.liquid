{% comment %}
==============================================
SECTION 2: Feature Grid (3 Columns)
==============================================
{% endcomment %}

{% comment %} File: sections/feature-grid.liquid {% endcomment %}
<section class="fg-section" style="padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px; background-color: {{ section.settings.background_color }};">
  <div class="container">
    {% if section.settings.heading != blank %}
      <h2 class="fg-heading" style="color: {{ section.settings.heading_color }};">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <div class="fg-grid">
      {% for block in section.blocks %}
        <div class="fg-card" {{ block.shopify_attributes }}>
          {% if block.settings.image_type == 'icon' and block.settings.icon != blank %}
            <div class="fg-card__icon-wrap">
              <img src="{{ block.settings.icon | image_url: width: 200 }}" alt="{{ block.settings.title }}" style="max-width: {{ block.settings.icon_size }}px;">
            </div>
          {% elsif block.settings.image_type == 'image' and block.settings.image != blank %}
            <div class="fg-card__image-wrap">
              <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title }}" style="border-radius: {{ block.settings.image_radius }}px;">
            </div>
          {% endif %}

          {% if block.settings.title != blank %}
            <h3 class="fg-card__title" style="color: {{ section.settings.title_color }}; font-size: {{ block.settings.title_size }}px;">
              {{ block.settings.title }}
            </h3>
          {% endif %}

          {% if block.settings.description != blank %}
            <p class="fg-card__desc" style="color: {{ section.settings.text_color }};">
              {{ block.settings.description }}
            </p>
          {% endif %}

          {% if block.settings.link_text != blank %}
            <a href="{{ block.settings.link_url }}" class="fg-card__link" style="color: {{ section.settings.link_color }};">
              {{ block.settings.link_text }} →
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
.fg-heading {
  text-align: center;
  font-size: clamp(1.5rem, 2.5vw, 2.2rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  margin-bottom: 3rem;
}

.fg-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 28px;
}

.fg-card {
  background: #fff;
  border: 1px solid #e8ecf0;
  border-radius: 1.25rem;
  padding: 2.5rem 2rem;
  text-align: center;
  transition: transform 0.25s ease, box-shadow 0.25s ease;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.fg-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 40px rgba(0,0,0,0.1);
  border-color: transparent;
}

.fg-card__icon-wrap {
  margin-bottom: 1.5rem;
}

.fg-card__icon-wrap img {
  display: block;
  margin: 0 auto;
  object-fit: contain;
}

.fg-card__image-wrap {
  width: 100%;
  margin-bottom: 1.5rem;
}

.fg-card__image-wrap img {
  width: 100%;
  height: auto;
  display: block;
}

.fg-card__title {
  font-weight: 700;
  line-height: 1.3;
  margin-bottom: 0.75rem;
}

.fg-card__desc {
  font-size: 15px;
  line-height: 1.7;
  flex: 1;
}

.fg-card__link {
  display: inline-block;
  margin-top: 1.25rem;
  font-weight: 600;
  font-size: 14px;
  text-decoration: none;
  letter-spacing: 0.01em;
  transition: opacity 0.2s;
}

.fg-card__link:hover {
  opacity: 0.75;
}

@media (max-width: 600px) {
  .fg-grid {
    grid-template-columns: 1fr;
    gap: 20px;
  }
}
</style>

{% schema %}
{
  "name": "Feature Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Why Choose Us"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Feature Title Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link Color",
      "default": "#0066cc"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "image_type",
          "label": "Image Type",
          "options": [
            {"value": "icon", "label": "Small Icon"},
            {"value": "image", "label": "Full Image"}
          ],
          "default": "icon"
        },
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (for small icon type)",
          "info": "Displays as small icon above title"
        },
        {
          "type": "range",
          "id": "icon_size",
          "label": "Icon Size",
          "min": 40,
          "max": 150,
          "step": 10,
          "default": 80
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (for full image type)",
          "info": "Displays as full-width feature image"
        },
        {
          "type": "range",
          "id": "image_radius",
          "label": "Image Border Radius",
          "min": 0,
          "max": 30,
          "step": 5,
          "default": 30
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "range",
          "id": "title_size",
          "label": "Title Size",
          "min": 16,
          "max": 36,
          "step": 2,
          "default": 24
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Feature description goes here"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature Grid",
      "blocks": [
        {"type": "feature"},
        {"type": "feature"},
        {"type": "feature"}
      ]
    }
  ]
}
{% endschema %}
