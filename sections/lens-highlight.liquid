<section class="lens-highlight">
  <div class="lens-highlight__inner">
    <img src="{{ section.settings.image | image_url: width: 1600 }}" alt="">
    <div>
      <h2>{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>
      <a href="{{ section.settings.cta_url }}" class="btn-primary">
        {{ section.settings.cta_label }}
      </a>
    </div>
  </div>
</section>

<style>
.lens-highlight {
  padding: 4rem 2rem;
}
.lens-highlight__inner {
  max-width: 1200px;
  margin: auto;
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 3rem;
  align-items: center;
}
.lens-highlight img {
  width: 100%;
  border-radius: 1rem;
}
</style>

{% schema %}
{
  "name": "Lens highlight",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "text", "label": "Text" },
    { "type": "text", "id": "cta_label", "label": "CTA label" },
    { "type": "url", "id": "cta_url", "label": "CTA link" }
  ],
  "presets": [{ "name": "Lens highlight" }]
}
{% endschema %}