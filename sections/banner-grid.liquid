<style>
  .home-banner-grid {
    padding-top: {{ section.settings.section_padding_top }}px;
    padding-bottom: {{ section.settings.section_padding_bottom }}px;
  }
  @media(max-width: 1199px) {
    .home-banner-grid {
      padding-top: {{ section.settings.section_padding_top_ip }}px;
      padding-bottom: {{ section.settings.section_padding_bottom_ip }}px;
    }
  }
  @media(max-width: 767px) {
    .home-banner-grid {
      padding-top: {{ section.settings.section_padding_top_xs }}px;
      padding-bottom: {{ section.settings.section_padding_bottom_xs }}px;
    }
  }

  /*=====================================
      banner css
  ======================================*/
  /* main css */
  .home-banner-grid ul.banner-ul {
    position: relative;
    display: -ms-flexbox;
    display: flex;
    -ms-flex-wrap: wrap;
    flex-wrap: wrap;
    {%- if settings.enable_rtl -%}
    margin: -30px -30px 0px 0px;
    {%- else -%}
    margin: -30px 0px 0px -30px;
    {%- endif -%}
  }
  .home-banner-grid ul.banner-ul li.banner-li {
    {%- if settings.enable_rtl -%}
    margin: 30px 30px 0px 0px;
    {%- else -%}
    margin: 30px 0px 0px 30px;
    {%- endif -%}
  }
  .home-banner-grid ul.banner-ul li.banner-li.one-banner {
    width: calc(41.67% - 30px);
  }
  .home-banner-grid ul.banner-ul li.banner-li.multiple-banner {
    width: calc(58.33% - 30px);
  }
  @media (max-width: 991px) {
    .home-banner-grid ul.banner-ul li.banner-li.one-banner,
    .home-banner-grid ul.banner-ul li.banner-li.multiple-banner {
      width: calc(100% - 30px);
    }
  }
  /* one banner css */
  .one-banner .banner-block {
    position: relative;
  }
  .one-banner .banner-block,
  .one-banner .banner-block a.banner-img,
  .one-banner .banner-block a.banner-img span.image,
  .one-banner .banner-block a.banner-img span.image img {
    height: 100%;
  }
  .one-banner .banner-block a.banner-img span.image img {
    object-fit: cover;
    {%- if settings.enable_rtl -%}
    transform: scaleX(-1);
    {%- endif -%}
    border-radius: var(--sti-border-radius);
  }
  .one-banner .banner-block a.banner-img span.image svg {
    width: 100%;
  }
  .one-banner .banner-block a.banner-img .banner-content {
    position: absolute;
    top: 60px;
    right: 60px;
    left: 60px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
  }
  .one-banner .banner-block a.banner-img .banner-content .banner-text span.subtitle {
    margin-bottom: 15px;
  }
  .one-banner .banner-block a.banner-img .banner-content .banner-text h2.title {
    font-size: 40px;
    {% if settings.section_header_custom_font_handle_enable %}
    font-family: var(--font-custom-stack-section-header);
    font-weight: var(--font-custom-weight-section-header);
    font-style: var(--font-custom-style-section-header);
    {% else %}
    font-family: var(--font-stack-section-header);
    font-weight: var(--font-weight-section-header);
    font-style: var(--font-style-section-header);
    {% endif %}
    line-height: 1.2; 
  }
  .one-banner .banner-block a.banner-img .banner-content .banner-button span.banner-btn {
    width: max-content;
  }
  @media (max-width: 1399px) {
    .one-banner .banner-block a.banner-img .banner-content {
      top: 30px;
      right: 30px;
      left: 30px;
    }
    .one-banner .banner-block a.banner-img .banner-content .banner-text h2.title {
      font-size: 32px;
    }
  }
  @media (max-width: 1199px) {
    .one-banner .banner-block a.banner-img .banner-content .banner-text span.subtitle {
      margin-bottom: 8px;
    }
    .one-banner .banner-block a.banner-img .banner-content .banner-text h2.title {
      font-size: 24px;
    }
  }
  @media (max-width: 991px) {
    .one-banner .banner-block,
    .one-banner .banner-block a.banner-img,
    .one-banner .banner-block a.banner-img span.image,
    .one-banner .banner-block a.banner-img span.image img {
      height: unset;
    }
  }
  @media (max-width: 767px) {
    .one-banner .banner-block a.banner-img .banner-content {
      right: 12px;
      left: 12px;
    }
  }
  @media (max-width: 479px) {
    .one-banner .banner-block a.banner-img .banner-content {
      flex-direction: column;
      align-items: flex-start;
    } 
    .one-banner .banner-block a.banner-img .banner-content .banner-button {
      margin-top: 12px;
    }
  }

  /* grid banner css */
  .multiple-banner ul.grid-banner-ul {
    display: flex;
    flex-wrap: wrap;
    margin-top: -30px;
    {%- if settings.enable_rtl -%}
    margin-right: -30px;
    {%- else -%}
    margin-left: -30px;
    {%- endif -%}
  }
  .multiple-banner ul.grid-banner-ul li.grid-banner-li {
    margin-top: 30px;
    {%- if settings.enable_rtl -%}
    margin-right: 30px;
    {%- else -%}
    margin-left: 30px;
    {%- endif -%}
  }
  .multiple-banner ul.grid-banner-ul li.grid-banner-li.full-banner {
    width: calc(100% - 30px);
  }
  .multiple-banner ul.grid-banner-ul li.grid-banner-li.small-banner {
    width: calc(58.33% - 30px);
  }
  .multiple-banner ul.grid-banner-ul li.grid-banner-li.short-banner {
    width: calc(41.67% - 30px);
  }
  @media (max-width: 767px) {
    .multiple-banner ul.grid-banner-ul {
      {%- if settings.enable_rtl -%}
      margin-right: -12px;
      {%- else -%}
      margin-left: -12px;
      {%- endif -%}
    }
    .multiple-banner ul.grid-banner-ul li.grid-banner-li {
      {%- if settings.enable_rtl -%}
      margin-right: 12px;
      {%- else -%}
      margin-left: 12px;
      {%- endif -%}
    }
    .multiple-banner ul.grid-banner-ul li.grid-banner-li.full-banner {
      width: calc(100% - 12px);
    }
    .multiple-banner ul.grid-banner-ul li.grid-banner-li.small-banner {
      width: calc(58.33% - 12px);
    }
    .multiple-banner ul.grid-banner-ul li.grid-banner-li.short-banner {
      width: calc(41.67% - 12px);
    }
  }
  @media (max-width: 479px) {
    .multiple-banner ul.grid-banner-ul li.grid-banner-li.small-banner,
    .multiple-banner ul.grid-banner-ul li.grid-banner-li.short-banner {
      width: calc(100% - 12px);
    }
  }
  /* image css */
  .multiple-banner ul.grid-banner-ul li.small-banner .banner-block,
  .multiple-banner ul.grid-banner-ul li.short-banner .banner-block,
  .multiple-banner ul.grid-banner-ul li.small-banner .banner-block a.banner-img,
  .multiple-banner ul.grid-banner-ul li.short-banner .banner-block a.banner-img,
  .multiple-banner ul.grid-banner-ul li.small-banner .banner-block a.banner-img span.image,
  .multiple-banner ul.grid-banner-ul li.short-banner .banner-block a.banner-img span.image,
  .multiple-banner ul.grid-banner-ul li.small-banner .banner-block a.banner-img span.image img,
  .multiple-banner ul.grid-banner-ul li.short-banner .banner-block a.banner-img span.image img {
    height: 100%;
