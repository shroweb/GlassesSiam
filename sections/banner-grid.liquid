<section class="home-banner-grid">
  <div class="container">
    <div class="row">
      <div class="col">
        <ul class="banner-ul">
          {% for block in section.blocks %}
          {% case block.type %}
          {% when 'single_banner' %}
          <li class="banner-li one-banner">
            <div class="banner-block">
              <a href="{{ block.settings.full_banner_url }}" class="banner-img">
                <span class="image">
                  {% comment %}
                  <img src="https://dummyimage.com/750x1055/e2e2e2/999999" class="img-fluid" alt="category-image">
                  {% endcomment %}
                  {%- if block.settings.full_banner_img -%}
                    {{ block.settings.full_banner_img | image_url: width: 1499 | image_tag:
                    loading: 'lazy',
                    width: block.settings.full_banner_img.width,
                    height: block.settings.full_banner_img.height,
                    class: "img-fluid",
                    alt: block.settings.full_banner_img.alt | escape }}
                    {%- else -%}
                  {%- capture placeholder -%}collection-{% cycle 1, 2, 3, 4, 5, 6 %}{%- endcapture -%}
                    {{ placeholder | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </span>
                <div class="banner-content">
                  <div class="banner-text">
                    {% if block.settings.banner_subtitle != '' %}
                    <span class="subtitle" style="color: {{ block.settings.banner_subtitle_color }};">{{ block.settings.banner_subtitle }}</span>
                    {% endif %}
                    {% if block.settings.banner_title != '' %}
                    <h2 class="title" style="color: {{ block.settings.banner_title_color }};">
                      {% if block.settings.banner_title_1 != '' %}
                      <span>{{ block.settings.banner_title_1 }}</span>
                      {% endif %}
                      {% if block.settings.banner_title_2 != '' %}
                      <span>{{ block.settings.banner_title_2 }}</span>
                      {% endif %}
                    </h2>
                    {% endif %}
                  </div>
                  <div class="banner-button">
                    {% if block.settings.full_banner_btn_text != '' %}
                    <span class="banner-btn btn {% if block.settings.banner_btn_style == 'btn-style1' %}btn-style{% elsif block.settings.banner_btn_style == 'btn-style2' %}btn-style2{% else %}btn-style3{% endif %}">{{ block.settings.full_banner_btn_text }}</span>
                    {% endif %}
                  </div>
                </div>
              </a>
            </div>
          </li>

          {% when 'grid_banner' %}
          <li class="banner-li multiple-banner">
            <ul class="grid-banner-ul">
              <li class="grid-banner-li full-banner">
                <div class="banner-block">
                  <a href="{{ block.settings.f_banner_url }}" class="banner-img">
                    <span class="image">
                      {% comment %}
                      <img src="https://dummyimage.com/775x335/e2e2e2/999999" class="img-fluid" alt="category-image">
                      {% endcomment %}
                      {%- if block.settings.full_banner_image -%}
                      {{ block.settings.full_banner_image | image_url: width: 1024 | image_tag:
                      loading: 'lazy',
                      width: block.settings.full_banner_image.width,
                      height: block.settings.full_banner_image.height,
                      class: "img-fluid",
                      alt: block.settings.full_banner_image.alt | escape }}
                      {%- else -%}
                      {%- capture placeholder -%}collection-{% cycle 1, 2, 3, 4, 5, 6 %}{%- endcapture -%}
                      {{ placeholder | placeholder_svg_tag: 'placeholder-svg' }}
                      {%- endif -%}
                    </span>
                    <div class="banner-content">
                      {% if block.settings.f_banner_subtitle != '' %}
                      <span class="subtitle" style="color: {{ block.settings.f_banner_subtitle_color }};">{{ block.settings.f_banner_subtitle }}</span>
                      {% endif %}
                      {% if block.settings.f_banner_title_1 != '' or block.settings.f_banner_title_2 != '' %}
                      <h2 class="title" style="color: {{ block.settings.f_banner_title_color }};">
                        {% if block.settings.f_banner_title_1 != '' %}
                        <span>{{ block.settings.f_banner_title_1 }}</span>
                        {% endif %}
                        {% if block.settings.f_banner_title_2 != '' %}
                        <span>{{ block.settings.f_banner_title_2 }}</span>
                        {% endif %}
                      </h2>
                      {% endif %}
                      {% if block.settings.f_banner_button_text != '' %}
                      <span class="banner-btn btn {% if block.settings.f_banner_btn_style == 'btn-style1' %}btn-style{% elsif block.settings.f_banner_btn_style == 'btn-style2' %}btn-style2{% else %}btn-style3{% endif %}">{{ block.settings.f_banner_button_text }}</span>
                      {% endif %}
                    </div>
                  </a>
                </div>
              </li>
              <li class="grid-banner-li small-banner">
                <div class="banner-block">
                  <a href="{{ block.settings.small_banner_url }}" class="banner-img">
                    <span class="image">
                      {% comment %}
                      <img src="https://dummyimage.com/445x410/e2e2e2/999999" class="img-fluid" alt="category-image">
                      {% endcomment %}
                      {%- if block.settings.small_banner_image -%}
                      {{ block.settings.small_banner_image | image_url: width: 1024 | image_tag:
                      loading: 'lazy',
                      width: block.settings.small_banner_image.width,
                      height: block.settings.small_banner_image.height,
                      class: "img-fluid",
                      alt: block.settings.small_banner_image.alt | escape }}
                      {%- else -%}
                      {%- capture placeholder -%}collection-{% cycle 1, 2, 3, 4, 5, 6 %}{%- endcapture -%}
                      {{ placeholder | placeholder_svg_tag: 'placeholder-svg' }}
                      {%- endif -%}
                    </span>
                    <div class="banner-content">
                      {% if block.settings.s_banner_subtitle != '' %}
                      <span class="subtitle" style="color: {{ block.settings.s_banner_subtitle_color }};">{{ block.settings.s_banner_subtitle }}</span>
                      {% endif %}
                      {% if block.settings.s_banner_title != '' %}
                      <h2 class="title" style="color: {{ block.settings.s_banner_title_color }};">{{ block.settings.s_banner_title }}</h2>
                      {% endif %}
                    </div>
                  </a>
                </div>
              </li>
              <li class="grid-banner-li short-banner">
                <div class="banner-block">
                  <a href="{{ block.settings.short_banner_url }}" class="banner-img">
                    <span class="image">
                      {% comment %}
                      <img src="https://dummyimage.com/410x540/e2e2e2/999999" class="img-fluid" alt="category-image">
                      {% endcomment %}
                      {%- if block.settings.short_banner_image -%}
                      {{ block.settings.short_banner_image | image_url: width: 1024 | image_tag:
                      loading: 'lazy',
                      width: block.settings.short_banner_image.width,
                      height: block.settings.short_banner_image.height,
                      class: "img-fluid",
                      alt: block.settings.short_banner_image.alt | escape }}
                      {%- else -%}
                      {%- capture placeholder -%}collection-{% cycle 1, 2, 3, 4, 5, 6 %}{%- endcapture -%}
                      {{ placeholder | placeholder_svg_tag: 'placeholder-svg' }}
                      {%- endif -%}
                    </span>
                    <div class="banner-content">
                      {% if block.settings.short_banner_subtitle != '' %}
                      <span class="subtitle" style="color: {{ block.settings.short_banner_subtitle_color }};">{{ block.settings.short_banner_subtitle }}</span>
                      {% endif %}
                      {% if block.settings.short_banner_title != '' %}
                      <h2 class="title" style="color: {{ block.settings.short_banner_title_color }};">{{ block.settings.short_banner_title }}</h2>
                      {% endif %}
                    </div>
                  </a>
                </div>
              </li>
            </ul>
          </li>
          {% endcase %}
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>

