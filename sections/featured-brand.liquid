{% comment %}
==============================================
SECTION 3: Brand Grid with Logos
==============================================
{% endcomment %}

{% comment %} File: sections/brand-grid.liquid {% endcomment %}
<section class="brand-grid" style="
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  background-color: {{ section.settings.background_color }};
  text-align: center;
">
  <div class="container" style="max-width: 1400px; margin: 0 auto; padding: 0 20px;">
    {% if section.settings.heading != blank %}
      <h2 style="
        font-size: {{ section.settings.heading_size }}px;
        color: {{ section.settings.heading_color }};
        margin-bottom: 60px;
        font-weight: normal;
      ">
        {{ section.settings.heading }}
      </h2>
    {% endif %}
    
    <div class="brand-logos" style="
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: {{ section.settings.logo_gap }}px;
      align-items: center;
      justify-items: center;
    ">
      {% for block in section.blocks %}
        {% if block.type == 'brand_logo' %}
          <a href="{{ block.settings.link }}" style="
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            background-color: {{ section.settings.card_bg }};
            border-radius: {{ section.settings.card_radius }}px;
            width: 100%;
            height: {{ section.settings.card_height }}px;
            transition: transform 0.3s;
            text-decoration: none;
          ">
            {% if block.settings.logo != blank %}
              <img src="{{ block.settings.logo | img_url: '300x' }}" 
                   alt="{{ block.settings.brand_name }}" 
                   style="max-width: 80%; max-height: 80%; object-fit: contain;">
            {% else %}
              <span style="font-size: 24px; font-weight: bold; color: #000;">
                {{ block.settings.brand_name }}
              </span>
            {% endif %}
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .brand-grid a:hover {
    transform: translateY(-5px);
  }
  
  @media (max-width: 768px) {
    .brand-logos {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
</style>

{% schema %}
{
  "name": "Brand Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Our most popular eyewear brands"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Size",
      "min": 24,
      "max": 56,
      "step": 2,
      "default": 36
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card Border Radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "default": 12
    },
    {
      "type": "range",
      "id": "card_height",
      "label": "Card Height",
      "min": 100,
      "max": 300,
      "step": 10,
      "default": 150
    },
    {
      "type": "range",
      "id": "logo_gap",
      "label": "Gap Between Logos",
      "min": 10,
      "max": 50,
      "step": 5,
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "brand_logo",
      "name": "Brand Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Brand Logo"
        },
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand Name",
          "default": "Brand Name",
          "info": "Used as alt text and fallback if no logo uploaded"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Brand Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Grid",
      "blocks": [
        {"type": "brand_logo"},
        {"type": "brand_logo"},
        {"type": "brand_logo"},
        {"type": "brand_logo"}
      ]
    }
  ]
}
{% endschema %}

