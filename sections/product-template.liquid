          "type": "checkbox",
          "id": "product_variant_color_image_enable",
          "label": "Show Image In-place Of Color",
          "default": true
        }
      ]
    },
    {
      "type": "product_sku",
      "name": "Product Sku",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "product_sku_title",
          "label": "SKU Title",
          "default": "SKU:"
        },
        {
          "type": "header",
          "content": "Social Option"
        },
        {
          "type": "checkbox",
          "id": "social_share_enable",
          "label": "Show Social Share",
          "default": true
        },
        {
          "type": "text",
          "id": "social_share_title",
          "label": "Social Share Title",
          "default": "Share:"
        }
      ]
    },
    {
      "type": "payment_img",
      "name": "Payment Image",
      "limit": 1
    }
  ]
