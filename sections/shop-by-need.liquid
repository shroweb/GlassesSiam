<section class="shop-need">
  <h2>{{ section.settings.heading }}</h2>

  <div class="shop-need__buttons">
    {% for block in section.blocks %}
      <a href="{{ block.settings.url }}" class="pill">
        {{ block.settings.label }}
      </a>
    {% endfor %}
  </div>
</section>

<style>
.shop-need {
  padding: 4rem 2rem;
  text-align: center;
}
.shop-need__buttons {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  justify-content: center;
}
.pill {
  padding: 12px 22px;
  border-radius: 999px;
  border: 1px solid #ccc;
  text-decoration: none;
}
</style>

{% schema %}
{
  "name": "Shop by need",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by what you need" }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Need",
      "settings": [
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "url", "id": "url", "label": "Link" }
      ]
    }
  ],
  "presets": [{ "name": "Shop by need" }]
}
{% endschema %}