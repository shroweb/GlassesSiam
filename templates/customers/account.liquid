<div class="acc-page">
  <div class="acc-page__inner">

    <!-- Sidebar -->
    <aside class="acc-sidebar">
      <div class="acc-sidebar__avatar">
        <div class="acc-avatar-circle">
          {{ customer.first_name | slice: 0 | upcase }}
        </div>
        <div>
          <p class="acc-sidebar__name">{{ customer.name }}</p>
          <p class="acc-sidebar__email">{{ customer.email }}</p>
        </div>
      </div>

      <nav class="acc-nav">
        <a href="/account" class="acc-nav__item is-active">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          Dashboard
        </a>
        <a href="/account/addresses" class="acc-nav__item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Addresses
          <span class="acc-nav__badge">{{ customer.addresses_count }}</span>
        </a>
        <a href="/pages/wishlist" class="acc-nav__item">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          Wishlist
          <span class="acc-nav__badge wishlist-counter"></span>
        </a>
        <a href="/account/logout" class="acc-nav__item acc-nav__item--logout">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          Log out
        </a>
      </nav>

      <!-- Default address card -->
      {% if customer.default_address %}
      <div class="acc-address-card">
        <p class="acc-address-card__label">Default address</p>
        <p class="acc-address-card__name">{{ customer.default_address.name }}</p>
        {% if customer.default_address.address1 != blank %}
          <p>{{ customer.default_address.address1 }}</p>
        {% endif %}
        {% if customer.default_address.address2 != blank %}
          <p>{{ customer.default_address.address2 }}</p>
        {% endif %}
        <p>
          {% if customer.default_address.city != blank %}{{ customer.default_address.city }}, {% endif %}
          {% if customer.default_address.province_code != blank %}{{ customer.default_address.province_code | upcase }} {% endif %}
          {% if customer.default_address.zip != blank %}{{ customer.default_address.zip }}{% endif %}
        </p>
        {% if customer.default_address.country != blank %}
          <p>{{ customer.default_address.country }}</p>
        {% endif %}
        <a href="/account/addresses" class="acc-address-card__edit">Edit address →</a>
      </div>
      {% endif %}
    </aside>

    <!-- Main -->
    <main class="acc-main">

      <!-- Welcome -->
      <div class="acc-main__header">
        <div>
          <p class="acc-main__greeting">Welcome back,</p>
          <h1 class="acc-main__name">{{ customer.first_name }}</h1>
        </div>
        <div class="acc-stats">
          <div class="acc-stat">
            <span class="acc-stat__val">{{ customer.orders_count }}</span>
            <span class="acc-stat__label">Orders</span>
          </div>
          <div class="acc-stat">
            <span class="acc-stat__val">{{ customer.total_spent | money_without_trailing_zeros }}</span>
            <span class="acc-stat__label">Total spent</span>
          </div>
        </div>
      </div>

      <!-- Order history -->
      <div class="acc-orders">
        <h2 class="acc-orders__title">Order history</h2>

        {% paginate customer.orders by 10 %}
        {% if customer.orders.size > 0 %}
          <div class="acc-orders__list">
            {% for order in customer.orders %}
              <div class="acc-order-card{% if order.cancelled %} acc-order-card--cancelled{% endif %}">
                <div class="acc-order-card__head">
                  <div>
                    <a href="{{ order.customer_url }}" class="acc-order-card__num">{{ order.name }}</a>
                    <p class="acc-order-card__date">{{ order.created_at | date: '%d %b %Y' }}</p>
                  </div>
                  <div class="acc-order-card__badges">
                    <span class="acc-badge acc-badge--{% if order.financial_status == 'paid' %}success{% elsif order.financial_status == 'pending' %}warning{% else %}danger{% endif %}">
                      {{ order.financial_status_label }}
                    </span>
                    <span class="acc-badge acc-badge--{% if order.fulfillment_status == 'fulfilled' %}success{% else %}neutral{% endif %}">
                      {{ order.fulfillment_status_label }}
                    </span>
                  </div>
                </div>

                {% if order.cancelled %}
                  <p class="acc-order-card__cancelled-msg">
                    Cancelled on {{ order.cancelled_at | date: '%d %b %Y' }}
                  </p>
                {% endif %}

                <!-- Line items preview -->
                <div class="acc-order-card__items">
                  {% for line_item in order.line_items limit: 3 %}
                    <div class="acc-order-item">
                      {% if line_item.image %}
                        <img src="{{ line_item.image | image_url: width: 120 }}" alt="{{ line_item.title | escape }}" width="60" height="44">
                      {% else %}
                        <div class="acc-order-item__no-img">
                          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                        </div>
                      {% endif %}
                      <div class="acc-order-item__info">
                        <p class="acc-order-item__name">{{ line_item.title }}</p>
                        {% if line_item.variant_title and line_item.variant_title != 'Default Title' %}
                          <p class="acc-order-item__variant">{{ line_item.variant_title }}</p>
                        {% endif %}
                        <p class="acc-order-item__qty">Qty: {{ line_item.quantity }}</p>
                      </div>
                    </div>
                  {% endfor %}
                  {% if order.line_items.size > 3 %}
                    <p class="acc-order-card__more">+{{ order.line_items.size | minus: 3 }} more item(s)</p>
                  {% endif %}
                </div>

                <div class="acc-order-card__foot">
                  <span class="acc-order-card__total">{{ order.total_price | money }}</span>
                  <a href="{{ order.customer_url }}" class="acc-order-card__view">View order →</a>
                </div>
              </div>
            {% endfor %}
          </div>

          {% if paginate.pages > 1 %}
            <div class="acc-pagination">
              {%- render 'pagination', paginate: paginate -%}
            </div>
          {% endif %}

        {% else %}
          <div class="acc-orders__empty">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#d1d5db" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <p>You haven't placed any orders yet.</p>
            <a href="/collections/all" class="acc-orders__shop-btn">Start shopping →</a>
          </div>
        {% endif %}
        {% endpaginate %}
      </div>
    </main>

  </div>
</div>

<style>
/* ── Account Page Layout ── */
.acc-page {
  background: #f8f9fb;
  min-height: 60vh;
  padding: 3rem 1.5rem 4rem;
}
.acc-page__inner {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 2rem;
  align-items: start;
}

/* ── Sidebar ── */
.acc-sidebar {
  background: #fff;
  border-radius: 1.25rem;
  border: 1px solid #e8ecf0;
  padding: 1.75rem;
  position: sticky;
  top: 2rem;
}
.acc-sidebar__avatar {
  display: flex;
  align-items: center;
  gap: 12px;
  padding-bottom: 1.25rem;
  border-bottom: 1px solid #f0f4f8;
  margin-bottom: 1.25rem;
}
.acc-avatar-circle {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: #113071;
  color: #fff;
  font-size: 20px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.acc-sidebar__name {
  font-size: 14px;
  font-weight: 700;
  color: #111827;
  line-height: 1.3;
}
.acc-sidebar__email {
  font-size: 12px;
  color: #9ca3af;
  word-break: break-all;
}

/* Nav */
.acc-nav {
  display: flex;
  flex-direction: column;
  gap: 2px;
  margin-bottom: 1.5rem;
}
.acc-nav__item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 500;
  color: #374151;
  text-decoration: none;
  transition: background 0.15s ease, color 0.15s ease;
}
.acc-nav__item:hover {
  background: #f0f4f8;
  color: #111827;
  text-decoration: none;
}
.acc-nav__item.is-active {
  background: #eef2fa;
  color: #113071;
  font-weight: 700;
}
.acc-nav__item--logout {
  margin-top: 8px;
  color: #ef4444;
  border-top: 1px solid #f0f4f8;
  padding-top: 14px;
}
.acc-nav__item--logout:hover {
  background: #fef2f2;
  color: #dc2626;
}
.acc-nav__badge {
  margin-left: auto;
  background: #e8ecf0;
  color: #374151;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 700;
  padding: 1px 7px;
  min-width: 20px;
  text-align: center;
}

/* Address card */
.acc-address-card {
  background: #f8f9fb;
  border: 1px solid #e8ecf0;
  border-radius: 10px;
  padding: 14px;
  font-size: 13px;
  color: #4b5563;
  line-height: 1.6;
}
.acc-address-card__label {
  font-size: 10.5px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #9ca3af;
  margin-bottom: 6px;
}
.acc-address-card__name {
  font-weight: 700;
  color: #111827;
}
.acc-address-card__edit {
  display: inline-block;
  margin-top: 10px;
  font-size: 12.5px;
  font-weight: 600;
  color: #113071;
  text-decoration: none;
}
.acc-address-card__edit:hover {
  text-decoration: underline;
}

/* ── Main ── */
.acc-main {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}
.acc-main__header {
  background: #113071;
  border-radius: 1.25rem;
  padding: 1.75rem 2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #fff;
}
.acc-main__greeting {
  font-size: 13px;
  opacity: 0.7;
  margin-bottom: 2px;
}
.acc-main__name {
  font-size: clamp(1.4rem, 2.5vw, 1.9rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: #fff;
  margin: 0;
}
.acc-stats {
  display: flex;
  gap: 2rem;
}
.acc-stat {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}
.acc-stat__val {
  font-size: 1.4rem;
  font-weight: 700;
  line-height: 1;
}
.acc-stat__label {
  font-size: 11.5px;
  opacity: 0.65;
  margin-top: 2px;
}

/* ── Orders ── */
.acc-orders {
  background: #fff;
  border-radius: 1.25rem;
  border: 1px solid #e8ecf0;
  padding: 1.75rem;
}
.acc-orders__title {
  font-size: 1.1rem;
  font-weight: 700;
  letter-spacing: -0.01em;
  color: #111827;
  margin-bottom: 1.25rem;
}
.acc-orders__list {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

/* Order card */
.acc-order-card {
  border: 1px solid #e8ecf0;
  border-radius: 12px;
  overflow: hidden;
  transition: box-shadow 0.2s ease;
}
.acc-order-card:hover {
  box-shadow: 0 4px 16px rgba(0,0,0,0.07);
}
.acc-order-card--cancelled {
  border-color: #fecaca;
  background: #fff9f9;
}

.acc-order-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 14px 16px 10px;
  border-bottom: 1px solid #f0f4f8;
  gap: 12px;
  flex-wrap: wrap;
}
.acc-order-card__num {
  font-size: 14.5px;
  font-weight: 700;
  color: #113071;
  text-decoration: none;
}
.acc-order-card__num:hover { text-decoration: underline; }
.acc-order-card__date {
  font-size: 12px;
  color: #9ca3af;
  margin-top: 2px;
}
.acc-order-card__badges {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.acc-badge {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 999px;
  letter-spacing: 0.04em;
}
.acc-badge--success { background: #d1fae5; color: #065f46; }
.acc-badge--warning { background: #fef3c7; color: #92400e; }
.acc-badge--danger  { background: #fee2e2; color: #991b1b; }
.acc-badge--neutral { background: #e8ecf0; color: #374151; }

.acc-order-card__cancelled-msg {
  font-size: 13px;
  color: #ef4444;
  padding: 8px 16px 0;
  font-weight: 600;
}

/* Items */
.acc-order-card__items {
  padding: 12px 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.acc-order-item {
  display: flex;
  gap: 10px;
  align-items: center;
}
.acc-order-item img {
  width: 60px;
  height: 44px;
  object-fit: contain;
  border-radius: 6px;
  background: #f8f9fb;
  border: 1px solid #e8ecf0;
  flex-shrink: 0;
}
.acc-order-item__no-img {
  width: 60px;
  height: 44px;
  background: #f8f9fb;
  border: 1px solid #e8ecf0;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.acc-order-item__name {
  font-size: 13.5px;
  font-weight: 600;
  color: #111827;
  line-height: 1.3;
}
.acc-order-item__variant {
  font-size: 12px;
  color: #9ca3af;
}
.acc-order-item__qty {
  font-size: 12px;
  color: #6b7280;
}
.acc-order-card__more {
  font-size: 12.5px;
  color: #9ca3af;
  padding-left: 70px;
}

/* Footer */
.acc-order-card__foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 16px 14px;
  border-top: 1px solid #f0f4f8;
}
.acc-order-card__total {
  font-size: 15px;
  font-weight: 700;
  color: #111827;
}
.acc-order-card__view {
  font-size: 13px;
  font-weight: 700;
  color: #113071;
  text-decoration: none;
}
.acc-order-card__view:hover { text-decoration: underline; }

/* Empty */
.acc-orders__empty {
  text-align: center;
  padding: 3rem 1rem;
  color: #9ca3af;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
}
.acc-orders__empty p {
  font-size: 15px;
  color: #6b7280;
}
.acc-orders__shop-btn {
  display: inline-flex;
  align-items: center;
  background: #113071;
  color: #fff;
  text-decoration: none;
  font-size: 14px;
  font-weight: 700;
  padding: 12px 24px;
  border-radius: 8px;
  letter-spacing: 0.04em;
  transition: background 0.2s ease;
}
.acc-orders__shop-btn:hover {
  background: #0d2458;
  color: #fff;
  text-decoration: none;
}

.acc-pagination { margin-top: 1.5rem; }

/* ── Responsive ── */
@media (max-width: 860px) {
  .acc-page__inner {
    grid-template-columns: 1fr;
  }
  .acc-sidebar {
    position: static;
  }
  .acc-main__header {
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }
  .acc-stats {
    gap: 1.5rem;
  }
  .acc-stat {
    align-items: flex-start;
  }
}
@media (max-width: 480px) {
  .acc-page {
    padding: 1.5rem 1rem 3rem;
  }
  .acc-order-card__head {
    flex-direction: column;
  }
}
</style>
