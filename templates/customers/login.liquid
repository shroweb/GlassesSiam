{% assign recover_success = false %}
<section class="customer-page section-ptb">
  <div class="container">
    <div class="row">
      <div class="col">
        <div class="acc-form">
          <div class="log-acc-page" id="CustomerLoginForm">
            <div class="acc-page">
              <div class="login">
                {% form 'customer_login' %}
                <div class="login-form-container">
                  <div class="section-capture">
                    <div class="section-title">
                      <h2>{{ 'customer.login.title' | t }}</h2>
                    </div>
                  </div>
                  {{ form.errors | default_errors }}
                  <ul class="fill-form">
                    <li class="log-email">
                      <label for="Email">{{ 'customer.login.email' | t }}</label>
                      <input type="email" name="customer[email]" id="CustomerEmail" class="input-full{% if form.errors contains 'email' %} error{% endif %}" placeholder="{{ 'customer.login.email' | t }}" autocorrect="off" autocapitalize="off" autofocus required>
                    </li>

                    {% if form.password_needed %}
                    <li class="log-pwd">
                      <label>{{ 'customer.login.password' | t }}</label>
                      <input type="password" value="" name="customer[password]" id="CustomerPassword" class="input-full{% if form.errors contains 'password' %} error{% endif %}" placeholder="{{ 'customer.login.password' | t }}" required>
                    </li>
                    {% endif %}
                  </ul>
                  <div class="form-action-button">
                    <button class="btn btn-style" type="submit">{{ 'customer.login.sign_in' | t }}</button>
                    {% if form.password_needed %}
                    <a href="#recover" id="RecoverPassword">{{ 'customer.login.forgot_password' | t }}</a>
                    {% endif %}
                  </div>
                </div>
                {% endform %}
              </div>
              <div class="acc-wrapper">
                <h6>{{ settings.dnt_acc_title }}</h6>
                <div class="account-optional-action">
                  {{ 'layout.customer.create_account' | t | customer_register_link }}
                </div>
              </div>
            </div>
          </div>
          <div class="log-acc-page" id="RecoverPasswordForm" style="display: none;">
            <div class="acc-page">
              <div class="login">
              {% form 'recover_customer_password' %}
              {% if form.posted_successfully? %}
                {% assign recover_success = true %}
              {% endif %}
              <div class="login-form-container">
                <div class="section-capture">
                  <div class="section-title">
                  <h2>{{ 'customer.recover_password.title' | t }}</h2>
                  <p>{% if form.posted_successfully? %}If an account exists for this email address, we've sent a password reset link.{% else %}{{ 'customer.recover_password.subtext' | t }}{% endif %}</p>
                </div>
                </div>
                <div id="ResetSuccess" class="form-state-banner form-state-banner--success"{% unless form.posted_successfully? %} style="display: none;"{% endunless %}>
                  <strong>Check your email</strong>
                  <p>We've sent a reset link if the email address is in our customer records. Open the email, follow the link, and then come back here to sign in.</p>
                  <button class="btn btn-style form-state-banner__action" type="button" id="ResetSuccessBack">Back to sign in</button>
                </div>
                <div id="RecoverPasswordFields"{% if form.posted_successfully? %} style="display: none;"{% endif %}>
                {{ form.errors | default_errors }}
                <ul class="fill-form">
                  <li class="log-email">
                    <label for="Email">{{ 'customer.login.email' | t }}</label>
                    <input type="email" value="" name="email" id="RecoverEmail" class="input-full" placeholder="{{ 'customer.recover_password.email' | t }}" autocorrect="off" autocapitalize="off" required>
                  </li>
                  <li class="form-toggle-btn">
                    <div class="form-action-button">
                      <button class="btn btn-style" type="submit">{{ 'customer.recover_password.submit' | t }}</button>
                      <a href="#" id="HideRecoverPasswordLink">{{ 'customer.recover_password.cancel' | t }}</a>
                    </div>
                  </li>
                </ul>
                </div>
              </div>
              {% endform %}
            </div>
            </div>
          </div>
        </div>
        {% if shop.checkout.guest_login %}
        <div class="log-acc-page" id="guest-login">
          <div class="login-form-container">
            <div class="section-capture">
              <div class="section-title">
              <h2>{{ 'customer.login.guest_title' | t }}</h2>
              {% form 'guest_login' %}
              <input type="submit" value="{{ 'customer.login.guest_continue' | t }}">
              {% endform %}
            </div>
            </div>
          </div>
        </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    var customerLoginForm = document.getElementById('CustomerLoginForm');
    var recoverForm = document.getElementById('RecoverPasswordForm');
    var resetSuccess = document.getElementById('ResetSuccess');
    var recoverFields = document.getElementById('RecoverPasswordFields');
    var successBackBtn = document.getElementById('ResetSuccessBack');
    var recoverFormElement = recoverForm ? recoverForm.querySelector('form') : null;
    var recoverSuccess = {{ recover_success | json }};
    var recoverSubmitted = false;

    try {
      recoverSubmitted = window.sessionStorage.getItem('customerRecoverSubmitted') === 'true';
    } catch (error) {
      recoverSubmitted = false;
    }

    function showRecoverView(showSuccessState) {
      if (!customerLoginForm || !recoverForm) {
        return;
      }

      customerLoginForm.style.display = 'none';
      recoverForm.style.display = '';

      if (showSuccessState && resetSuccess) {
        resetSuccess.style.display = '';
      }

      if (recoverFields) {
        recoverFields.style.display = showSuccessState ? 'none' : '';
      }
    }

    if (recoverFormElement) {
      recoverFormElement.addEventListener('submit', function() {
        try {
          window.sessionStorage.setItem('customerRecoverSubmitted', 'true');
        } catch (error) {}
      });
    }

    if (customerLoginForm && recoverForm && (window.location.hash === '#recover' || recoverSuccess || recoverSubmitted)) {
      showRecoverView(recoverSuccess || recoverSubmitted);
    }

    if ((recoverSuccess || recoverSubmitted) && resetSuccess) {
      try {
        window.sessionStorage.removeItem('customerRecoverSubmitted');
      } catch (error) {}
    }

    if (successBackBtn && customerLoginForm && recoverForm) {
      successBackBtn.addEventListener('click', function() {
        recoverForm.style.display = 'none';
        customerLoginForm.style.display = '';
        if (resetSuccess) {
          resetSuccess.style.display = 'none';
        }
        if (recoverFields) {
          recoverFields.style.display = '';
        }
        window.location.hash = '';
      });
    }
  });
</script>
<style>
  .customer-page .log-acc-page{
    width: 50%;
    margin: 0 auto;
  }
  .customer-page .log-acc-page .acc-page{
    width: 100%;
    height: 100%;
    padding: 60px;
    background-color: var(--extra-color-body);
    display: flex!important;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border-radius: var(--sti-border-radius);
  }
  .customer-page .log-acc-page .acc-page .login{
    width: 100%;
  }
  @media(max-width: 1199px){
    .customer-page .log-acc-page .acc-page{
      padding: 30px;
    }
  }
  @media(max-width: 991px){
    .customer-page .log-acc-page{
      width: 100%;
    }
  }
  @media(max-width: 767px){
    .customer-page .log-acc-page{
      margin-top: 30px;
    }
  }
  /* form css */
  .customer-page .log-acc-page .login-form-container p{
    margin-top: 15px;
  }
  .customer-page .log-acc-page .login-form-container .form-state-banner{
    margin-top: 18px;
    padding: 16px 18px;
    border-radius: 16px;
    border: 1px solid #dbe7ff;
    background: linear-gradient(180deg, #f7fbff 0%, #eef5ff 100%);
  }
  .customer-page .log-acc-page .login-form-container .form-state-banner strong{
    display: block;
    font-size: 16px;
    font-weight: 700;
    color: #113071;
  }
  .customer-page .log-acc-page .login-form-container .form-state-banner p{
    margin: 8px 0 0;
    color: #475569;
    line-height: 1.6;
  }
  .customer-page .log-acc-page .login-form-container .form-state-banner__action{
    margin-top: 14px;
  }
  .customer-page .log-acc-page .login-form-container ul.fill-form li{
    margin-top: 28px;
  }
  .customer-page .log-acc-page .login-form-container ul.fill-form li:first-child{
    margin-top: 0px;
  }
  .customer-page .log-acc-page .login-form-container ul.fill-form li label{
    display: block;
    margin-bottom: 14px;
    cursor: auto;
    line-height: 1;
    font-size: 16px;
    color: var(--font-color-body);
    font-weight: var(--sti-font-weight);
  }
  .customer-page .log-acc-page .login-form-container input{
    width: 100%;
    background-color: #ffffff;
  }
  .customer-page .log-acc-page .login-form-container .form-action-button{
    margin-top: 50px;
    text-align: center;
  }
  .customer-page .log-acc-page .login-form-container .form-action-button a{
    display: block;
    color: #999;
    margin-top: 18px;
    text-decoration: underline;
    line-height: 1;
  }
  .customer-page .log-acc-page .login-form-container .form-action-button a:hover{
    color: var(--font-color-primary);
  }
  .customer-page .log-acc-page .acc-wrapper{
    margin-top: 25px;
    text-align: center;
  }
  .customer-page .log-acc-page .acc-wrapper h6{
    font-size: 18px;
    font-weight: var(--font-custom-weight-section-header);
  }
  .customer-page .log-acc-page .acc-wrapper .account-optional-action{
    margin-top: 11px;
  }
  @media (max-width: 1199px){
    .customer-page .log-acc-page .login-form-container .form-action-button{
      margin-top: 40px;
    }
  }
  @media (max-width: 767px){
    .customer-page .log-acc-page .login-form-container .form-action-button{
      margin-top: 20px;
    }
  }

  /* acc-link css */
  .customer-page .log-acc-page .acc-wrapper{
    margin-top: 25px;
    text-align: center;
  }
  .customer-page .log-acc-page .acc-wrapper h6{
    font-size: 18px;
  }
  .customer-page .log-acc-page .acc-wrapper .account-optional-action{
    margin-top: 11px;
  }
  .customer-page .log-acc-page .acc-wrapper .account-optional-action a{
    color: var(--font-color-primary);
    text-decoration: underline;
  }

  /* error css */
  .customer-page .log-acc-page .errors{
    padding: 10px 15px;
    {% if settings.enable_rtl %}
    text-align: right;
    {% else %}
    text-align: left;
    {% endif %}
  }
  .customer-page .log-acc-page .errors ul{
    {% if settings.enable_rtl %}
    margin-right: 15px;
    margin-left: 0;
    {% else %}
    margin-left: 15px;
    {% endif %}
    list-style: square;
  }
  .customer-page .log-acc-page .errors ul li{
    margin-top: 5px;
  }
  .customer-page .log-acc-page .errors ul li:first-child{
    margin-top: 0px;
  }
</style>
