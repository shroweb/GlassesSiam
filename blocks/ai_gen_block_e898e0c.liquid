{% doc %}
  @prompt
    reviews
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-reviews-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-reviews-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-reviews-header-{{ ai_gen_id }} {
    margin-bottom: 30px;
  }

  .ai-reviews-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 10px;
    font-weight: 600;
  }

  .ai-reviews-summary-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-bottom: 20px;
  }

  .ai-reviews-rating-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-reviews-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
  }

  .ai-reviews-star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-reviews-star-empty-{{ ai_gen_id }} {
    fill: {{ block.settings.star_empty_color }};
  }

  .ai-reviews-average-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
  }

  .ai-reviews-count-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
  }

  .ai-reviews-list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  .ai-review-item-{{ ai_gen_id }} {
    padding: 25px;
    background-color: {{ block.settings.review_bg_color }};
    border-radius: {{ block.settings.border_radius }}px;
    border: 1px solid {{ block.settings.border_color }};
  }

  .ai-review-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 12px;
    gap: 15px;
  }

  .ai-review-author-section-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-review-author-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 5px;
  }

  .ai-review-date-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
  }

  .ai-review-rating-{{ ai_gen_id }} {
    display: flex;
    gap: 3px;
  }

  .ai-review-star-{{ ai_gen_id }} {
    width: {{ block.settings.review_star_size }}px;
    height: {{ block.settings.review_star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-review-content-{{ ai_gen_id }} {
    font-size: 15px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-reviews-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
  }

  .ai-reviews-empty-icon-{{ ai_gen_id }} {
    width: 60px;
    height: 60px;
    margin: 0 auto 15px;
    opacity: 0.3;
  }

  .ai-reviews-empty-text-{{ ai_gen_id }} {
    font-size: 16px;
  }

  .ai-reviews-write-btn-{{ ai_gen_id }} {
    display: inline-block;
    margin-top: 20px;
    padding: 12px 30px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-reviews-write-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-reviews-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-reviews-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-review-header-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 10px;
    }

    .ai-review-item-{{ ai_gen_id }} {
      padding: 20px;
    }
  }
{% endstyle %}

<product-reviews-{{ ai_gen_id }} class="ai-reviews-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-reviews-container-{{ ai_gen_id }}">
    <div class="ai-reviews-header-{{ ai_gen_id }}">
      {% if block.settings.show_title %}
        <h2 class="ai-reviews-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}

      {% if block.settings.show_summary %}
        <div class="ai-reviews-summary-{{ ai_gen_id }}">
          <div class="ai-reviews-rating-{{ ai_gen_id }}">
            <div class="ai-reviews-stars-{{ ai_gen_id }}">
              {% for i in (1..5) %}
                <svg class="ai-reviews-star-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              {% endfor %}
            </div>
            <span class="ai-reviews-average-{{ ai_gen_id }}">{{ block.settings.average_rating }}</span>
          </div>
          <span class="ai-reviews-count-{{ ai_gen_id }}">({{ block.settings.review_count }} reviews)</span>
        </div>
      {% endif %}
    </div>

    {% if block.settings.review_count > 0 %}
      <div class="ai-reviews-list-{{ ai_gen_id }}">
        {% for i in (1..block.settings.reviews_to_show) %}
          {% liquid
            assign review_author_key = 'review_' | append: i | append: '_author'
            assign review_rating_key = 'review_' | append: i | append: '_rating'
            assign review_date_key = 'review_' | append: i | append: '_date'
            assign review_content_key = 'review_' | append: i | append: '_content'

            assign review_author = block.settings[review_author_key]
            assign review_rating = block.settings[review_rating_key]
            assign review_date = block.settings[review_date_key]
            assign review_content = block.settings[review_content_key]
          %}

          {% if review_author != blank %}
            <div class="ai-review-item-{{ ai_gen_id }}">
              <div class="ai-review-header-{{ ai_gen_id }}">
                <div class="ai-review-author-section-{{ ai_gen_id }}">
                  <h3 class="ai-review-author-{{ ai_gen_id }}">{{ review_author }}</h3>
                  {% if review_date != blank %}
                    <div class="ai-review-date-{{ ai_gen_id }}">{{ review_date }}</div>
                  {% endif %}
                </div>
                <div class="ai-review-rating-{{ ai_gen_id }}">
                  {% for star in (1..5) %}
                    <svg 
                      class="ai-review-star-{{ ai_gen_id }} {% if star > review_rating %}ai-reviews-star-empty-{{ ai_gen_id }}{% endif %}" 
                      viewBox="0 0 24 24" 
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  {% endfor %}
                </div>
              </div>
              {% if review_content != blank %}
                <p class="ai-review-content-{{ ai_gen_id }}">{{ review_content }}</p>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="ai-reviews-empty-{{ ai_gen_id }}">
        <svg class="ai-reviews-empty-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <div class="ai-reviews-empty-text-{{ ai_gen_id }}">{{ block.settings.empty_message }}</div>
        {% if block.settings.show_write_button %}
          <a href="{{ block.settings.write_review_url }}" class="ai-reviews-write-btn-{{ ai_gen_id }}">
            {{ block.settings.write_button_text }}
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>
</product-reviews-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductReviews{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.init();
      }

      init() {
        const reviewItems = this.querySelectorAll('.ai-review-item-{{ ai_gen_id }}');
        reviewItems.forEach((item, index) => {
          item.style.animationDelay = `${index * 0.1}s`;
        });
      }
    }

    customElements.define('product-reviews-{{ ai_gen_id }}', ProductReviews{{ ai_gen_id }});
  })();
</script>

