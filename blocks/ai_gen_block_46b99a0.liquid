            {{ block.settings.color_label }}
            <svg class="ai-eyewear-filter__icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="ai-eyewear-filter__dropdown-{{ ai_gen_id }}">
