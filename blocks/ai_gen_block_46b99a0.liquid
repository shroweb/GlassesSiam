          <div class="ai-eyewear-filter__dropdown-{{ ai_gen_id }}">
            <div class="ai-eyewear-filter__dropdown-content-{{ ai_gen_id }}">
              {% assign glasses_types = block.settings.glasses_type_options | split: ',' %}
              {% for type in glasses_types %}
                {% assign type_trimmed = type | strip %}
                <div class="ai-eyewear-filter__option-{{ ai_gen_id }}" data-value="{{ type_trimmed | handleize }}">
                  <div class="ai-eyewear-filter__checkbox-{{ ai_gen_id }}"></div>
