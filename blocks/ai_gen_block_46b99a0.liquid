      {% if block.settings.show_features %}
        <div class="ai-eyewear-filter__item-{{ ai_gen_id }}" data-filter="features">
          <button class="ai-eyewear-filter__button-{{ ai_gen_id }}" aria-expanded="false">
            {{ block.settings.features_label }}
            <svg class="ai-eyewear-filter__icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="ai-eyewear-filter__dropdown-{{ ai_gen_id }}">
            <div class="ai-eyewear-filter__dropdown-content-{{ ai_gen_id }}">
              {% assign features = block.settings.features_options | split: ',' %}
              {% for feature in features %}
                {% assign feature_trimmed = feature | strip %}
                <div class="ai-eyewear-filter__option-{{ ai_gen_id }}" data-value="{{ feature_trimmed | handleize }}">
                  <div class="ai-eyewear-filter__checkbox-{{ ai_gen_id }}"></div>
                  <span class="ai-eyewear-filter__option-label-{{ ai_gen_id }}">{{ feature_trimmed }}</span>
