</eyewear-filter-{{ ai_gen_id }}>

<script>
  (function() {
    class EyewearFilter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.activeFilters = {};
        this.collectionUrl = this.dataset.collectionUrl || window.location.pathname;
      }

      connectedCallback() {
        this.filterItems = this.querySelectorAll('.ai-eyewear-filter__item-{{ ai_gen_id }}');
        this.clearButton = this.querySelector('.ai-eyewear-filter__clear-{{ ai_gen_id }}');
        this.activeFiltersContainer = this.querySelector('.ai-eyewear-filter__active-filters-{{ ai_gen_id }}');
        
        this.setupEventListeners();
        this.parseUrlFilters();
      }

      setupEventListeners() {
        this.filterItems.forEach(item => {
          const button = item.querySelector('.ai-eyewear-filter__button-{{ ai_gen_id }}');
          const dropdown = item.querySelector('.ai-eyewear-filter__dropdown-{{ ai_gen_id }}');
          const options = item.querySelectorAll('.ai-eyewear-filter__option-{{ ai_gen_id }}');

          button.addEventListener('click', (e) => {
            e.stopPropagation();
            this.toggleDropdown(item);
          });

          options.forEach(option => {
            option.addEventListener('click', (e) => {
              e.stopPropagation();
              this.toggleOption(item, option);
            });
          });
        });

        document.addEventListener('click', () => {
          this.closeAllDropdowns();
        });

        if (this.clearButton) {
          this.clearButton.addEventListener('click', () => {
            this.clearAllFilters();
          });
        }
      }

      toggleDropdown(item) {
        const button = item.querySelector('.ai-eyewear-filter__button-{{ ai_gen_id }}');
        const dropdown = item.querySelector('.ai-eyewear-filter__dropdown-{{ ai_gen_id }}');
        const isActive = dropdown.classList.contains('active');

        this.closeAllDropdowns();

        if (!isActive) {
          dropdown.classList.add('active');
          button.classList.add('active');
          button.setAttribute('aria-expanded', 'true');
        }
      }

      closeAllDropdowns() {
        this.filterItems.forEach(item => {
          const button = item.querySelector('.ai-eyewear-filter__button-{{ ai_gen_id }}');
          const dropdown = item.querySelector('.ai-eyewear-filter__dropdown-{{ ai_gen_id }}');
          dropdown.classList.remove('active');
          button.classList.remove('active');
          button.setAttribute('aria-expanded', 'false');
        });
      }

      toggleOption(item, option) {
        const checkbox = option.querySelector('.ai-eyewear-filter__checkbox-{{ ai_gen_id }}');
        const filterType = item.dataset.filter;
        const value = option.dataset.value;

        if (!this.activeFilters[filterType]) {
          this.activeFilters[filterType] = [];
        }

        const index = this.activeFilters[filterType].indexOf(value);
        
        if (index > -1) {
          this.activeFilters[filterType].splice(index, 1);
          checkbox.classList.remove('checked');
          if (this.activeFilters[filterType].length === 0) {
            delete this.activeFilters[filterType];
          }
        } else {
          this.activeFilters[filterType].push(value);
          checkbox.classList.add('checked');
        }

        this.updateActiveFiltersDisplay();
        this.applyFilters();
      }

      updateActiveFiltersDisplay() {
        this.activeFiltersContainer.innerHTML = '';
        
        let hasFilters = false;
        for (const filterType in this.activeFilters) {
          this.activeFilters[filterType].forEach(value => {
            hasFilters = true;
            const tag = document.createElement('div');
            tag.className = 'ai-eyewear-filter__active-tag-{{ ai_gen_id }}';
            tag.innerHTML = `
              ${value.replace(/-/g, ' ')}
              <svg class="ai-eyewear-filter__active-tag-close-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            `;
            
            tag.querySelector('.ai-eyewear-filter__active-tag-close-{{ ai_gen_id }}').addEventListener('click', () => {
              this.removeFilter(filterType, value);
            });
            
            this.activeFiltersContainer.appendChild(tag);
          });
        }

        if (this.clearButton) {
          this.clearButton.style.display = hasFilters ? 'inline-flex' : 'none';
        }
      }

      removeFilter(filterType, value) {
        const index = this.activeFilters[filterType].indexOf(value);
        if (index > -1) {
          this.activeFilters[filterType].splice(index, 1);
          if (this.activeFilters[filterType].length === 0) {
            delete this.activeFilters[filterType];
          }
        }

        this.filterItems.forEach(item => {
          if (item.dataset.filter === filterType) {
            const option = item.querySelector(`[data-value="${value}"]`);
            if (option) {
              const checkbox = option.querySelector('.ai-eyewear-filter__checkbox-{{ ai_gen_id }}');
              checkbox.classList.remove('checked');
            }
          }
        });

        this.updateActiveFiltersDisplay();
        this.applyFilters();
      }

      clearAllFilters() {
        this.activeFilters = {};
        
        this.filterItems.forEach(item => {
          const checkboxes = item.querySelectorAll('.ai-eyewear-filter__checkbox-{{ ai_gen_id }}');
          checkboxes.forEach(checkbox => checkbox.classList.remove('checked'));
        });

        this.updateActiveFiltersDisplay();
        this.applyFilters();
      }

      applyFilters() {
        const params = new URLSearchParams();
        
        for (const filterType in this.activeFilters) {
          if (this.activeFilters[filterType].length > 0) {
            params.append(`filter.p.m.custom.${filterType}`, this.activeFilters[filterType].join(','));
          }
        }

        const url = params.toString() ? `${this.collectionUrl}?${params.toString()}` : this.collectionUrl;
        
        fetch(url)
          .then(response => response.text())
          .then(html => {
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const newProducts = doc.querySelector('[data-collection-products]');
            const currentProducts = document.querySelector('[data-collection-products]');
            
            if (newProducts && currentProducts) {
              currentProducts.innerHTML = newProducts.innerHTML;
            }

            window.history.pushState({}, '', url);
          })
          .catch(error => {
            console.error('Filter error:', error);
          });
      }

      parseUrlFilters() {
        const params = new URLSearchParams(window.location.search);
        
        params.forEach((value, key) => {
          if (key.startsWith('filter.p.m.custom.')) {
            const filterType = key.replace('filter.p.m.custom.', '');
            const values = value.split(',');
            this.activeFilters[filterType] = values;

            this.filterItems.forEach(item => {
              if (item.dataset.filter === filterType) {
                values.forEach(val => {
                  const option = item.querySelector(`[data-value="${val}"]`);
                  if (option) {
                    const checkbox = option.querySelector('.ai-eyewear-filter__checkbox-{{ ai_gen_id }}');
                    checkbox.classList.add('checked');
                  }
                });
              }
            });
          }
        });

        this.updateActiveFiltersDisplay();
      }
    }

    customElements.define('eyewear-filter-{{ ai_gen_id }}', EyewearFilter{{ ai_gen_id }});
  })();
</script>

