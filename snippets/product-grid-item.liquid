{%- liquid 
  assign variant = product.selected_or_first_available_variant
  assign card_context = card_context | default: 'grid'
  if product.available
  assign func = "Shopify.addItem(" | append: variant.id | append: ", 1)"
  endif
-%}
{%- liquid assign color_label = 'Color,color,colour,couleur,cor,colore,farbe,색,色,カラー,färg,farve,szín,barva' | split: ',' -%}
{%- liquid
  assign has_try_on = false
  if product.metafields.custom.glasson_id != blank or product.tags contains 'live-try-on' or product.tags contains 'virtual-try-on'
    assign has_try_on = true
  endif

  assign has_360 = false
  for media in product.media
    if media.media_type == 'model' or media.media_type == 'video' or media.media_type == 'external_video'
      assign has_360 = true
      break
    endif
  endfor

  assign color_count = 0
  for option in product.options_with_values
    assign option_name_downcase = option.name | downcase
    if color_label contains option_name_downcase
      assign color_count = option.values.size
      break
    endif
  endfor

  assign product_text = product.title | append: ' ' | append: product.type | append: ' ' | append: product.tags | join: ' ' | downcase
  assign eyewear_category = 'Eyeglasses'
  if product_text contains 'sunglass' or product_text contains '/s' or product_text contains 'sun '
    assign eyewear_category = 'Sunglasses'
  endif

  assign material_value = product.metafields.custom.material.value | default: product.metafields.custom.material
  assign shape_value = product.metafields.custom.shape.value | default: product.metafields.custom.shape
  assign gender_value = product.metafields.custom.gender.value | default: product.metafields.custom.gender
  assign frame_type_value = product.metafields.custom.frame_type.value | default: product.metafields.custom.frame_type
  assign size_value = product.metafields.custom.size.value | default: product.metafields.custom.size
  assign lens_feature_value = product.metafields.custom.lens_feature.value | default: product.metafields.custom.lens_feature
  assign progressive_bifocal_value = product.metafields.custom.progressive_bifocal.value | default: product.metafields.custom.progressive_bifocal
  assign spring_hinges_value = product.metafields.custom.spring_hinges.value | default: product.metafields.custom.spring_hinges
  assign face_shape_value = product.metafields.custom.face_shape_recommendation.value | default: product.metafields.custom.face_shape_recommendation
  assign temple_length_value = product.metafields.custom.temple_length.value | default: product.metafields.custom.temple_length
  assign bridge_width_value = product.metafields.custom.bridge_width.value | default: product.metafields.custom.bridge_width
  assign lens_width_value = product.metafields.custom.lens_width.value | default: product.metafields.custom.lens_width
  assign lens_height_value = product.metafields.custom.lens_height.value | default: product.metafields.custom.lens_height
  assign color_values = ''
  for option in product.options_with_values
    assign option_name_downcase = option.name | downcase
    if color_label contains option_name_downcase
      assign color_values = option.values | join: '|'
      break
    endif
  endfor
  if color_values == blank
    assign color_values = product.metafields.custom.color.value | default: product.metafields.custom.color
  endif
-%}
<div
  class="single-product-wrap product-card-eyewear{% unless product.available %} stock-out{% endunless %}{% if card_context == 'rail' %} is-rail{% endif %}"
  data-product-handle="{{ product.handle }}"
  data-product-url="{{ product.url }}"
  data-product-title="{{ product.title | escape }}"
  data-product-vendor="{{ product.vendor | escape }}"
  data-filter-vendor="{{ product.vendor | escape }}"
  data-filter-category="{{ eyewear_category | escape }}"
  data-filter-availability="{% if product.available %}In stock{% else %}Out of stock{% endif %}"
  data-filter-material="{{ material_value | escape }}"
  data-filter-shape="{{ shape_value | escape }}"
  data-filter-gender="{{ gender_value | escape }}"
  data-filter-color="{{ color_values | escape }}"
  data-filter-size="{{ size_value | escape }}"
  data-filter-frame-type="{{ frame_type_value | escape }}"
  data-filter-lens-feature="{{ lens_feature_value | escape }}"
  data-filter-progressive-bifocal="{{ progressive_bifocal_value | escape }}"
  data-filter-spring-hinges="{{ spring_hinges_value | escape }}"
  data-filter-face-shape="{{ face_shape_value | escape }}"
  data-filter-temple-length="{{ temple_length_value | escape }}"
  data-filter-bridge-width="{{ bridge_width_value | escape }}"
  data-filter-lens-width="{{ lens_width_value | escape }}"
  data-filter-lens-height="{{ lens_height_value | escape }}"
>
  <div class="product-image{% unless product.available %} stock-out{% endunless %}">
    <div class="product-card-topline">
      {% if has_try_on %}
      <span class="product-card-badge">Live try-on</span>
      {% endif %}
    </div>
    <a class="pro-img" href="{{ product.url | within: collection }}">
      <img class="img-fluid img1" src="{{ product.featured_image.src | image_url: width: 760 }}" width="{{ product.featured_image.width }}" height="{{ product.featured_image.height }}" alt="{{ product.featured_image.alt }}" loading="lazy">
    </a>
    <div class="product-card-hover-actions">
      {% if has_try_on %}
      <a class="product-card-hover-actions__button is-primary" href="{{ product.url | within: collection }}#live-try-on">Live view</a>
      {% endif %}
      {% if has_360 %}
      <a class="product-card-hover-actions__button" href="{{ product.url | within: collection }}#product-gallery">360 view</a>
      {% endif %}
    </div>
    <div class="product-label">
      {%- render 'product-label' -%}
    </div>
    {% if color_count > 0 %}
    <div class="product-card-colors-count">{{ color_count }} colors</div>
    {% endif %}
  </div>
  <div class="product-content">
    {% if card_context == 'rail' %}
      <h6 class="product-card-rail-title">
        <a href="{{ product.url | within: collection }}" title="{{ product.title }}">{{ product.title }}</a>
      </h6>
      <div class="price-box">
        {% if product.compare_at_price_max > product.price %}
        <span class="old-price">{{ product.compare_at_price | money }}</span>
        {% endif %}
        <span class="new-price">{{ product.price | money }}</span>
        <span class="product-price-note">Including lenses</span>
      </div>
    {% else %}
      <div class="product-card-meta">
        {% if product.vendor != blank %}
        <p class="product-card-vendor">{{ product.vendor }}</p>
        {% endif %}
        {% if settings.show_product_type %}
        <div class="product-type">
          <span>{{ eyewear_category }}</span>
        </div>
        {% endif %}
      </div>
      <div class="title-price">
        <div class="title-type">
          <h6>
            <a href="{{ product.url | within: collection }}" title="{{ product.title }}">{{ product.title }}</a>
          </h6>
        </div>
        <div class="price-box">
          {% if product.compare_at_price_max > product.price %}
          <span class="old-price">{{ product.compare_at_price | money }}</span>
          {% endif %}
          <span class="new-price">{{ product.price | money }}</span>
          <span class="product-price-note">Including lenses</span>
        </div>
      </div>
      {% if product.available %}
      <p class="product-delivery-chip">Next-day delivery</p>
      {% endif %}
    {% endif %}
  </div>
</div>
