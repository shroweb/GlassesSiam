<script>
(function () {
  'use strict';

  /* ─── Shape metadata + classification ─── */
  var SHAPES = {
    oval: {
      label: 'Oval',
      desc: 'Your balanced proportions suit almost every frame style. Bold rectangulars, classics, and cat-eyes all look great on you.',
      svg: '<svg viewBox="0 0 80 100" fill="none" xmlns="http://www.w3.org/2000/svg"><ellipse cx="40" cy="50" rx="30" ry="44" stroke="currentColor" stroke-width="4.5"/></svg>'
    },
    round: {
      label: 'Round',
      desc: 'Angular and rectangular frames add definition and beautifully lengthen your face.',
      svg: '<svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="50" cy="50" r="40" stroke="currentColor" stroke-width="4.5"/></svg>'
    },
    square: {
      label: 'Square',
      desc: 'Round and oval frames soften your strong jawline for a striking, balanced look.',
      svg: '<svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="12" y="8" width="76" height="84" rx="10" stroke="currentColor" stroke-width="4.5"/></svg>'
    },
    heart: {
      label: 'Heart',
      desc: 'Bottom-heavy frames and rimless styles beautifully balance your wider forehead with your refined chin.',
      svg: '<svg viewBox="0 0 100 110" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M50 102C22 74 7 50 7 32 7 14 20 8 30 8 39 8 47 13 50 20 53 13 61 8 70 8 80 8 93 14 93 32 93 50 78 74 50 102Z" stroke="currentColor" stroke-width="4.5" stroke-linejoin="round"/></svg>'
    },
    oblong: {
      label: 'Oblong',
      desc: 'Wide frames with bold temples add width and create a perfectly balanced, proportionate appearance.',
      svg: '<svg viewBox="0 0 60 100" fill="none" xmlns="http://www.w3.org/2000/svg"><ellipse cx="30" cy="50" rx="22" ry="44" stroke="currentColor" stroke-width="4.5"/></svg>'
    }
  };

  function dist(a, b) {
    var dx = a.x - b.x, dy = a.y - b.y;
    return Math.sqrt(dx * dx + dy * dy);
  }

  function classifyShape(lm) {
    var cheekW    = dist(lm[234], lm[454]);
    var foreheadW = dist(lm[103], lm[332]);
    var jawW      = dist(lm[172], lm[397]);
    var faceH     = dist(lm[10],  lm[152]);
    if (!cheekW || !faceH) return 'oval';

    var wh  = cheekW / faceH;
    var ftj = foreheadW / jawW;
    var jtf = jawW / cheekW;

    if (wh < 0.57)                  return 'oblong';
    if (wh > 0.82 && jtf > 0.72)   return 'round';
    if (wh > 0.72 && jtf > 0.80)   return 'square';
    if (ftj > 1.15)                 return 'heart';
    return 'oval';
  }

