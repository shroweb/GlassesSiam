  function normalizeFacetValue(value) {
    return String(value || '')
      .toLowerCase()
      .replace(/[_]+/g, ' ')
      .replace(/\s+/g, ' ')
      .trim();
  }

  function titleizeFacetValue(value) {
    var raw = String(value || '').trim();
    if (!raw) return '';
    var lower = normalizeFacetValue(raw);
    if (lower === 'xl') return 'XL';
    if (lower === 'xxl') return 'XXL';
    if (lower === 'metal') return 'Metal';
    return lower.replace(/\b\w/g, function(char) { return char.toUpperCase(); });
  }

  function coerceToArray(value) {
    if (value == null || value === '') return [];
    if (Array.isArray(value)) {
      return value.reduce(function(acc, item) {
        return acc.concat(coerceToArray(item));
      }, []);
    }
    if (typeof value === 'string') {
      return value
