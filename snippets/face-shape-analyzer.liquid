  var rafId     = null;
  var holdTimer = null;
  var noFaceTimer = null;
  var holdStart = null;
  var buf       = [];
  var BUF_SIZE  = 15;
  var HOLD_MS   = 2000;
  var products  = {};
  var catalogProducts = [];
  var quizSteps = [];
  var quizIndex = 0;
  var launchHasCategory = false;
  var quizAnswers = { category: '', material: '', colors: [], headWidth: '', frameStyle: '' };

  /* ─── DOM ─── */
  var overlay, video, canvas, ctx;
  var openBtns, closeBtn, startBtn, cancelBtn, retryBtn, noCameraBtn, backBtn, quizContinueBtn, quizSkipBtn;
  var statusTxt, progFill, errorEl;
  var shapeName, shapeDesc, prodsGrid, seeAllA, introHeading, introBody, resultEyebrow;
  var quizTitle, quizSubtitle, quizOptions, quizProgress, quizStepCount;

  /* ─── Init ─── */
  function init() {
    var dataEl = document.getElementById('fsa-product-data');
    if (dataEl) { try { products = JSON.parse(dataEl.textContent); } catch(e) {} }
    var catalogEl = document.getElementById('fsa-product-catalog');
    if (catalogEl) { try { catalogProducts = JSON.parse(catalogEl.textContent); } catch(e) {} }

    overlay   = document.getElementById('fsa-overlay');
    video     = document.getElementById('fsaVideo');
    canvas    = document.getElementById('fsaCanvas');
    openBtns  = Array.prototype.slice.call(document.querySelectorAll('#fsaOpenBtn, [data-fsa-open]'));
    closeBtn  = document.getElementById('fsaClose');
    startBtn  = document.getElementById('fsaStart');
    cancelBtn = document.getElementById('fsaCancel');
    retryBtn  = document.getElementById('fsaRetry');
    noCameraBtn = document.getElementById('fsaNoCamera');
    backBtn = document.getElementById('fsaBack');
    quizContinueBtn = document.getElementById('fsaQuizContinue');
    quizSkipBtn = document.getElementById('fsaQuizSkip');
    statusTxt = document.getElementById('fsaStatusText');
    progFill  = document.getElementById('fsaProgressFill');
    errorEl   = document.getElementById('fsaError');
    shapeName = document.getElementById('fsaShapeName');
    shapeDesc = document.getElementById('fsaShapeDesc');
    prodsGrid = document.getElementById('fsaProductsGrid');
    seeAllA   = document.getElementById('fsaSeeAll');
    introHeading = document.getElementById('fsaIntroHeading');
    introBody = document.getElementById('fsaIntroBody');
    resultEyebrow = document.getElementById('fsaResultEyebrow');
    quizTitle = document.getElementById('fsaQuizTitle');
    quizSubtitle = document.getElementById('fsaQuizSubtitle');
    quizOptions = document.getElementById('fsaQuizOptions');
    quizProgress = document.getElementById('fsaQuizProgress');
    quizStepCount = document.getElementById('fsaStepCount');

    if (!overlay) return;
    ctx = canvas ? canvas.getContext('2d') : null;

    if (openBtns && openBtns.length) {
      openBtns.forEach(function(btn) {
        btn.addEventListener('click', function(event) {
          event.preventDefault();
          openModal(btn.getAttribute('data-fsa-category') || 'both');
        });
      });
    }
    closeBtn.addEventListener('click', closeModal);
    startBtn.addEventListener('click', onStart);
    cancelBtn.addEventListener('click', closeModal);
    retryBtn.addEventListener('click', doRetry);
    if (noCameraBtn) noCameraBtn.addEventListener('click', finishWithoutCamera);
