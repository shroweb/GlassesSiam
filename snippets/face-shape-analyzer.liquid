{% comment %}
  Face Shape Analyzer
  Fullscreen modal triggered by #fsaOpenBtn in the header.
  Uses MediaPipe Face Mesh (loaded lazily from CDN) to classify face shape,
  then shows matching product recommendations from the
  custom.face_shape_recommendation metafield.
{% endcomment %}

{% comment %} ── Product data (pre-rendered by Liquid, read by JS) ── {% endcomment %}
{%- assign fsa_shapes = 'oval,round,square,heart,oblong' | split: ',' -%}
<script id="fsa-product-data" type="application/json">
{
  {%- for fsa_shape in fsa_shapes -%}
  "{{ fsa_shape }}": [
    {%- assign fsa_count = 0 -%}
    {%- for fsa_p in collections.all.products -%}
      {%- assign fsa_p_shape = fsa_p.metafields.custom.face_shape_recommendation | downcase | strip -%}
      {%- if fsa_p_shape == fsa_shape and fsa_count < 12 -%}
        {%- assign fsa_type = fsa_p.type | downcase -%}
        {%- assign fsa_category = 'both' -%}
        {%- if fsa_type contains 'sun' -%}
          {%- assign fsa_category = 'sunglasses' -%}
        {%- elsif fsa_type contains 'eye' or fsa_type contains 'optical' or fsa_type contains 'frame' or fsa_type contains 'glass' -%}
          {%- assign fsa_category = 'eyeglasses' -%}
        {%- endif -%}
        {%- if fsa_count > 0 -%},{%- endif -%}
        {
          "title": {{ fsa_p.title | json }},
          "url":   {{ fsa_p.url | json }},
          "price": {{ fsa_p.price | money | json }},
          "image": {% if fsa_p.featured_image != blank %}{{ fsa_p.featured_image | image_url: width: 400 | json }}{% else %}""{% endif %},
          "vendor": {{ fsa_p.vendor | json }},
          "category": {{ fsa_category | json }}
        }
        {%- assign fsa_count = fsa_count | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}
  ]{%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
}
</script>

<script id="fsa-product-catalog" type="application/json">
[
  {%- assign fsa_catalog_count = 0 -%}
  {%- for fsa_p in collections.all.products -%}
    {%- assign fsa_type = fsa_p.type | downcase -%}
    {%- assign fsa_category = 'both' -%}
    {%- if fsa_type contains 'sun' -%}
      {%- assign fsa_category = 'sunglasses' -%}
    {%- elsif fsa_type contains 'eye' or fsa_type contains 'optical' or fsa_type contains 'frame' or fsa_type contains 'glass' -%}
      {%- assign fsa_category = 'eyeglasses' -%}
    {%- endif -%}
    {%- assign fsa_search_text = fsa_p.title | append: ' ' | append: fsa_p.type | append: ' ' | append: fsa_p.tags | join: ' ' | downcase -%}
    {%- if fsa_catalog_count > 0 -%},{%- endif -%}
    {
      "title": {{ fsa_p.title | json }},
      "url": {{ fsa_p.url | json }},
      "price": {{ fsa_p.price | money | json }},
      "image": {% if fsa_p.featured_image != blank %}{{ fsa_p.featured_image | image_url: width: 500 | json }}{% else %}""{% endif %},
      "vendor": {{ fsa_p.vendor | json }},
      "category": {{ fsa_category | json }},
      "search": {{ fsa_search_text | json }},
      "tags": {{ fsa_p.tags | json }},
      "material_meta": {{ fsa_p.metafields.custom.frame_material.value | default: fsa_p.metafields.custom.material.value | default: fsa_p.metafields.custom.materials.value | json }},
      "style_meta": {{ fsa_p.metafields.custom.frame_style.value | default: fsa_p.metafields.custom.style.value | default: fsa_p.metafields.custom.frame_shape.value | json }},
      "fit_meta": {{ fsa_p.metafields.custom.frame_fit.value | default: fsa_p.metafields.custom.fit.value | default: fsa_p.metafields.custom.width_fit.value | json }},
      "width_meta": {{ fsa_p.metafields.custom.frame_width.value | default: fsa_p.metafields.custom.width.value | default: fsa_p.metafields.custom.size.value | json }},
      "color_options": [
        {%- assign fsa_color_values_count = 0 -%}
        {%- for option in fsa_p.options_with_values -%}
          {%- assign fsa_option_name = option.name | downcase | strip -%}
          {%- if fsa_option_name == 'color' or fsa_option_name == 'colour' or fsa_option_name == 'frame color' or fsa_option_name == 'frame colour' -%}
            {%- for value in option.values -%}
              {%- if fsa_color_values_count > 0 -%},{%- endif -%}
              {{ value | json }}
              {%- assign fsa_color_values_count = fsa_color_values_count | plus: 1 -%}
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
      ]
    }
    {%- assign fsa_catalog_count = fsa_catalog_count | plus: 1 -%}
  {%- endfor -%}
]
</script>

{% comment %} ── Modal HTML ── {% endcomment %}
<div id="fsa-overlay"
     class="fsa-overlay"
     aria-modal="true"
     role="dialog"
     aria-label="Face Shape Analyzer"
     aria-hidden="true">

  <button class="fsa-close-btn" id="fsaClose" aria-label="Close">
    <i class="ri-close-line"></i>
  </button>

  {% comment %} Screen 1 – Decision after quiz {% endcomment %}
  <div class="fsa-screen fsa-screen--intro" data-screen="intro">
    <div class="fsa-decision-wrap">
      <div class="fsa-decision-content">
        <p class="fsa-decision-kicker">Optional AI Camera Scan</p>
        <h2 class="fsa-heading" id="fsaIntroHeading">Would you like to continue with our AI feature for better results?</h2>
        <p class="fsa-body-text" id="fsaIntroBody">
          Your privacy matters. We never save scan data, and you can skip the camera and use your quiz answers only.
        </p>
        <p class="fsa-privacy-note">
          <i class="ri-lock-line"></i> Processed entirely on your device — nothing is uploaded
        </p>
        <div class="fsa-decision-actions">
          <button class="fsa-btn fsa-btn--primary" id="fsaStart" type="button">
            <i class="ri-camera-line fsa-btn-icon"></i>
            <span class="fsa-btn-text">Continue with camera</span>
            <span class="fsa-btn-spinner" aria-hidden="true"></span>
          </button>
          <button class="fsa-btn fsa-btn--outline" id="fsaNoCamera" type="button">
            Continue without camera
          </button>
        </div>
        <p class="fsa-error" id="fsaError" role="alert" aria-live="polite"></p>
      </div>
      <div class="fsa-decision-visual" aria-hidden="true">
        <div class="fsa-decision-glass">
          <p>Let's find your perfect pair.</p>
        </div>
      </div>
    </div>
  </div>

  {% comment %} Screen 1b – Quiz flow {% endcomment %}
  <div class="fsa-screen fsa-screen--quiz" data-screen="quiz">
    <div class="fsa-quiz-shell">
      <div class="fsa-quiz-topbar">
        <button class="fsa-nav-btn" id="fsaBack" type="button" aria-label="Go back">
          <i class="ri-arrow-left-s-line"></i>
        </button>
        <div class="fsa-quiz-brand">Frame Finder</div>
        <div class="fsa-quiz-step-pill" id="fsaStepCount">1/4</div>
      </div>
      <div class="fsa-quiz-progress">
        <div class="fsa-quiz-progress-fill" id="fsaQuizProgress"></div>
      </div>
      <div class="fsa-quiz-body">
        <div class="fsa-quiz-copy">
          <h2 class="fsa-quiz-title" id="fsaQuizTitle">What type of glasses are you looking for?</h2>
          <p class="fsa-quiz-subtitle" id="fsaQuizSubtitle"></p>
        </div>
        <div class="fsa-quiz-options" id="fsaQuizOptions"></div>
        <div class="fsa-quiz-actions">
          <button class="fsa-btn fsa-btn--primary fsa-btn--disabled" id="fsaQuizContinue" type="button" disabled>Continue</button>
          <button class="fsa-quiz-skip" id="fsaQuizSkip" type="button">Skip this step</button>
        </div>
      </div>
    </div>
  </div>

  {% comment %} Screen 2 – Live camera {% endcomment %}
  <div class="fsa-screen fsa-screen--camera" data-screen="camera">
    <video id="fsaVideo" playsinline muted autoplay></video>
    <canvas id="fsaCanvas" aria-hidden="true"></canvas>
    <div class="fsa-oval-guide" aria-hidden="true"></div>
    <div class="fsa-status-chip">
      <span class="fsa-status-dot" aria-hidden="true"></span>
      <span id="fsaStatusText">Position your face in the oval</span>
    </div>
    <div class="fsa-progress-wrap" aria-hidden="true">
      <div class="fsa-progress-fill" id="fsaProgressFill"></div>
    </div>
    <button class="fsa-btn fsa-btn--ghost fsa-btn--cancel" id="fsaCancel" type="button">
      Cancel
    </button>
  </div>

  {% comment %} Screen 3 – Result {% endcomment %}
  <div class="fsa-screen fsa-screen--result" data-screen="result">
    <div class="fsa-result-scroll">
      <div class="fsa-result-inner">
        <div class="fsa-result-badge">
          <div class="fsa-shape-label">
            <p class="fsa-result-eyebrow" id="fsaResultEyebrow">Scan Complete</p>
            <h2 class="fsa-result-name" id="fsaShapeName">Recommended Frames</h2>
          </div>
        </div>
        <p class="fsa-result-desc" id="fsaShapeDesc"></p>
        <h3 class="fsa-recs-heading">Recommended for you</h3>
        <div class="fsa-products-grid" id="fsaProductsGrid"></div>
        <a class="fsa-see-all" id="fsaSeeAll" href="#">
          See all recommended frames
          <i class="ri-arrow-right-line"></i>
        </a>
        <button class="fsa-btn fsa-btn--ghost fsa-btn--retry" id="fsaRetry" type="button">
          <i class="ri-refresh-line"></i> Try again
        </button>
      </div>
    </div>
  </div>

</div>

<style>
/* ─────────────────────────────────────────────
   Face Shape Analyzer  (.fsa- namespace)
───────────────────────────────────────────── */
.fsa-overlay {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 100000;
  background: rgba(10, 18, 40, 0.97);
  color: #ffffff;
  font-family: var(--font-stack-body, sans-serif);
}
.fsa-overlay.is-open {
  display: block;
}

/* Close */
.fsa-close-btn {
  position: absolute;
  top: 16px;
  right: 16px;
  z-index: 20;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: rgba(255,255,255,0.12);
  border: none;
  color: #fff;
  font-size: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.2s;
  line-height: 1;
}
.fsa-close-btn:hover { background: rgba(255,255,255,0.22); }

/* ── Screens ── */
.fsa-screen {
  display: none;
  position: absolute;
  inset: 0;
}
.fsa-overlay[data-screen="intro"]  .fsa-screen--intro  {
  display: flex;
  align-items: center;
  justify-content: center;
}
.fsa-overlay[data-screen="quiz"] .fsa-screen--quiz {
  display: flex;
  align-items: stretch;
  justify-content: center;
}
.fsa-overlay[data-screen="camera"] .fsa-screen--camera { display: block; }
.fsa-overlay[data-screen="result"] .fsa-screen--result {
  display: flex;
  align-items: stretch;
}
.fsa-overlay[data-screen="quiz"],
.fsa-overlay[data-screen="intro"] {
  background: #f6f8fb;
  color: #111827;
}
.fsa-overlay[data-screen="quiz"] .fsa-close-btn,
.fsa-overlay[data-screen="intro"] .fsa-close-btn {
  background: rgba(255,255,255,0.9);
  color: #64748b;
  box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08);
}
.fsa-overlay[data-screen="quiz"] .fsa-close-btn:hover,
.fsa-overlay[data-screen="intro"] .fsa-close-btn:hover {
  background: #ffffff;
}

/* ── Screen 1: Intro ── */
.fsa-screen-inner {
  text-align: center;
  max-width: 480px;
  padding: 40px 28px;
  width: 100%;
}
.fsa-intro-icon {
  font-size: 62px;
  color: #31AF68;
  margin-bottom: 22px;
  line-height: 1;
}
.fsa-heading {
  font-size: clamp(22px, 4vw, 32px);
  font-weight: 700;
  margin-bottom: 12px;
  color: #fff;
  line-height: 1.2;
}
.fsa-body-text {
  font-size: 15px;
  color: rgba(255,255,255,0.72);
  margin-bottom: 14px;
  line-height: 1.6;
}
.fsa-privacy-note {
  font-size: 13px;
  color: rgba(255,255,255,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5px;
  margin-bottom: 32px;
}
.fsa-error {
  margin-top: 16px;
  font-size: 14px;
  color: #ff7070;
  line-height: 1.5;
  min-height: 20px;
}
.fsa-decision-wrap {
  width: min(1180px, calc(100% - 48px));
  min-height: min(760px, calc(100vh - 48px));
  margin: 24px;
  display: grid;
  grid-template-columns: minmax(320px, 0.95fr) minmax(360px, 1.05fr);
  border-radius: 28px;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 30px 90px rgba(15, 23, 42, 0.12);
}
.fsa-decision-content {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 56px 56px 48px;
  text-align: left;
}
.fsa-decision-kicker {
  margin: 0 0 12px;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #5aa9ef;
}
.fsa-decision-content .fsa-heading {
  color: #0f172a;
  margin-bottom: 14px;
}
.fsa-decision-content .fsa-body-text {
  color: #475569;
  margin-bottom: 16px;
}
.fsa-decision-content .fsa-privacy-note {
  justify-content: flex-start;
  color: #64748b;
  margin-bottom: 30px;
}
.fsa-decision-actions {
  display: grid;
  gap: 14px;
  justify-items: flex-start;
}
.fsa-decision-visual {
  position: relative;
  background:
    linear-gradient(180deg, rgba(17,48,113,0.08), rgba(17,48,113,0.08)),
    linear-gradient(135deg, #dceeff 0%, #f3f8ff 100%);
  overflow: hidden;
}
.fsa-decision-visual::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 30% 30%, rgba(90,169,239,0.38) 0, rgba(90,169,239,0) 32%),
    linear-gradient(135deg, rgba(17,48,113,0.1) 0%, rgba(17,48,113,0.02) 100%);
}
.fsa-decision-glass {
  position: absolute;
  right: 36px;
  bottom: 42px;
  width: min(340px, calc(100% - 72px));
  padding: 28px 30px;
  border-radius: 26px;
  background: rgba(255,255,255,0.28);
  border: 1px solid rgba(255,255,255,0.45);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  color: #ffffff;
  box-shadow: 0 16px 34px rgba(17, 48, 113, 0.16);
}
.fsa-decision-glass p {
  margin: 0;
  font-size: clamp(28px, 3vw, 54px);
  line-height: 1.05;
  letter-spacing: -0.04em;
}

/* ── Buttons ── */
.fsa-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 14px 34px;
  border-radius: 999px;
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  border: none;
  transition: background 0.2s, transform 0.2s, opacity 0.2s;
  min-width: 190px;
  line-height: 1;
}
.fsa-btn--primary {
  background: #113071;
  color: #fff;
  border: 2px solid rgba(255,255,255,0.2);
}
.fsa-btn--primary:hover:not(:disabled) {
  background: #0d2458;
  transform: translateY(-1px);
}
.fsa-btn--primary:disabled { opacity: 0.55; cursor: default; }

.fsa-btn--ghost {
  background: transparent;
  color: rgba(255,255,255,0.65);
  border: 1px solid rgba(255,255,255,0.22);
}
.fsa-btn--ghost:hover {
  background: rgba(255,255,255,0.08);
  color: #fff;
}
.fsa-btn--outline {
  background: transparent;
  color: #3786dd;
  border: 2px solid #5aa9ef;
}
.fsa-btn--outline:hover {
  background: rgba(90,169,239,0.08);
  color: #226ab9;
}
.fsa-btn--disabled,
.fsa-btn:disabled {
  opacity: 0.45;
  cursor: not-allowed;
  transform: none !important;
}

/* Quiz */
.fsa-quiz-shell {
  width: 100%;
  min-height: 100%;
  display: flex;
  flex-direction: column;
}
.fsa-quiz-topbar {
  display: grid;
  grid-template-columns: 48px 1fr auto;
  align-items: center;
  gap: 18px;
  padding: 18px 24px 10px;
}
.fsa-nav-btn {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  border: 1px solid #d9e2ec;
  background: #ffffff;
  color: #64748b;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  cursor: pointer;
}
.fsa-quiz-brand {
  justify-self: center;
  color: #113071;
  font-size: 18px;
  font-weight: 700;
}
.fsa-quiz-step-pill {
  padding: 6px 14px;
  border-radius: 999px;
  background: #eef2f7;
  color: #475569;
  font-size: 14px;
  font-weight: 600;
}
.fsa-quiz-progress {
  height: 6px;
  background: #e5e7eb;
  overflow: hidden;
}
.fsa-quiz-progress-fill {
  width: 0;
  height: 100%;
  background: #5aa9ef;
  transition: width 0.2s ease;
}
.fsa-quiz-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 36px 24px 56px;
}
.fsa-quiz-copy {
  text-align: center;
  max-width: 720px;
  margin-bottom: 28px;
}
.fsa-quiz-title {
  margin: 0;
  color: #111827;
  font-size: clamp(32px, 3.2vw, 54px);
  line-height: 1.12;
  letter-spacing: -0.04em;
}
.fsa-quiz-subtitle {
  margin: 10px 0 0;
  color: #64748b;
  font-size: 18px;
  line-height: 1.5;
}
.fsa-quiz-options {
  width: min(100%, 420px);
  display: grid;
  gap: 14px;
}
.fsa-quiz-option {
  display: grid;
  grid-template-columns: 100px 1fr;
  align-items: center;
  min-height: 98px;
  border-radius: 18px;
  border: 1px solid #e7edf3;
  background: #ffffff;
  box-shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
  cursor: pointer;
  transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
}
.fsa-quiz-option:hover {
  transform: translateY(-2px);
  border-color: rgba(17,48,113,0.16);
}
.fsa-quiz-option.is-selected {
  border-color: #5aa9ef;
  box-shadow: 0 16px 30px rgba(90, 169, 239, 0.14);
}
.fsa-quiz-option__icon {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  border-right: 1px solid #eef2f7;
  color: #6b7784;
  font-size: 34px;
}
.fsa-quiz-option__label {
  padding: 0 22px;
  color: #0f172a;
  font-size: 17px;
  font-weight: 700;
  line-height: 1.3;
}
.fsa-quiz-swatch-group {
  display: inline-flex;
  align-items: center;
}
.fsa-quiz-swatch {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.9);
  box-shadow: 0 0 0 1px rgba(15, 23, 42, 0.08);
  margin-left: -10px;
}
.fsa-quiz-swatch:first-child {
  margin-left: 0;
}
.fsa-quiz-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
  margin-top: 34px;
}
.fsa-quiz-skip {
  border: none;
  background: none;
  color: #64748b;
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  text-decoration: underline;
  text-underline-offset: 3px;
}

/* Button loading state */
.fsa-btn-spinner {
  display: none;
  width: 16px;
  height: 16px;
  border: 2px solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: fsa-spin 0.7s linear infinite;
  flex-shrink: 0;
}
.fsa-overlay[data-state="loading_sdk"] .fsa-btn-text,
.fsa-overlay[data-state="loading_sdk"] .fsa-btn-icon,
.fsa-overlay[data-state="camera_init"] .fsa-btn-text,
.fsa-overlay[data-state="camera_init"] .fsa-btn-icon { display: none; }
.fsa-overlay[data-state="loading_sdk"] .fsa-btn-spinner,
.fsa-overlay[data-state="camera_init"] .fsa-btn-spinner { display: inline-block; }
@keyframes fsa-spin { to { transform: rotate(360deg); } }

/* ── Screen 2: Camera ── */
#fsaVideo {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transform: scaleX(-1);
}
#fsaCanvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  transform: scaleX(-1);
}
.fsa-oval-guide {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -55%);
  width: min(260px, 52vw);
  height: min(360px, 68vh);
  border-radius: 50%;
  border: 3px dashed rgba(255,255,255,0.65);
  pointer-events: none;
  box-shadow: 0 0 0 9999px rgba(0,0,0,0.42);
}
.fsa-status-chip {
  position: absolute;
  top: 20px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.72);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  padding: 8px 18px;
  border-radius: 999px;
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  color: #fff;
  white-space: nowrap;
  max-width: calc(100% - 40px);
}
.fsa-status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #31AF68;
  flex-shrink: 0;
  animation: fsa-pulse 1.6s ease-in-out infinite;
}
@keyframes fsa-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.45; transform: scale(0.75); }
}
.fsa-progress-wrap {
  position: absolute;
  bottom: 72px;
  left: 50%;
  transform: translateX(-50%);
  width: min(260px, 52vw);
  height: 4px;
  background: rgba(255,255,255,0.18);
  border-radius: 2px;
  overflow: hidden;
}
.fsa-progress-fill {
  height: 100%;
  width: 0%;
  background: #31AF68;
  border-radius: 2px;
  transition: width 0.05s linear;
}
.fsa-btn--cancel {
  position: absolute;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  font-size: 14px;
  padding: 10px 28px;
  min-width: 0;
}

/* ── Screen 3: Result ── */
.fsa-screen--result { align-items: stretch; }
.fsa-result-scroll {
  flex: 1;
  overflow-y: auto;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  padding: 64px 24px 48px;
  width: 100%;
}
.fsa-result-inner {
  width: 100%;
  max-width: 1120px;
  text-align: left;
}
.fsa-result-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 22px;
  margin-bottom: 14px;
}
.fsa-shape-icon {
  width: 60px;
  height: 60px;
  color: #31AF68;
  flex-shrink: 0;
}
.fsa-shape-icon svg { width: 100%; height: 100%; }
.fsa-shape-label { text-align: center; }
.fsa-result-eyebrow {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: rgba(255,255,255,0.62);
  margin: 0 0 4px;
}
.fsa-result-name {
  font-size: clamp(28px, 6vw, 42px);
  font-weight: 700;
  margin: 0;
  color: #fff;
  line-height: 1;
}
.fsa-result-desc {
  max-width: 720px;
  font-size: 16px;
  color: rgba(255,255,255,0.78);
  line-height: 1.7;
  margin-bottom: 28px;
}
.fsa-recs-heading {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: rgba(255,255,255,0.4);
  margin-bottom: 14px;
  font-weight: 600;
}
.fsa-products-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18px;
  margin-bottom: 26px;
}
.fsa-product-card {
  background: #ffffff;
  border: 1px solid rgba(219,229,241,0.95);
  border-radius: 22px;
  overflow: hidden;
  text-decoration: none;
  color: #0f172a;
  display: flex;
  flex-direction: column;
  transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
  text-align: left;
  min-height: 100%;
  box-shadow: 0 18px 42px rgba(15, 23, 42, 0.10);
}
.fsa-product-card:hover {
  background: #ffffff;
  transform: translateY(-4px);
  color: #0f172a;
  border-color: #cbd9ea;
  box-shadow: 0 24px 48px rgba(15, 23, 42, 0.14);
}
.fsa-product-card__img {
  aspect-ratio: 16 / 11;
  overflow: hidden;
  background: linear-gradient(180deg, #f8fbff 0%, #edf4fb 100%);
  padding: 22px;
}
.fsa-product-card__img img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
}
.fsa-product-card__body {
  padding: 14px 16px 16px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  flex: 1 1 auto;
}
.fsa-product-card__vendor {
  margin: 0;
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  font-weight: 700;
  color: #94a3b8;
}
.fsa-product-card__title {
  font-size: 15px;
  font-weight: 700;
  margin: 0;
  line-height: 1.35;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  color: #0f172a;
}
.fsa-product-card__price {
  font-size: 15px;
  color: #113071;
  font-weight: 700;
  margin: 0;
}
.fsa-product-card__cta {
  margin-top: auto;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: #113071;
  font-size: 13px;
  font-weight: 700;
}
.fsa-no-products {
  grid-column: 1 / -1;
  color: rgba(255,255,255,0.65);
  font-size: 14px;
  padding: 24px 0;
  text-align: center;
}
.fsa-see-all {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: #31AF68;
  font-size: 15px;
  font-weight: 600;
  text-decoration: none;
  margin-bottom: 20px;
}
.fsa-see-all:hover { color: #28a060; text-decoration: underline; }
.fsa-btn--retry {
  display: flex;
  margin: 0 auto;
  font-size: 13px;
  padding: 10px 24px;
  min-width: 0;
}

/* ── Trigger button in header (matches a.header-icon style) ── */
.fsa-trigger-btn {
  position: relative;
  display: flex;
  align-items: center;
  line-height: 1;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  color: inherit;
}
.fsa-trigger-btn:hover { color: var(--font-color-primary); }
.fsa-trigger-btn .icon {
  font-size: var(--font-size-body);
  display: flex;
  line-height: 0;
}

/* ── Mobile ── */
@media (max-width: 576px) {
  .fsa-decision-wrap {
    width: calc(100% - 24px);
    min-height: calc(100vh - 24px);
    margin: 12px;
    grid-template-columns: 1fr;
  }
  .fsa-decision-content {
    padding: 34px 22px 28px;
    text-align: center;
  }
  .fsa-decision-content .fsa-privacy-note {
    justify-content: center;
  }
  .fsa-decision-actions {
    justify-items: stretch;
  }
  .fsa-decision-visual {
    min-height: 240px;
  }
  .fsa-decision-glass {
    left: 18px;
    right: 18px;
    bottom: 18px;
    width: auto;
  }
  .fsa-quiz-topbar {
    grid-template-columns: 40px 1fr auto;
    padding: 14px 14px 10px;
  }
  .fsa-quiz-title {
    font-size: 28px;
  }
  .fsa-quiz-options {
    width: 100%;
  }
  .fsa-quiz-option {
    grid-template-columns: 86px 1fr;
    min-height: 88px;
  }
  .fsa-screen-inner       { padding: 32px 20px; }
  .fsa-result-scroll      { padding: 60px 16px 36px; }
  .fsa-result-badge       { flex-direction: column; gap: 10px; }
  .fsa-shape-label        { text-align: center; }
  .fsa-products-grid      { gap: 8px; }
}
.fsa-overlay[data-screen="result"] {
  background:
    radial-gradient(circle at top left, rgba(90,169,239,0.22), rgba(90,169,239,0) 32%),
    linear-gradient(135deg, #0d224f 0%, #173f91 100%);
}
.fsa-see-all {
  color: #ffffff;
  min-height: 46px;
  padding: 0 18px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.22);
  background: rgba(255,255,255,0.10);
}
.fsa-see-all:hover {
  color: #ffffff;
  text-decoration: none;
  background: rgba(255,255,255,0.18);
}
.fsa-btn--retry {
  margin-top: 12px;
}
@media (max-width: 991px) {
  .fsa-products-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}
@media (max-width: 576px) {
  .fsa-result-inner,
  .fsa-shape-label,
  .fsa-result-desc {
    text-align: center;
  }
  .fsa-result-badge {
    justify-content: center;
  }
  .fsa-products-grid {
    grid-template-columns: 1fr;
  }
}
