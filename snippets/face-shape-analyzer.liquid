    }
    if (key.indexOf('exact') !== -1 || key.indexOf('size') !== -1 || /^\d/.test(key)) {
      return '<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M10 31L31 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/><path d="M16 10H31V25" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/><path d="M12 36H36" stroke="currentColor" stroke-width="3" stroke-linecap="round"/><path d="M16 33V39" stroke="currentColor" stroke-width="3" stroke-linecap="round"/><path d="M24 33V39" stroke="currentColor" stroke-width="3" stroke-linecap="round"/><path d="M32 33V39" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>';
    }
    return '<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17 15C17 11.134 20.134 8 24 8C27.866 8 31 11.134 31 15V18C31 21.866 27.866 25 24 25C20.134 25 17 21.866 17 18V15Z" stroke="currentColor" stroke-width="3"/><path d="M13 36C13 31.0294 17.0294 27 22 27H26C30.9706 27 35 31.0294 35 36V38H13V36Z" stroke="currentColor" stroke-width="3"/></svg>';
  }

  function getStyleIconSvg(value) {
    var key = normalizeFacetValue(value);
    if (key.indexOf('bold') !== -1 || key.indexOf('oversized') !== -1 || key.indexOf('statement') !== -1 || key.indexOf('thick') !== -1) {
      return '<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M24 8L27.6 18.4L38 22L27.6 25.6L24 36L20.4 25.6L10 22L20.4 18.4L24 8Z" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/><path d="M35 11L36.2 14.8L40 16L36.2 17.2L35 21L33.8 17.2L30 16L33.8 14.8L35 11Z" fill="currentColor"/></svg>';
    }
    if (key.indexOf('minimal') !== -1 || key.indexOf('rimless') !== -1 || key.indexOf('thin') !== -1 || key.indexOf('wire') !== -1 || key.indexOf('light') !== -1) {
      return '<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="24" cy="24" r="6.5" stroke="currentColor" stroke-width="3"/><path d="M24 9V14" stroke="currentColor" stroke-width="3" stroke-linecap="round"/><path d="M24 34V39" stroke="currentColor" stroke-width="3" stroke-linecap="round"/><path d="M9 24H14" stroke="currentColor" stroke-width="3" stroke-linecap="round"/><path d="M34 24H39" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>';
    }
    return '<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="11" y="11" width="10" height="10" rx="2.5" stroke="currentColor" stroke-width="3"/><rect x="27" y="11" width="10" height="10" rx="2.5" stroke="currentColor" stroke-width="3"/><rect x="11" y="27" width="10" height="10" rx="2.5" stroke="currentColor" stroke-width="3"/><rect x="27" y="27" width="10" height="10" rx="2.5" stroke="currentColor" stroke-width="3"/></svg>';
  }

  function getColorIconMarkup(value) {
    var swatchMap = {
      black: '#111111',
      tortoise: '#7b4b2a',
      brown: '#8b5e3c',
      blue: '#60a5fa',
      green: '#34d399',
      red: '#ef4444',
      pink: '#f472b6',
      purple: '#8b5cf6',
      clear: '#e8f1ff',
      transparent: '#e8f1ff',
      crystal: '#eef2ff',
      beige: '#d6c1a4',
      gold: '#d4a62a',
      silver: '#b8c2cc',
      gray: '#94a3b8',
      grey: '#94a3b8',
      white: '#f8fafc'
    };
    var key = normalizeFacetValue(value);
    var tokens = key.split(/[\s/,+-]+/).filter(Boolean);
    var colors = [];
    tokens.forEach(function(token) {
      if (swatchMap[token] && colors.indexOf(swatchMap[token]) === -1) colors.push(swatchMap[token]);
    });
    if (!colors.length) colors.push('#cbd5e1');
    return '<span class="fsa-quiz-swatch-group">' + colors.slice(0, 3).map(function(color) {
      return '<span class="fsa-quiz-swatch" style="background:' + color + '"></span>';
    }).join('') + '</span>';
  }

  function buildQuizSteps() {
    var steps = [];
    var materialBuckets = getFacetBuckets('material');
    var colorBuckets = getFacetBuckets('color');
    var widthBuckets = getFacetBuckets('width');
    var styleBuckets = getFacetBuckets('style');

    if (!launchHasCategory) {
      steps.push({
        id: 'category',
        title: 'What type of glasses are you looking for?',
        subtitle: '',
        multi: false,
        options: [
          { value: 'eyeglasses', label: 'Eyeglasses', icon: '<svg viewBox="0 0 64 28" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3 11.5C3 8.46243 5.46243 6 8.5 6H21.5C24.5376 6 27 8.46243 27 11.5V14.5C27 17.5376 24.5376 20 21.5 20H8.5C5.46243 20 3 17.5376 3 14.5V11.5Z" stroke="currentColor" stroke-width="2.5"/><path d="M37 11.5C37 8.46243 39.4624 6 42.5 6H55.5C58.5376 6 61 8.46243 61 11.5V14.5C61 17.5376 58.5376 20 55.5 20H42.5C39.4624 20 37 17.5376 37 14.5V11.5Z" stroke="currentColor" stroke-width="2.5"/><path d="M27 12.5H37" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/><path d="M2 10L7 9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/><path d="M62 10L57 9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>' },
          { value: 'sunglasses', label: 'Sunglasses', icon: '<svg viewBox="0 0 64 28" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3 11.5C3 8.46243 5.46243 6 8.5 6H21.5C24.5376 6 27 8.46243 27 11.5V14.5C27 17.5376 24.5376 20 21.5 20H8.5C5.46243 20 3 17.5376 3 14.5V11.5Z" fill="currentColor" fill-opacity="0.18" stroke="currentColor" stroke-width="2.5"/><path d="M37 11.5C37 8.46243 39.4624 6 42.5 6H55.5C58.5376 6 61 8.46243 61 11.5V14.5C61 17.5376 58.5376 20 55.5 20H42.5C39.4624 20 37 17.5376 37 14.5V11.5Z" fill="currentColor" fill-opacity="0.18" stroke="currentColor" stroke-width="2.5"/><path d="M27 12.5H37" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/><path d="M2 10L7 9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/><path d="M62 10L57 9" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>' },
          { value: 'both', label: 'Both', icon: '<svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M10 15H38" stroke="currentColor" stroke-width="3.2" stroke-linecap="round"/><path d="M10 24H38" stroke="currentColor" stroke-width="3.2" stroke-linecap="round"/><path d="M10 33H38" stroke="currentColor" stroke-width="3.2" stroke-linecap="round"/><circle cx="18" cy="15" r="4" fill="#ffffff" stroke="currentColor" stroke-width="3"/><circle cx="30" cy="24" r="4" fill="#ffffff" stroke="currentColor" stroke-width="3"/><circle cx="22" cy="33" r="4" fill="#ffffff" stroke="currentColor" stroke-width="3"/></svg>' }
        ]
      });
    }

    if (materialBuckets.length) {
      steps.push({
        id: 'material',
        title: 'Which frame materials are you interested in?',
        subtitle: 'These options come from your current product data.',
        multi: false,
        options: materialBuckets.slice(0, 6).map(function(bucket) {
          return { value: bucket.value, label: bucket.label, icon: getMaterialIconSvg(bucket.value) };
        })
      });
    }

    if (colorBuckets.length) {
      steps.push({
        id: 'colors',
        title: 'What frame colors do you like?',
        subtitle: 'You can pick more than one.',
        multi: true,
        options: colorBuckets.slice(0, 6).map(function(bucket) {
          return { value: bucket.value, label: bucket.label, icon: getColorIconMarkup(bucket.value) };
        })
      });
    }

    if (widthBuckets.length) {
      steps.push({
        id: 'headWidth',
        title: 'Which fit or size works best for you?',
        subtitle: 'These values come from your product sizing data.',
        multi: false,
        options: widthBuckets.slice(0, 6).map(function(bucket) {
          return { value: bucket.value, label: bucket.label, icon: getWidthIconSvg(bucket.value) };
        })
      });
    }

    if (styleBuckets.length) {
      steps.push({
        id: 'frameStyle',
        title: 'What frame style do you prefer?',
        subtitle: 'These styles come from your current product data.',
        multi: false,
        options: styleBuckets.slice(0, 6).map(function(bucket) {
          return { value: bucket.value, label: bucket.label, icon: getStyleIconSvg(bucket.value) };
        })
      });
    }

    return steps;
  }

  function getStepValue(stepId) {
    if (stepId === 'colors') return quizAnswers.colors || [];
    return quizAnswers[stepId];
  }

  function setStepValue(stepId, value) {
    if (stepId === 'colors') {
      quizAnswers.colors = value;
    } else {
      quizAnswers[stepId] = value;
    }
    if (stepId === 'category' && value) finderCategory = value;
  }

  function isStepAnswered(step) {
    var value = getStepValue(step.id);
    return step.multi ? value && value.length > 0 : !!value;
  }

  function renderQuizStep() {
    var step = quizSteps[quizIndex];
    if (!step || !quizTitle || !quizOptions) return;

    setScreen('quiz');
    setState(S.QUIZ);
    if (quizTitle) quizTitle.textContent = step.title;
    if (quizSubtitle) {
      quizSubtitle.textContent = step.subtitle || '';
      quizSubtitle.style.display = step.subtitle ? '' : 'none';
    }
    if (quizStepCount) quizStepCount.textContent = (quizIndex + 1) + '/' + quizSteps.length;
    if (quizProgress) quizProgress.style.width = (((quizIndex + 1) / quizSteps.length) * 100) + '%';
    if (backBtn) backBtn.style.visibility = (quizIndex === 0 && launchHasCategory) ? 'hidden' : 'visible';

    var selectedValue = getStepValue(step.id);
    quizOptions.innerHTML = step.options.map(function(option) {
      var selected = step.multi
        ? Array.isArray(selectedValue) && selectedValue.indexOf(option.value) !== -1
        : selectedValue === option.value;
      return '<button type="button" class="fsa-quiz-option' + (selected ? ' is-selected' : '') + '" data-step-id="' + step.id + '" data-value="' + option.value + '">'
        + '<span class="fsa-quiz-option__icon">' + option.icon + '</span>'
        + '<span class="fsa-quiz-option__label">' + option.label + '</span>'
        + '</button>';
    }).join('');

    Array.prototype.slice.call(quizOptions.querySelectorAll('.fsa-quiz-option')).forEach(function(btn) {
      btn.addEventListener('click', function() {
        selectQuizOption(step, btn.getAttribute('data-value'));
      });
    });

    updateQuizContinueState();
  }

  function updateQuizContinueState() {
    if (!quizContinueBtn) return;
    var step = quizSteps[quizIndex];
    var enabled = step ? isStepAnswered(step) : false;
    quizContinueBtn.disabled = !enabled;
    quizContinueBtn.classList.toggle('fsa-btn--disabled', !enabled);
  }

  function selectQuizOption(step, value) {
    if (!step) return;
    if (step.multi) {
      var current = (quizAnswers.colors || []).slice();
      var idx = current.indexOf(value);
      if (idx === -1) current.push(value); else current.splice(idx, 1);
      setStepValue(step.id, current);
    } else {
      setStepValue(step.id, value);
    }
    renderQuizStep();
  }

  function handleQuizContinue() {
    if (quizIndex >= quizSteps.length - 1) {
      showDecision();
      return;
    }
    quizIndex += 1;
    renderQuizStep();
  }

  function handleQuizSkip() {
    var step = quizSteps[quizIndex];
    if (step) {
      setStepValue(step.id, step.multi ? [] : '');
    }
    if (quizIndex >= quizSteps.length - 1) {
      showDecision();
    } else {
      quizIndex += 1;
      renderQuizStep();
    }
  }

  function handleBack() {
    if (overlay.getAttribute('data-screen') === 'intro') {
      renderQuizStep();
      return;
    }
    if (quizIndex === 0) {
      closeModal();
      return;
    }
    quizIndex -= 1;
    renderQuizStep();
  }

  function showDecision() {
    applyFinderCopy();
    setScreen('intro');
    setState(S.DECISION);
    if (startBtn) {
      startBtn.disabled = false;
      startBtn.classList.remove('fsa-btn--disabled');
    }
  }

  function summarizeQuizAnswers() {
    var parts = [];
    if (finderCategory && finderCategory !== 'both') parts.push(finderCategory);
    if (quizAnswers.material) {
      parts.push(titleizeFacetValue(quizAnswers.material));
    }
    if (quizAnswers.colors && quizAnswers.colors.length) {
      parts.push(quizAnswers.colors.map(titleizeFacetValue).join(' + ') + ' tones');
    }
    if (quizAnswers.headWidth) {
      parts.push(titleizeFacetValue(quizAnswers.headWidth) + ' fit');
    }
    if (quizAnswers.frameStyle) {
      parts.push(titleizeFacetValue(quizAnswers.frameStyle) + ' styling');
    }
    if (!parts.length) return 'These picks are based on your quick quiz preferences.';
    return 'These picks are based on your preference for ' + parts.join(', ') + '.';
  }

  function scoreQuizProduct(product) {
    var score = 0;
    var materials = getProductFacetValues(product, 'material').map(normalizeFacetValue);
    var colors = getProductFacetValues(product, 'color').map(normalizeFacetValue);
    var widths = getProductFacetValues(product, 'width').map(normalizeFacetValue);
    var styles = getProductFacetValues(product, 'style').map(normalizeFacetValue);
    if (finderCategory === 'both' || product.category === finderCategory || product.category === 'both') score += 5;
    if (quizAnswers.material && materials.indexOf(normalizeFacetValue(quizAnswers.material)) !== -1) score += 4;
    (quizAnswers.colors || []).forEach(function(colorPref) {
      if (colors.indexOf(normalizeFacetValue(colorPref)) !== -1) score += 2;
    });
    if (quizAnswers.headWidth && widths.indexOf(normalizeFacetValue(quizAnswers.headWidth)) !== -1) score += 3;
    if (quizAnswers.frameStyle && styles.indexOf(normalizeFacetValue(quizAnswers.frameStyle)) !== -1) score += 3;
    return score;
  }

  function renderProductsList(prods) {
    if (!prodsGrid) return;
    if (prods.length > 0) {
      prodsGrid.innerHTML = prods.map(function (p) {
        var img = p.image
          ? '<img src="' + p.image + '" alt="' + (p.title || '').replace(/[<>&"]/g, '') + '" loading="lazy">'
          : '';
        var vendor = p.vendor ? '<p class="fsa-product-card__vendor">' + p.vendor + '</p>' : '';
        return '<a class="fsa-product-card" href="' + (p.url || '#') + '">'
          + '<div class="fsa-product-card__img">' + img + '</div>'
          + '<div class="fsa-product-card__body">'
          + vendor
          + '<p class="fsa-product-card__title">' + (p.title || '') + '</p>'
          + '<p class="fsa-product-card__price">' + (p.price || '') + '</p>'
          + '<span class="fsa-product-card__cta">Shop frame <i class="ri-arrow-right-line"></i></span>'
          + '</div></a>';
      }).join('');
    } else {
      prodsGrid.innerHTML = '<p class="fsa-no-products">No matching products found yet — try a broader selection.</p>';
    }
  }

  function openModal(category) {
    if (state !== S.IDLE) return;
    finderCategory = category || 'both';
    launchHasCategory = !!category;
    quizAnswers = {
      category: category || '',
      material: '',
      colors: [],
      headWidth: '',
      frameStyle: ''
    };
    quizSteps = buildQuizSteps();
    quizIndex = 0;
    applyFinderCopy();
    overlay.setAttribute('aria-hidden', 'false');
    overlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    clearErr();
    if (quizSteps.length) {
      setScreen('quiz');
      setState(S.QUIZ);
      renderQuizStep();
    } else {
      showDecision();
    }
  }

  function closeModal() {
    stopCamera();
    stopHold();
    clearNoFace();
    buf = [];
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
    overlay.removeAttribute('data-screen');
    document.body.style.overflow = '';
    if (progFill) progFill.style.width = '0%';
    if (startBtn) startBtn.disabled = false;
    if (quizProgress) quizProgress.style.width = '0%';
    clearErr();
    quizAnswers = { category: '', material: '', colors: [], headWidth: '', frameStyle: '' };
    quizSteps = [];
    quizIndex = 0;
    launchHasCategory = false;
    setState(S.IDLE);
  }

  function doRetry() {
    stopCamera();
    stopHold();
    clearNoFace();
    buf = [];
    if (progFill) progFill.style.width = '0%';
    if (startBtn) startBtn.disabled = false;
    clearErr();
    quizAnswers.material = '';
    quizAnswers.colors = [];
    quizAnswers.headWidth = '';
    quizAnswers.frameStyle = '';
    if (!launchHasCategory) quizAnswers.category = '';
    quizSteps = buildQuizSteps();
    quizIndex = 0;
    if (quizSteps.length) {
      renderQuizStep();
    } else {
      showDecision();
    }
  }

  /* ─── Start button ─── */
  function onStart() {
    if (state !== S.DECISION && state !== S.LOADING_SDK && state !== S.PERMISSION) return;
    startBtn.disabled = true;
    clearErr();
    setState(S.LOADING_SDK);
    loadSdk().then(function () {
      setState(S.PERMISSION);
      startCamera();
    }).catch(function () {
      startBtn.disabled = false;
      setState(S.DECISION);
      showErr('Could not load analyzer. Please check your connection.');
    });
  }

  function finishWithoutCamera() {
    stopCamera();
    stopHold();
    clearNoFace();
    if (resultEyebrow) resultEyebrow.textContent = 'Quiz Complete';
    if (shapeName) shapeName.textContent = 'Recommended Frames';
    if (shapeDesc) shapeDesc.textContent = summarizeQuizAnswers();

    var scored = catalogProducts
      .filter(function(product) {
        return finderCategory === 'both' || product.category === finderCategory || product.category === 'both';
      })
      .map(function(product) {
        return { product: product, score: scoreQuizProduct(product) };
      })
      .sort(function(a, b) { return b.score - a.score; })
      .map(function(entry) { return entry.product; });

    if (!scored.length) scored = catalogProducts.slice();
    renderProductsList(scored.slice(0, 4));

    var collectionHandle = finderCategory === 'eyeglasses'
      ? 'eyeglasses'
      : finderCategory === 'sunglasses'
        ? 'sunglasses'
        : 'all';
    if (seeAllA) seeAllA.href = '/collections/' + collectionHandle;

    setState(S.RESULT);
    setScreen('result');
  }

  /* ─── SDK lazy load ─── */
  function loadSdk() {
    return new Promise(function (resolve, reject) {
      if (window._fsaSdkState === 'ready') { resolve(); return; }
      if (window._fsaSdkState === 'loading') {
        var t = setInterval(function () {
          if (window._fsaSdkState === 'ready') { clearInterval(t); resolve(); }
          if (window._fsaSdkState === 'error')  { clearInterval(t); reject();  }
        }, 150);
        return;
      }
      window._fsaSdkState = 'loading';
      var s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/npm/@mediapipe/face_mesh@0.4.1633559619/face_mesh.js';
      s.crossOrigin = 'anonymous';
      s.onload  = function () { window._fsaSdkState = 'ready'; resolve(); };
      s.onerror = function () { window._fsaSdkState = 'error';  reject();  };
      document.head.appendChild(s);
    });
  }

  /* ─── FaceMesh init ─── */
  function initFaceMesh() {
    return new Promise(function (resolve, reject) {
      if (faceMesh) { resolve(); return; }
      var FM = window.FaceMesh;
      if (!FM) { reject(new Error('FaceMesh not available')); return; }
      try {
        faceMesh = new FM({
          locateFile: function (f) {
            return 'https://cdn.jsdelivr.net/npm/@mediapipe/face_mesh@0.4.1633559619/' + f;
          }
        });
        faceMesh.setOptions({
          maxNumFaces: 1,
          refineLandmarks: false,
          minDetectionConfidence: 0.6,
          minTrackingConfidence: 0.5
        });
        faceMesh.onResults(onResults);
        faceMesh.initialize().then(resolve).catch(reject);
      } catch (e) { reject(e); }
    });
  }

  /* ─── Camera ─── */
  function startCamera() {
    if (startBtn) startBtn.disabled = true;
    clearErr();
    setState(S.CAMERA_INIT);

    initFaceMesh()
      .then(function () {
        return navigator.mediaDevices.getUserMedia({
          video: { facingMode: 'user', width: { ideal: 640 }, height: { ideal: 480 } },
          audio: false
        });
      })
      .then(function (stream) {
        vidStream = stream;
        video.srcObject = stream;
        return video.play();
      })
      .then(function () {
        canvas.width  = video.videoWidth  || 640;
        canvas.height = video.videoHeight || 480;
        setScreen('camera');
        setState(S.SCANNING);
        setStatus('Position your face in the oval');
        startDetection();
        startNoFace();
      })
      .catch(function (err) {
        if (startBtn) startBtn.disabled = false;
        setScreen('intro');
        setState(S.DECISION);
        if (err && (err.name === 'NotAllowedError' || err.name === 'PermissionDeniedError')) {
          showErr('Camera access was denied. Please allow camera permission in your browser settings.');
        } else {
          showErr('Could not start your camera. Please ensure it is not in use by another app.');
        }
      });
  }

  function stopCamera() {
    if (rafId)     { cancelAnimationFrame(rafId); rafId = null; }
    if (vidStream) { vidStream.getTracks().forEach(function (t) { t.stop(); }); vidStream = null; }
    if (video)     { video.srcObject = null; }
    if (ctx && canvas) { ctx.clearRect(0, 0, canvas.width, canvas.height); }
  }

  /* ─── Detection loop ─── */
  function startDetection() {
    function loop() {
      if (state !== S.SCANNING && state !== S.HOLDING) return;
      if (video.readyState >= 2 && faceMesh) {
        faceMesh.send({ image: video }).catch(function () {});
      }
      rafId = requestAnimationFrame(loop);
    }
    rafId = requestAnimationFrame(loop);
  }

  /* ─── Results handler ─── */
  function onResults(res) {
    if (!ctx || !canvas) return;
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    var lms = res.multiFaceLandmarks && res.multiFaceLandmarks[0];
    if (!lms) {
      buf = [];
      stopHold();
      if (state === S.HOLDING) setState(S.SCANNING);
      return;
    }

    clearNoFace();
    startNoFace();
    drawDots(lms);

    var shape = classifyShape(lms);
    buf.push(shape);
    if (buf.length > BUF_SIZE) buf.shift();

    var stable = buf.length === BUF_SIZE && buf.every(function (s) { return s === buf[0]; });

    if (stable) {
      setStatus('Hold still\u2026');
      if (state === S.SCANNING) {
        setState(S.HOLDING);
        startHold(shape);
      }
    } else {
      if (state === S.HOLDING) { setState(S.SCANNING); stopHold(); }
      setStatus(buf.length > 7 ? 'Almost there\u2026' : 'Position your face in the oval');
    }
  }

  function drawDots(lms) {
    var w = canvas.width, h = canvas.height;
    var pts = [10,152,234,454,103,332,172,397,33,263,4,61,291,127,356,70,300,132,361];
    ctx.fillStyle = 'rgba(80,200,120,0.65)';
    for (var i = 0; i < pts.length; i++) {
      var p = lms[pts[i]];
      ctx.beginPath();
      ctx.arc(p.x * w, p.y * h, 3, 0, 6.283);
      ctx.fill();
    }
  }

  /* ─── Hold timer ─── */
  function startHold(shape) {
    holdStart = Date.now();
    holdTimer = setInterval(function () {
      var pct = Math.min(((Date.now() - holdStart) / HOLD_MS) * 100, 100);
      if (progFill) progFill.style.width = pct + '%';
      if (pct >= 100) {
        stopHold();
        clearNoFace();
        stopCamera();
        renderResult(shape);
        setState(S.RESULT);
        setScreen('result');
      }
    }, 50);
  }

  function stopHold() {
    if (holdTimer) { clearInterval(holdTimer); holdTimer = null; }
    if (progFill)  progFill.style.width = '0%';
  }

  /* ─── No-face nudge ─── */
  function startNoFace() {
    if (noFaceTimer) return;
    noFaceTimer = setTimeout(function () {
      noFaceTimer = null;
      if (state === S.SCANNING) setStatus('Make sure your face is well-lit and centred in the oval');
    }, 7000);
  }
  function clearNoFace() { if (noFaceTimer) { clearTimeout(noFaceTimer); noFaceTimer = null; } }

  /* ─── Helpers ─── */
  function setStatus(msg) { if (statusTxt) statusTxt.textContent = msg; }
  function showErr(msg)   { if (errorEl) errorEl.textContent = msg; }
  function clearErr()     { if (errorEl) errorEl.textContent = ''; }

  /* ─── Result ─── */
  function renderResult(shape) {
    var meta = SHAPES[shape] || SHAPES.oval;
    if (resultEyebrow) resultEyebrow.textContent = 'Scan Complete';
    if (shapeName) shapeName.textContent = meta.label + ' Face';
    if (shapeDesc) shapeDesc.textContent = meta.desc;

    var prods = products[shape] || [];
    if (finderCategory !== 'both') {
      prods = prods.filter(function(p) {
        return p.category === finderCategory || p.category === 'both';
      });
    }
    if (!prods.length && finderCategory !== 'both') {
      prods = products[shape] || [];
    }
    prods = prods.slice(0, 4);
    renderProductsList(prods);

    var collectionHandle = finderCategory === 'eyeglasses'
      ? 'eyeglasses'
      : finderCategory === 'sunglasses'
        ? 'sunglasses'
        : 'all';
    var url = '/collections/' + collectionHandle + '?filter.p.m.custom.face_shape_recommendation=' + shape;
    if (seeAllA)   seeAllA.href = url;
  }

  /* ─── Boot ─── */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

}());
</script>
