  function getProductFacetValues(product, facet) {
    if (!product) return [];
    if (facet === 'material') {
      return uniqValues(
        coerceToArray(product.material_meta).concat(
          extractTagFacetValues(product.tags, ['material', 'frame material', 'frame_material'])
        )
      );
    }
    if (facet === 'style') {
      return uniqValues(
        coerceToArray(product.style_meta).concat(
          extractTagFacetValues(product.tags, ['style', 'frame style', 'frame-style', 'frame_style', 'shape', 'frame shape'])
        )
      );
    }
    if (facet === 'width') {
      return uniqValues(
        coerceToArray(product.fit_meta)
          .concat(coerceToArray(product.width_meta))
          .concat(extractTagFacetValues(product.tags, ['fit', 'frame fit', 'width', 'frame width', 'frame_width', 'size']))
      );
    }
    if (facet === 'color') {
      return uniqValues(
        coerceToArray(product.color_options).concat(
          extractTagFacetValues(product.tags, ['color', 'colour', 'frame color', 'frame colour'])
        )
      );
    }
    return [];
  }

  function getFacetBuckets(facet) {
    var buckets = {};
    catalogProducts.forEach(function(product) {
      getProductFacetValues(product, facet).forEach(function(value) {
        var key = normalizeFacetValue(value);
        if (!key) return;
        if (!buckets[key]) {
          buckets[key] = { value: key, label: titleizeFacetValue(value), count: 0 };
