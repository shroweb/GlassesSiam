    if (quizContinueBtn) quizContinueBtn.addEventListener('click', handleQuizContinue);
    if (quizSkipBtn) quizSkipBtn.addEventListener('click', handleQuizSkip);

    overlay.addEventListener('click', function (e) { if (e.target === overlay) closeModal(); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && state !== S.IDLE) closeModal(); });
  }

  function setState(s) { state = s; overlay && overlay.setAttribute('data-state', s); }
