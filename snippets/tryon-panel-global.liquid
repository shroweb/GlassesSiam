{% comment %}
  Global Try-On Panel — renders on non-product pages (collection, etc.)
  Populates itself via JS by reading product data from GlassOn's context
  or from the nearest product card in the DOM.
{% endcomment %}

<div id="tryon-panel" class="tryon-panel" aria-hidden="true">
  <div class="tryon-panel__inner">

    <button class="tryon-panel__close" id="tryonPanelClose" aria-label="Close panel">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <div class="tryon-panel__thumb">
      <img id="tryonPanelImage" src="" alt="" width="140" height="100">
    </div>

    <div class="tryon-panel__info">
      <p class="tryon-panel__vendor" id="tryonPanelVendor"></p>
      <h3 class="tryon-panel__title" id="tryonPanelTitle">Loading...</h3>
      <div class="tryon-panel__price">
        <span class="tryon-panel__price-new" id="tryonPanelPrice"></span>
      </div>
      <div class="tryon-panel__actions">
        <button class="tryon-panel__atc" id="tryonAddToCart">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
          Add to Cart
        </button>
        <a class="tryon-panel__see-frame" id="tryonSeeFrame" href="#">
          See Frame
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
      <p class="tryon-panel__feedback" id="tryonFeedback" aria-live="polite"></p>
    </div>

  </div>
</div>

<style>
.tryon-panel {
  position: fixed;
  bottom: 16px;
  left: 0;
  right: 0;
  z-index: 1000001;
  transform: translateY(calc(100% + 16px));
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  pointer-events: none;
  padding: 0 12px;
}
.tryon-panel.is-visible {
  transform: translateY(0);
  pointer-events: auto;
}
.tryon-panel__inner {
  background: #fff;
  border-radius: 20px;
  box-shadow: 0 8px 48px rgba(0,0,0,0.22);
  padding: 22px 22px 26px;
  display: flex;
  gap: 18px;
  align-items: flex-start;
  max-width: 560px;
  margin: 0 auto;
  position: relative;
}
.tryon-panel__close {
  position: absolute;
  top: 14px;
  right: 14px;
  background: #f3f4f6;
  border: none;
  border-radius: 50%;
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: #6b7280;
  transition: background 0.15s, color 0.15s;
  flex-shrink: 0;
}
.tryon-panel__close:hover { background: #e5e7eb; color: #111827; }
.tryon-panel__thumb {
  flex-shrink: 0;
  width: 130px;
  height: 96px;
  border-radius: 12px;
  overflow: hidden;
  background: #f8f9fb;
  border: 1px solid #e8ecf0;
}
.tryon-panel__thumb img {
  width: 100%; height: 100%; object-fit: contain; display: block;
}
.tryon-panel__info { flex: 1; min-width: 0; }
.tryon-panel__vendor {
  font-size: 11px; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; color: #9ca3af; margin-bottom: 3px;
}
.tryon-panel__title {
  font-size: 16px; font-weight: 700; color: #111827;
  letter-spacing: -0.01em; line-height: 1.3; margin-bottom: 7px;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.tryon-panel__price { display: flex; align-items: baseline; gap: 8px; margin-bottom: 12px; }
.tryon-panel__price-new { font-size: 19px; font-weight: 700; color: #111827; }
.tryon-panel__actions { display: flex; gap: 8px; align-items: center; }
.tryon-panel__atc {
  display: inline-flex; align-items: center; gap: 7px;
  background: #113071; color: #fff; border: none; border-radius: 9px;
  font-size: 14px; font-weight: 700; letter-spacing: 0.04em;
  padding: 12px 20px; cursor: pointer;
  transition: background 0.2s, transform 0.15s;
  flex: 1; justify-content: center;
}
.tryon-panel__atc:hover { background: #0d2458; transform: translateY(-1px); }
.tryon-panel__atc:disabled { background: #c4c9d4; cursor: not-allowed; transform: none; }
.tryon-panel__see-frame {
  display: inline-flex; align-items: center; gap: 5px;
  background: transparent; color: #113071; border: 1.5px solid #113071;
  border-radius: 9px; font-size: 14px; font-weight: 700;
  letter-spacing: 0.04em; padding: 12px 16px; text-decoration: none;
  transition: background 0.2s, color 0.2s; white-space: nowrap;
}
.tryon-panel__see-frame:hover { background: #113071; color: #fff; text-decoration: none; }
.tryon-panel__feedback { font-size: 12px; color: #16a34a; margin-top: 6px; min-height: 16px; font-weight: 600; }
@media (max-width: 480px) {
  .tryon-panel { bottom: 10px; padding: 0 8px; }
  .tryon-panel__inner { padding: 18px 16px 22px; gap: 14px; }
  .tryon-panel__thumb { width: 100px; height: 76px; }
}
</style>

<script>
(function() {
  var panel     = document.getElementById('tryon-panel');
  var closeBtn  = document.getElementById('tryonPanelClose');
  var atcBtn    = document.getElementById('tryonAddToCart');
  var feedback  = document.getElementById('tryonFeedback');
  var imgEl     = document.getElementById('tryonPanelImage');
  var titleEl   = document.getElementById('tryonPanelTitle');
  var vendorEl  = document.getElementById('tryonPanelVendor');
  var priceEl   = document.getElementById('tryonPanelPrice');
  var seeFrame  = document.getElementById('tryonSeeFrame');

  if (!panel) return;

  var panelVisible  = false;
  var userClosed    = false;
  var currentVariantId = null;

  function showPanel() { panel.classList.add('is-visible'); panel.setAttribute('aria-hidden','false'); panelVisible = true; }
  function hidePanel() { panel.classList.remove('is-visible'); panel.setAttribute('aria-hidden','true'); panelVisible = false; }

  function formatMoney(cents) {
    return (cents / 100).toLocaleString('en-US', { style: 'currency', currency: 'THB', minimumFractionDigits: 2 });
  }

  // Populate panel from a Shopify product object (from /products/handle.js)
  function populateFromProduct(product) {
    var variant = product.variants[0];
    currentVariantId = variant.id;
    if (atcBtn) atcBtn.dataset.variantId = variant.id;
    if (titleEl) titleEl.textContent = product.title;
    if (vendorEl) vendorEl.textContent = product.vendor;
    if (priceEl) priceEl.textContent = formatMoney(variant.price);
    if (imgEl && product.featured_image) { imgEl.src = product.featured_image; imgEl.alt = product.title; }
    if (seeFrame) seeFrame.href = '/products/' + product.handle;
  }

  // Try to find the product handle from the GlassOn button's nearest product card
  function getHandleFromDOM() {
    // GlassOn buttons are inside .glasson-wrap; walk up to find a product card link
    var glassonBtns = document.querySelectorAll('.glasson-btn');
    if (!glassonBtns.length) return null;

    // Find which one is "active" — GlassOn doesn't mark it, so grab all nearby product links
    var allProductLinks = document.querySelectorAll('a[href*="/products/"]');
    var candidates = Array.from(allProductLinks).map(function(a) {
      var m = a.href.match(/\/products\/([^/?#]+)/);
      return m ? m[1] : null;
    }).filter(Boolean);

    // Deduplicate
    var seen = {};
    return candidates.filter(function(h) { return seen[h] ? false : (seen[h] = true); });
  }

  // Watch GlassOn shadow DOM
  function isGlassOnOpen() {
    var el = document.querySelector('glasson-try-on');
    if (!el || !el.shadowRoot) return false;
    return !!el.shadowRoot.querySelector('.g-dialog-overlay--active');
  }

  function checkGlassOn() {
    var open = isGlassOnOpen();
    if (open && !panelVisible && !userClosed) {
      // Try to figure out which product is being tried on
      // GlassOn stores the current product handle as a data attribute on the glasson-wrap
      var wrap = document.querySelector('.glasson-wrap');
      var handle = wrap ? (wrap.closest('[data-product-handle]') || wrap.closest('[data-handle]')) : null;
      var productHandle = handle ? (handle.dataset.productHandle || handle.dataset.handle) : null;

      // Fallback: grab from page URL if on product page
      if (!productHandle) {
        var urlMatch = window.location.pathname.match(/\/products\/([^/?#]+)/);
        productHandle = urlMatch ? urlMatch[1] : null;
      }

      // Last resort: grab first product handle visible on page
      if (!productHandle) {
        var handles = getHandleFromDOM();
        productHandle = handles && handles[0];
      }

      if (productHandle) {
        fetch('/products/' + productHandle + '.js')
          .then(function(r) { return r.json(); })
          .then(function(p) { populateFromProduct(p); showPanel(); })
          .catch(function() { showPanel(); }); // show even if fetch fails
      } else {
        showPanel();
      }
    } else if (!open && panelVisible) {
      hidePanel();
      userClosed = false;
    }
  }

  function attachShadowObserver(el) {
    if (!el.shadowRoot || el._shadowObserved) return;
    el._shadowObserved = true;
    new MutationObserver(checkGlassOn).observe(el.shadowRoot, {
      childList: true, subtree: true, attributes: true, attributeFilter: ['class']
    });
  }

  var glassonEl = document.querySelector('glasson-try-on');
  if (glassonEl) attachShadowObserver(glassonEl);

  new MutationObserver(function() {
    var el = document.querySelector('glasson-try-on');
    if (el) attachShadowObserver(el);
  }).observe(document.body, { childList: true, subtree: false });

  // Close button
  if (closeBtn) {
    closeBtn.addEventListener('click', function() { userClosed = true; hidePanel(); });
  }

  // Add to Cart
  if (atcBtn) {
    atcBtn.addEventListener('click', function() {
      var variantId = atcBtn.dataset.variantId || currentVariantId;
      if (!variantId) return;
      atcBtn.disabled = true;
      atcBtn.textContent = 'Adding…';
      if (feedback) feedback.textContent = '';

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: parseInt(variantId), quantity: 1 })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.status) throw new Error(data.description || data.message);
        if (feedback) { feedback.textContent = '✓ Added to cart!'; setTimeout(function() { feedback.textContent = ''; }, 3000); }
        var bubble = document.querySelector('.cart-count, .cart-item-count, [data-cart-count]');
        if (bubble) fetch('/cart.js').then(function(r) { return r.json(); }).then(function(c) { bubble.textContent = c.item_count; });
      })
      .catch(function(err) {
        if (feedback) { feedback.textContent = err.message || 'Error — try again'; feedback.style.color = '#dc2626'; setTimeout(function() { feedback.textContent = ''; feedback.style.color = ''; }, 4000); }
      })
      .finally(function() {
        atcBtn.disabled = false;
        atcBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>Add to Cart';
      });
    });
  }

})();
</script>
